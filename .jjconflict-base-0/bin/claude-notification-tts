#!/usr/bin/env bash
# Claude Code Notification hook: speaks the notification message in Korean
# via bin/say. Fires when Claude is asking for permission to use a tool, or
# when the prompt has been idle for the configured time.
#
# Hook contract: the Notification hook receives a JSON payload on stdin with
# at least:
#   { "session_id": "...", "transcript_path": "...", "message": "..." }
# We just read .message and speak a Korean translation/preface so the user
# gets an audible heads-up even when the terminal isn't focused.
#
# Output: print {"continue": true, "suppressOutput": true} so the hook is
# silent in the transcript.
set -u

DOTFILES_ROOT="${DOTFILES_ROOT:-$HOME/.dotfiles}"
SAY="$DOTFILES_ROOT/bin/say"
LOG_FILE="${CLAUDE_NOTIFY_TTS_LOG:-$HOME/.local/state/claude-notification-tts.log}"
mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true

# Trim log if it gets too big (mirrors claude-stop-tts).
if [ -f "$LOG_FILE" ] && [ "$(wc -l < "$LOG_FILE" 2>/dev/null || echo 0)" -gt 2000 ]; then
    tail -1000 "$LOG_FILE" > "$LOG_FILE.tmp" && mv "$LOG_FILE.tmp" "$LOG_FILE"
fi
log() { printf '[%s] %s\n' "$(date -Iseconds)" "$*" >> "$LOG_FILE"; }

# Always exit 0; print the no-op response — Notification hook errors would
# spam the transcript but not block anything.
trap 'printf "{\"continue\": true, \"suppressOutput\": true}\n"; exit 0' EXIT

input=$(cat)
log "stdin: $input"

# Pull the message field. Fall back to a generic prompt if empty.
msg=$(printf '%s' "$input" | jq -r '.message // empty' 2>/dev/null)
if [ -z "$msg" ]; then
    msg="Claude needs your attention"
fi

# Build the spoken text. The steering rule mandates the "도구 실행합니다"
# prefix for permission requests. Distinguish permission asks from idle
# warnings: the message text from Claude Code is one of:
#   "Claude needs your permission to use <tool>"
#   "Claude is waiting for your input"
# Match on the verb to choose the prefix.
case "$msg" in
    *permission*to\ use*|*permission*)
        # Extract tool name if present ("Claude needs your permission to use Bash" → "Bash")
        tool=$(printf '%s' "$msg" | sed -nE 's/.*permission to use ([A-Za-z0-9_-]+).*/\1/p')
        if [ -n "$tool" ]; then
            spoken="도구 실행합니다. ${tool} 사용 권한을 요청합니다."
        else
            spoken="도구 실행합니다. 권한이 필요합니다."
        fi
        ;;
    *waiting*for*input*|*idle*)
        spoken="입력을 기다리고 있습니다."
        ;;
    *)
        # Unknown message shape — speak it as-is in Korean preface form.
        # Cap length so a long English message doesn't read forever.
        capped="${msg:0:200}"
        spoken="알림: ${capped}"
        ;;
esac

log "spoken: $spoken"

if [ -x "$SAY" ]; then
    setsid "$SAY" "$spoken" </dev/null >/dev/null 2>&1 &
    log "spawned $SAY pid=$!"
else
    log "ABORT: $SAY not executable"
fi
disown 2>/dev/null || true

exit 0
