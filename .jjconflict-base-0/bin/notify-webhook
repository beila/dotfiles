#!/usr/bin/env bash
# notify-webhook — notification dispatcher with swappable backends.
#
# Usage:
#   notify-webhook [-t TITLE] [-p PRIORITY] [-u URL] MESSAGE
#
# Options:
#   -t TITLE      short title (bold where the backend supports it)
#   -p PRIORITY   low | normal | high | urgent (default: normal)
#   -u URL        optional related URL
#
# Environment:
#   NOTIFY_BACKEND   name of backend to use. If unset, auto-detected:
#                      - private-dotfiles/telegram.env present -> 'telegram'
#                      - otherwise                              -> 'none' (no-op)
#   DOTFILES_ROOT    default $HOME/.dotfiles
#
# Backends live in $DOTFILES_ROOT/script/logger/backends/<name>.sh and export a
# single function `notify_send TITLE PRIORITY URL MESSAGE`. If the chosen
# backend file does not exist, the dispatcher prints a diagnostic to stderr
# and returns 0, so callers that opt-in to notifications never fail on
# misconfigured machines.

set -u

# --- argument parsing -------------------------------------------------------
title=""
priority="normal"
url=""
while [ $# -gt 0 ]; do
    case "$1" in
        -t) title=$2; shift 2 ;;
        -p) priority=$2; shift 2 ;;
        -u) url=$2; shift 2 ;;
        --) shift; break ;;
        -*) echo "notify-webhook: unknown option $1" >&2; exit 2 ;;
        *)  break ;;
    esac
done
if [ $# -lt 1 ]; then
    echo "notify-webhook: missing MESSAGE" >&2
    exit 2
fi
message=$*

DOTFILES_ROOT=${DOTFILES_ROOT:-$HOME/.dotfiles}
BACKEND_DIR="$DOTFILES_ROOT/script/logger/backends"
PRIVATE_DIR="$DOTFILES_ROOT/private-dotfiles"

# --- backend selection ------------------------------------------------------
# Priority:
#   1. explicit NOTIFY_BACKEND env var
#   2. config-file auto-detection (telegram.env -> telegram, etc.)
#   3. 'none' (no-op)
if [ -z "${NOTIFY_BACKEND:-}" ]; then
    if [ -f "$PRIVATE_DIR/telegram.env" ]; then
        NOTIFY_BACKEND=telegram
    else
        NOTIFY_BACKEND=none
    fi
fi

BACKEND_FILE="$BACKEND_DIR/${NOTIFY_BACKEND}.sh"
if [ ! -f "$BACKEND_FILE" ]; then
    # Unknown backend -> silent no-op, log for diagnostics.
    echo "notify-webhook: backend '$NOTIFY_BACKEND' not found; skipping" >&2
    exit 0
fi

# shellcheck source=/dev/null
source "$BACKEND_FILE"

if ! command -v notify_send >/dev/null 2>&1; then
    echo "notify-webhook: backend '$NOTIFY_BACKEND' did not define notify_send()" >&2
    exit 1
fi

notify_send "$title" "$priority" "$url" "$message"
