#!/usr/bin/env bash
# Minimal MCP server exposing say and say-ko as tools
# Protocol: JSON-RPC 2.0 over stdio
# Test: bash test_mcp_tts.sh (run after any change)
set -euo pipefail

read_msg() {
  local line
  IFS= read -r line
  printf '%s' "$line"
}

send_msg() {
  printf '%s\n' "$1"
}

while true; do
  msg="$(read_msg)" || exit 0
  id="$(printf '%s' "$msg" | jq -r '.id // empty')"
  method="$(printf '%s' "$msg" | jq -r '.method // empty')"

  case "$method" in
    initialize)
      send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{\"protocolVersion\":\"2024-11-05\",\"capabilities\":{\"tools\":{}},\"serverInfo\":{\"name\":\"tts\",\"version\":\"1.0.0\"}}}"
      ;;
    notifications/initialized)
      ;;
    tools/list)
      send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"result\":{\"tools\":[{\"name\":\"say\",\"description\":\"Speak English text aloud via piper-tts (offline)\",\"inputSchema\":{\"type\":\"object\",\"properties\":{\"text\":{\"type\":\"string\",\"description\":\"Text to speak\"}},\"required\":[\"text\"]}},{\"name\":\"say_ko\",\"description\":\"Speak Korean text aloud via edge-tts (online)\",\"inputSchema\":{\"type\":\"object\",\"properties\":{\"text\":{\"type\":\"string\",\"description\":\"Text to speak in Korean\"}},\"required\":[\"text\"]}}]}}"
      ;;
    tools/call)
      tool="$(printf '%s' "$msg" | jq -r '.params.name')"
      text="$(printf '%s' "$msg" | jq -r '.params.arguments.text')"
      # Kill previous TTS playback before starting new one
      [ -n "${tts_pid:-}" ] && { kill -- -"$tts_pid" 2>/dev/null || true; }; tts_pid=
      case "$tool" in
        say)
          setsid ~/.dotfiles/bin/say "$text" &>/dev/null &
          tts_pid=$!
          send_msg "$(jq -nc --argjson id "$id" --arg text "Spoke: $text" '{"jsonrpc":"2.0","id":$id,"result":{"content":[{"type":"text","text":$text}]}}')"
          ;;
        say_ko)
          setsid ~/.dotfiles/bin/say-ko "$text" &>/dev/null &
          tts_pid=$!
          send_msg "$(jq -nc --argjson id "$id" --arg text "Spoke: $text" '{"jsonrpc":"2.0","id":$id,"result":{"content":[{"type":"text","text":$text}]}}')"
          ;;
        *)
          send_msg "$(jq -nc --argjson id "$id" --arg msg "Unknown tool: $tool" '{"jsonrpc":"2.0","id":$id,"error":{"code":-32601,"message":$msg}}')"
          ;;
      esac
      ;;
    *)
      [ -n "$id" ] && send_msg "{\"jsonrpc\":\"2.0\",\"id\":$id,\"error\":{\"code\":-32601,\"message\":\"Unknown method\"}}"
      ;;
  esac
done
