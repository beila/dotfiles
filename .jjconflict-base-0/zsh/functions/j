#!env zsh
# Run project's just inside a nix devshell. Logging is handled by the
# zz-logrun-auto.zsh accept-line widget on the outer prompt invocation
# (when `j` is in LOGRUN_AUTO_FUNCTIONS); this function no longer calls
# logrun itself.
#
# First arg may be one of:
#   +name / #name          — shortcut for .#name in the current-dir flake
#   .#name, XXX#YYY        — full nix installable (the "usual nix arg")
#   path:/github:/flake:…  — URL-form flake refs
# Otherwise uses the current dir's flake (. or path:.) as the installable.
local installable=""
case "$1" in
    [+#]*)
        installable=".#${1#[+#]}"; shift ;;
    *'#'*|path:*|github:*|flake:*|gitlab:*|sourcehut:*|git+*|tarball+*|file+*|hg+*)
        installable="$1"; shift ;;
esac

nix_develop_command() {
    which nix &> /dev/null || return
    local i="$installable"
    if [[ -z "$i" ]]; then
        test -f flake.nix || return
        if git ls-files 2>/dev/null | grep -qx 'flake.nix'; then
            i="."
        else
            i="path:."
        fi
    fi
    echo "nix develop $i --ignore-env --impure --keep VERBOSE --keep LOGRUN_PID --keep LOGRUN_MOVE_FILE --command"
}

set -x
$(nix_develop_command) just "$@"
