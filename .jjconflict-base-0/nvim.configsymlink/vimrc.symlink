set runtimepath+=~/.vim " for nvim

source ~/.vim/myvimrc
"source ~/.vim/macvimrc
source ~/.vim/ubunturc
if has("gui_running") || exists("g:neovide")
    source ~/.vim/gvimrc
    if exists("g:neovide")
    endif
else
    set mouse=
endif
"source ~/.vim/androidrc
"source ~/.vim/ignitionrc
"source ~/.vim/ignition-ps4.vimrc
"source ~/.vim/windows.vimrc
