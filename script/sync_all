#!/usr/bin/env bash
# Sync all known dotfiles/docs repos that exist on this machine
DOTFILES_ROOT="${DOTFILES_ROOT:-$HOME/.dotfiles}"
SYNC="$DOTFILES_ROOT/script/sync_dotfiles"
LOCKFILE="/tmp/sync_all.lock"

# Skip if already running
exec 9>"$LOCKFILE"
flock -n 9 || { echo "sync_all already running, skipping"; exit 0; }

TARGETS="$DOTFILES_ROOT $HOME/hjdocs $HOME/hjdocs/public-docs $HOME/pp/insuk-www"
TARGETS="$TARGETS $HOME/dev/hjdocs $HOME/dev/hjdocs/public-docs $HOME/dev/i"
TARGETS="$TARGETS $HOME/devc/hjdocs $HOME/devc/hjdocs/public-docs $HOME/devc/i $HOME/devc/i/devc1"
TARGETS="$TARGETS $HOME/devm/hjdocs $HOME/devm/hjdocs/public-docs $HOME/devm/i"

NOTIFY="$DOTFILES_ROOT/bin/notify-webhook"
HOST="$(hostnamectl --pretty 2>/dev/null || hostname)"

for dir in $TARGETS; do
    [ -d "$dir" ] && "$SYNC" "$dir" || "$NOTIFY" "⚠️ sync failed on $HOST: $dir"
done

# Snapshot all other jj repos (not in TARGETS)
"$DOTFILES_ROOT/script/jj_snapshot_all"
