#!/usr/bin/env bash
# Sync all jj/git repos under $HOME that have an 'hj' remote.
# sync_repo no-ops repos without hj, so we can run it broadly.
DOTFILES_ROOT="${DOTFILES_ROOT:-$HOME/.dotfiles}"
SYNC="$DOTFILES_ROOT/script/sync_repo"
DB="$HOME/.cache/plocate.db"

NOTIFY="$DOTFILES_ROOT/bin/notify-webhook"
HOST="$(hostnamectl --pretty 2>/dev/null || hostname)"

if [ ! -f "$DB" ]; then
    echo "plocate database not found at $DB" >&2
    exit 1
fi

{
    plocate --database "$DB" -r '/\.jj$'  2>/dev/null
    plocate --database "$DB" -r '/\.git$' 2>/dev/null
} | while read -r marker; do dirname "$marker"; done \
  | grep -Ev '/(\.cache|\.cargo|\.nix-profile|node_modules)(/|$)' \
  | sort -u | while read -r repo; do
    [ -d "$repo" ] || continue
    "$SYNC" "$repo" || "$NOTIFY" "⚠️ sync failed on $HOST: $repo"
done
