#!/usr/bin/env bash
# flake-update — weekly nix flake update + home-manager build dry-run.
#
# Why: nixos-unstable + home-manager unstable produce occasional breaking
# changes (deprecated options, schema migrations, package renames). Running
# `home-manager switch` blind on update day means the breakage shows up
# during a critical task. This timer runs the update + dry-build weekly,
# so the user finds out about a breakage on a Sunday morning instead of
# at 18:00 on a Thursday when the next switch happens to coincide with
# whatever they were doing.
#
# Flow:
#   1. `nix flake update` in home-manager.configsymlink/. Failures are
#      classified — network errors are WARN (transient), others ERROR.
#   2. `home-manager build --impure --flake .` (NOT switch). Build fail
#      → ERROR (notified). Success → continue.
#   3. `home-manager news --flake . --information-only` to read unread
#      news, pipe to claude for classification: BREAKING (notify) vs OK
#      (silent). claude unavailable / errors → silent INFO log; the user
#      can still grep the persisted log file.
#   4. flake.lock diff summary → INFO log (silent unless paired with an
#      ERROR earlier in the same run).
#
# `home-manager switch` is intentionally NOT run. The user controls when
# their machine actually changes; this script only signals that the next
# switch is going to break (or has news worth reading).
#
# Env knobs:
#   FLAKE_UPDATE_DRY_RUN=1     skip the actual `nix flake update` call
#                              (still runs build + news; useful for tests)
#   FLAKE_UPDATE_FLAKE_DIR     override the flake directory (default
#                              ~/.dotfiles/home-manager.configsymlink)
#   CLAUDECODE                 if set (we're inside Claude Code), skip
#                              the news classifier to avoid recursive
#                              nesting

set -uo pipefail

LOG_TAG=flake-update
DOTFILES_ROOT=${DOTFILES_ROOT:-$HOME/.dotfiles}
# shellcheck source=/dev/null
source "$DOTFILES_ROOT/script/logger/log.sh"

FLAKE_DIR="${FLAKE_UPDATE_FLAKE_DIR:-$DOTFILES_ROOT/home-manager.configsymlink}"

if [ ! -f "$FLAKE_DIR/flake.nix" ]; then
    log ERROR "no flake.nix at $FLAKE_DIR — set FLAKE_UPDATE_FLAKE_DIR or check the dotfiles layout"
    exit 1
fi

# Preflight: nix + home-manager on PATH. We want a clear actionable error
# rather than a confusing 'command not found' from the middle of a run.
for cmd in nix home-manager; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        log ERROR "$cmd not found on PATH — install nix or run 'home-manager switch' first"
        exit 1
    fi
done

cd "$FLAKE_DIR" || { log ERROR "cd $FLAKE_DIR failed"; exit 1; }

log INFO "START flake_dir=$FLAKE_DIR"

# Snapshot lock before so we can summarise what moved.
LOCK_BEFORE=$(mktemp /tmp/flake-update.lock.XXXXXX)
cp flake.lock "$LOCK_BEFORE" 2>/dev/null || true
trap 'rm -f "$LOCK_BEFORE"' EXIT

# --- Step 1: nix flake update -------------------------------------------------
if [ "${FLAKE_UPDATE_DRY_RUN:-}" = "1" ]; then
    log INFO "DRY-RUN: skipping nix flake update"
else
    err=$(mktemp /tmp/flake-update.err.XXXXXX)
    if ! nix flake update 2>"$err"; then
        first=$(head -2 "$err" | tr '\n' ' ')
        case "$first" in
            *"unable to download"*|*"Could not resolve"*|*"Connection"*|*"Network is unreachable"*|*"Temporary failure"*|*"timed out"*|*"timeout"*)
                # Transient. WARN (under default ERROR notify threshold).
                log WARN "NETWORK-ERR nix flake update: $first"
                rm -f "$err"
                exit 0  # Try again next week — not worth a phone alert.
                ;;
            *)
                log ERROR "nix flake update failed: $first"
                rm -f "$err"
                exit 1
                ;;
        esac
    fi
    rm -f "$err"
fi

# Did anything actually change?
if cmp -s "$LOCK_BEFORE" flake.lock; then
    log INFO "flake.lock unchanged — all inputs already at HEAD; skipping build + news"
    exit 0
fi

# --- Step 2: home-manager build (dry build, no activation) --------------------
err=$(mktemp /tmp/flake-update.err.XXXXXX)
if ! home-manager build --impure --flake . 2>"$err"; then
    # Build failure = the next `home-manager switch` will fail too. Page user.
    summary=$(grep -E "^error:|^warning:" "$err" | head -3 | tr '\n' ' | ')
    log ERROR "home-manager build FAILED after flake update — switch will break. Summary: ${summary:-see log}"
    log ERROR "first 20 lines of build stderr:"
    head -20 "$err" | while IFS= read -r line; do log ERROR "  $line"; done
    rm -f "$err"
    exit 1
fi
rm -f "$err"
log INFO "home-manager build OK"

# Result symlink is at ./result; remove it so the local working tree stays clean.
# (build creates a gcroot under /nix/var/nix/gcroots so the closure isn't GC'd.)
rm -f result

# --- Step 3: home-manager news → claude classifier ----------------------------
news_raw=$(home-manager news --flake . --information 2>/dev/null || true)
# Strip the always-present "Last checked" / "X news items" framing; keep
# the actual entry bodies. If nothing meaningful is left, treat as empty.
news_body=$(printf '%s\n' "$news_raw" | grep -v -E '^Last checked:|^[0-9]+ unread|^$' | head -200)

if [ -z "$news_body" ]; then
    log INFO "no unread home-manager news"
elif [ -n "${CLAUDECODE:-}" ]; then
    log INFO "claude skipped (running inside Claude Code session) — news preserved in log only"
    log INFO "--- news (unclassified) ---"
    printf '%s\n' "$news_body" | while IFS= read -r line; do log INFO "  $line"; done
elif ! command -v claude >/dev/null 2>&1; then
    log INFO "claude not installed — classifier skipped, news preserved in log only"
    log INFO "--- news (unclassified) ---"
    printf '%s\n' "$news_body" | while IFS= read -r line; do log INFO "  $line"; done
else
    prompt='Below is the output of `home-manager news`. Reply with exactly one line:
- `BREAKING: <one-sentence summary>` if any item describes a deprecation, removed option, behaviour change requiring user action, schema migration, or version pin that would affect a typical home-manager config.
- `OK` if all items are FYI, informational, new optional features, or housekeeping notes.
Be conservative — when in doubt, say OK. No code blocks, no preamble.

NEWS:
'
    classifier_output=$(printf '%s%s\n' "$prompt" "$news_body" \
        | timeout 30 claude --print --tools "" --no-session-persistence 2>/dev/null \
        | head -1 \
        | sed 's/\x1b\[[0-9;]*m//g; s/^[[:space:]]*//; s/[[:space:]]*$//')

    if [ -z "$classifier_output" ]; then
        log INFO "claude classifier returned empty — news preserved in log only"
        log INFO "--- news (unclassified) ---"
        printf '%s\n' "$news_body" | while IFS= read -r line; do log INFO "  $line"; done
    elif [[ "$classifier_output" == BREAKING:* ]]; then
        # WARN level so it sits between INFO (silent) and ERROR (urgent).
        # Default LOG_NOTIFY_THRESHOLD is ERROR so WARN doesn't notify; we
        # bump just this one line via a direct notify body.
        summary=${classifier_output#BREAKING:}
        summary=${summary# }
        log WARN "home-manager news flagged: $summary"
        log WARN "--- news body ---"
        printf '%s\n' "$news_body" | while IFS= read -r line; do log WARN "  $line"; done
        # Force-notify even though WARN is below the default threshold.
        # log.sh's notify path is internal; emit a single ERROR-level line
        # so the existing pipeline pages user. The log filename already
        # carries enough context.
        log ERROR "BREAKING home-manager news after flake update: $summary (see log for body)"
    else
        # Classifier said OK (or returned something we can't parse — be
        # conservative and treat unrecognised as OK rather than spamming).
        log INFO "claude classifier: $classifier_output (no notification)"
        log DEBUG "--- news body (silent) ---"
        printf '%s\n' "$news_body" | while IFS= read -r line; do log DEBUG "  $line"; done
    fi
fi

# --- Step 4: flake.lock summary ----------------------------------------------
# Diff the two lock files for human-readable input changes.
if command -v jq >/dev/null 2>&1; then
    moved=$(diff <(jq -r '.nodes | to_entries[] | "\(.key) \(.value.locked.rev // "?")"' "$LOCK_BEFORE" 2>/dev/null) \
                 <(jq -r '.nodes | to_entries[] | "\(.key) \(.value.locked.rev // "?")"' flake.lock 2>/dev/null) \
            | grep -E '^[<>] ' | head -20)
    if [ -n "$moved" ]; then
        log INFO "inputs moved:"
        printf '%s\n' "$moved" | while IFS= read -r line; do log INFO "  $line"; done
    fi
fi

log INFO "DONE flake_dir=$FLAKE_DIR"
