#!/usr/bin/env bash
# dlog — CLI wrapper around script/logger/log.sh.
# (named 'dlog' because zsh has a 'log' builtin that shadows PATH entries.)
#
# Makes leveled logging callable from any shell without sourcing log.sh,
# e.g. inside one-shot pipelines or from non-shell code.
#
# Usage:
#   LOG_TAG=my-script dlog LEVEL "message"
#   LOG_TAG=my-script LOG_CONTEXT=some-scope dlog ERROR "fell over"
#
# Required env:
#   LOG_TAG     identifies the script in the log file name
#
# Optional env: see log.sh for the full list.
#
# Exit status:
#   0 on success (line written; notification fired if threshold met)
#   1 if the lib cannot be located
#   non-zero passthrough on arg parsing errors

set -u

if [ "$#" -lt 2 ]; then
    echo "usage: dlog LEVEL \"message\"" >&2
    exit 2
fi

DOTFILES_ROOT=${DOTFILES_ROOT:-$HOME/.dotfiles}
LIB="$DOTFILES_ROOT/script/logger/log.sh"
if [ ! -f "$LIB" ]; then
    echo "dlog: cannot find $LIB" >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$LIB"
log "$@"
