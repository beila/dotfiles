#!/usr/bin/env bash
# Trace mode for manual debugging: SYNC_REPO_DEBUG=1 sync_repo …
# Off by default — systemd-driven runs are noisy enough already, and the
# leveled logger captures everything important to ~/.local/state/logs/.
if [ "${SYNC_REPO_DEBUG:-0}" = "1" ]; then
    set -x
fi
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
DOTFILES_ROOT=$(dirname "$SCRIPT_DIR")
GIT=${GIT_EXECUTABLE:-git}
MACHINE_NAME=$(hostnamectl --pretty 2>/dev/null | grep -v '\.')
MACHINE_NAME=${MACHINE_NAME:-$(hostname -s)}

# SSH hardening for all git/jj subprocesses. ConnectTimeout kills stalled
# handshakes fast; ServerAlive detects half-open connections (VPN drop, proxy
# freeze). BatchMode prevents password prompts that would deadlock under
# systemd. Caller can override by exporting GIT_SSH_COMMAND beforehand.
export GIT_SSH_COMMAND="${GIT_SSH_COMMAND:-ssh -o ConnectTimeout=10 -o ServerAliveInterval=15 -o ServerAliveCountMax=3 -o BatchMode=yes}"

# Outer timeout for each git/jj network call. Catches total process hangs
# that survive ssh-level timeouts (proxy wrappers, DNS stalls, etc.).
SYNC_REPO_CMD_TIMEOUT=${SYNC_REPO_CMD_TIMEOUT:-60}

cd "$1" || {
    echo "Error: No such directory as $1"; exit
}

# Silently skip non-jj repos. sync_all blindly hands us every .git/.jj marker
# under $HOME, including Brazil-managed checkouts (~/devc/, ~/.toolbox/) and
# any other plain-git repo. We don't sync those — converting a repo to jj
# (`jj git init --colocate`) is the explicit opt-in. No log line: matches the
# "no sync config" early-exit below in spirit (don't notify on no-ops).
jj root &>/dev/null || exit 0

# Per-repo lock to prevent concurrent syncs. Must key off the BACKING repo, not
# the workspace, because multiple jj workspaces (e.g. ~/dev/{pro,pro2,sawt}/src/IgnitionX)
# share one .jj store + op log under ~/brazil-repos/IgnitionX/.jj. Concurrent
# runs on different workspaces would otherwise race the shared op log (visible
# as branching `jj workspace update-stale` ops) and clobber the snapshot pushes.
# `jj git root` returns the shared .git path; `jj root` would return the
# per-workspace path and miss this.
LOCK_PATH=$(jj git root 2>/dev/null || echo "$1")
LOCKFILE="/tmp/sync_repo_$(echo "$LOCK_PATH" | tr / _).lock"
exec 9>"$LOCKFILE"
flock -n 9 || { echo "sync_repo already running for $LOCK_PATH, skipping"; exit 0; }

# --- structured logging + error classification --------------------------------
# Use log.sh's local default (~/.local/state/logs/) instead of the inherited
# ~/hjdocs/logs/, since this script syncs ~/hjdocs itself. Tests opt out via
# SYNC_LOG_ROOT_KEEP=1 to pin a tempdir.
if [ "${SYNC_LOG_ROOT_KEEP:-0}" != "1" ]; then
    unset LOG_ROOT LOG_REL_BASE LOG_NOTIFY_DEDUP_DIR
fi
LOG_TAG=sync_repo
# LOG_CONTEXT disambiguates between multiple workspaces / worktrees of the
# same repo. If we tried to use just `basename "$LOCK_PATH"` we'd get e.g.
# "IgnitionX" from both ~/dev/pro/src/IgnitionX and ~/dev/pro2/src/IgnitionX
# and the log files would collide.
#
# Strategy: take the path relative to $HOME, drop any 'dev/' / 'brazil-repos/'
# prefix noise, replace '/' with '-'. Keeps log file names short and unique.
_rel_home=${LOCK_PATH#$HOME/}
_rel_home=${_rel_home#dev/}
_rel_home=${_rel_home#brazil-repos/}
LOG_CONTEXT=$(printf '%s' "$_rel_home" | tr / -)
# shellcheck source=/dev/null
source "$DOTFILES_ROOT/script/logger/log.sh"

# classify_cmd <tag> <cmd...>
# Run <cmd...>, capture stderr, classify failure as NETWORK (usually transient
# -> WARN) or OTHER (-> ERROR). Returns the original exit code.
# Sets $_LAST_CLASSIFICATION to OK / TIMEOUT / BENIGN-DEL / NETWORK-ERR / OTHER-ERR
# so callers can branch on the kind of failure (e.g. push_force_replace only
# proceeds with the push if the preceding delete was successful or benign).
# Network-pattern heuristics based on git/ssh/curl error strings.
_LAST_CLASSIFICATION=""
classify_cmd() {
    local tag=$1; shift
    local err rc
    err=$(mktemp "/tmp/sync_repo_err.XXXXXX")
    "$@" 2>"$err"
    rc=$?
    _LAST_CLASSIFICATION=OK
    if [ $rc -ne 0 ]; then
        if [ $rc -eq 124 ] || [ $rc -eq 137 ]; then
            # timeout(1) exit codes: 124 (SIGTERM expired), 137 (SIGKILL after grace).
            _LAST_CLASSIFICATION=TIMEOUT
            log WARN "TIMEOUT $tag: exceeded ${SYNC_REPO_CMD_TIMEOUT}s; killed"
        elif grep -qE 'remote ref does not exist|unable to delete.*remote ref|does not appear to be a git repository' "$err"; then
            # Benign: deleting a branch that isn't on the remote. Happens on
            # every run for push-del of hostname-prefixed snapshots after their
            # first failed push, or when a snapshot was never pushed. Log at
            # DEBUG so we keep a trace without paging anyone.
            _LAST_CLASSIFICATION=BENIGN-DEL
            log DEBUG "BENIGN-DEL $tag: $(head -1 "$err")"
        elif grep -qE 'Could not resolve hostname|Could not read from remote repository|Connection (refused|timed out|reset)|Network is unreachable|No route to host|Temporary failure in name resolution|kex_exchange_identification|Operation timed out|Failed to connect to|SSL_ERROR|remote end hung up|RPC failed|Another user is currently pushing' "$err"; then
            # 'Another user is currently pushing' is gitfarm's message when the
            # repo is locked by a concurrent git-receive-pack. Transient — the
            # next sync_repo run will retry.
            _LAST_CLASSIFICATION=NETWORK-ERR
            log WARN "NETWORK-ERR $tag: $(head -2 "$err" | tr '\n' ' ')"
        else
            _LAST_CLASSIFICATION=OTHER-ERR
            log ERROR "OTHER-ERR $tag (rc=$rc): $(head -2 "$err" | tr '\n' ' ')"
        fi
        # Forward stderr to the process stderr so set -x / systemd journal still see it
        cat "$err" >&2
    fi
    rm -f "$err"
    return $rc
}

# push_force_replace <tag> <url> <commit> <branch>
# Emulate force-push via delete+push for servers that reject --force (gitfarm).
# Only push if the delete actually removed the ref OR the ref didn't exist —
# otherwise the push would fail non-fast-forward and the bogus OTHER-ERR masks
# the real cause (concurrent push, transient network, server hook). Next
# sync_repo run retries the cycle cleanly.
#
# Pushes to a URL directly (not a configured remote name) so git does NOT
# update local refs/remotes/<remote>/* tracking refs. This keeps jj's view
# free of hostname-prefixed remote bookmarks — they exist only on the server,
# never in the local jj/git store.
push_force_replace() {
    local tag=$1 url=$2 commit=$3 branch=$4
    timeout_cmd "push-del $tag" git --git-dir="$GIT_DIR" push "$url" --delete "$branch"
    local del_class=$_LAST_CLASSIFICATION
    case "$del_class" in
        OK|BENIGN-DEL)
            timeout_cmd "push $tag" git --git-dir="$GIT_DIR" push "$url" "${commit}:${branch}" || true
            ;;
        *)
            log WARN "SKIP-PUSH $tag: delete failed (${del_class:-unknown}); will retry next run"
            ;;
    esac
}

# timeout_cmd <tag> <cmd...>
# classify_cmd wrapped in timeout(1). --kill-after sends SIGKILL 10s after
# the initial SIGTERM if the child refuses to die. Total max wall time:
# $SYNC_REPO_CMD_TIMEOUT + 10s.
timeout_cmd() {
    local tag=$1; shift
    classify_cmd "$tag" timeout --kill-after=10 "$SYNC_REPO_CMD_TIMEOUT" "$@"
}

# --- jj branch helpers --------------------------------------------------------
# Step functions read these globals (set in main):
#   PUSH_REV, GIT_DIR, WORKSPACE_NAME, SNAPSHOT_URL, SYNC_BM, SYNC_REMOTE,
#   MACHINE_NAME, DOTFILES_ROOT, SYNC_REPO_CMD_TIMEOUT.

# Pick a stable single-rev change_id even when @ is an empty merge. One jj
# call to snapshot @ avoids races with concurrent jj.
snapshot_at_to_push_rev() {
    local at_info change_id is_empty is_merge has_desc parent_change_id msg
    at_info=$(jj log -r @ --no-graph -T 'change_id ++ "|" ++ if(empty, "1", "0") ++ "|" ++ if(parents.len() > 1, "1", "0") ++ "|" ++ if(description, "1", "0") ++ "|" ++ parents.map(|p| p.change_id()).join(",")' 2>/dev/null)
    IFS='|' read -r change_id is_empty is_merge has_desc parent_change_id <<<"$at_info"
    if [ "$is_empty" = "0" ] || [ "$is_merge" = "1" ]; then
        jj new
        if [ "$is_empty" = "0" ] && [ "$has_desc" = "0" ]; then
            if ! msg=$(VERBOSE=1 "$DOTFILES_ROOT/bin/commit-msg" "$change_id"); then
                echo "commit-msg failed" >&2
                exit 1
            fi
            jj describe "$change_id" -m "$msg"
        fi
        PUSH_REV=$change_id
    else
        PUSH_REV=$parent_change_id
    fi
}

# `jj git root` is authoritative now that the script only handles jj repos.
# Step 2's `jj workspace update-stale` (run before this) ensures the op log
# is fresh, so transient stale-view failures are rare and self-recover on the
# next cycle.
resolve_git_dir() {
    GIT_DIR=$(jj git root 2>/dev/null)
}

# Find which workspace this run is operating on. Multiple workspaces share
# one `.jj/repo` store + op log (e.g. ~/dev/{pro,pro2}/src/IgnitionX both
# share ~/brazil-repos/IgnitionX/.jj), so the only signal that distinguishes
# "which workspace am I in" is matching @'s commit_id against the per-
# workspace target_id from `jj workspace list`. Sets WORKSPACE_NAME (empty
# if no match — caller decides whether that's fatal).
resolve_workspace_name() {
    local at_commit
    at_commit=$(jj log -r @ --no-graph -T 'commit_id' 2>/dev/null)
    WORKSPACE_NAME=$(jj workspace list -T 'self.name() ++ " " ++ self.target().commit_id() ++ "\n"' 2>/dev/null | awk -v c="$at_commit" '$2 == c {print $1; exit}')
}

# Detect files jj refuses to snapshot (size limit). Such files silently
# bypass the entire sync — surface as ERROR so the user can either delete
# the file or raise snapshot.max-new-file-size for this repo.
check_refused_snapshots() {
    local err
    err=$(jj status 2>&1 1>/dev/null)
    if echo "$err" | grep -q "Refused to snapshot"; then
        local files
        files=$(echo "$err" | awk '
            /Refused to snapshot/ { flag=1; next }
            flag && /^  / && /MiB \(/ {
                sub(/^  /, ""); sub(/:.*$/, ""); print
            }
        ' | tr '\n' ' ')
        log ERROR "REFUSED-SNAPSHOT not backed up: ${files}(raise snapshot.max-new-file-size or delete the file)"
    fi
}

# --- Snapshot push (purely additive — no local changes) -----------------------
# Writes per-host snapshots of the working state to refs/heads/<MACHINE>/<NAME>
# on the snapshot URL via raw git. Two reasons to push directly to the URL
# instead of through a configured remote:
#   1. No local refs/remotes/<remote>/* tracking refs get updated, so jj never
#      imports these snapshots as remote bookmarks. The `jj log` and
#      `jj bookmark list` views stay clean.
#   2. The script doesn't need a `backup` remote configured in either git or
#      jj — sync.snapshot-url is the single source of truth.
#
# The snapshot is the safety net: it MUST run BEFORE step_sync_remote_bookmark
# touches local state (rebase / bookmark advance / etc.), so a botched
# bookmark sync never destroys work that hasn't been backed up.

step_push_workspace_snapshot() {
    [ -n "$SNAPSHOT_URL" ] || return 0
    [ -n "$WORKSPACE_NAME" ] || return 0
    local current_commit ws_branch
    current_commit=$(jj log -r "$PUSH_REV" --no-graph -T 'commit_id' 2>/dev/null)
    [ -n "$current_commit" ] || return 0
    ws_branch="refs/heads/${MACHINE_NAME}/${WORKSPACE_NAME}"
    push_force_replace "${MACHINE_NAME}/${WORKSPACE_NAME}" "$SNAPSHOT_URL" "$current_commit" "$ws_branch"
}

# Snapshot every non-host-prefixed local bookmark under MACHINE/<bookmark>.
# Only runs in the default workspace: jj's local bookmarks are repo-scoped
# (shared across all workspaces of a `.jj/repo`), so other workspaces would
# just push redundant copies of the same refs the default workspace already
# pushed. The grep filter excludes any leftover hostname-prefixed bookmarks
# from old sync_repo runs (the new flow doesn't create them locally).
step_push_local_bookmark_snapshots() {
    [ -n "$SNAPSHOT_URL" ] || return 0
    [ "$WORKSPACE_NAME" = "default" ] || return 0
    local bm ref
    for bm in $(jj bookmark list -T 'name ++ "\n"' 2>/dev/null | grep -v "^${MACHINE_NAME}/" | sort -u); do
        ref=$(jj log -r "$bm" --no-graph -T 'commit_id' 2>/dev/null) || continue
        push_force_replace "${MACHINE_NAME}/${bm}" "$SNAPSHOT_URL" "$ref" "refs/heads/${MACHINE_NAME}/${bm}"
    done
}

# --- Sync-bookmark sync (jj-mediated, may modify local state) -----------------
# Fetches ONLY the configured bookmark from the configured remote — narrow
# refspec means hostname-prefixed snapshots from this or other hosts never
# enter jj's view at all. Rebase/push of the local working copy follow.

ancestry_class() {
    local local_rev=$1 remote_rev=$2
    if [ "$local_rev" = "$remote_rev" ]; then
        echo equal
    elif jj log -r "$local_rev & ::$remote_rev" --no-graph -T '"y"' 2>/dev/null | grep -q y; then
        echo local-ancestor
    elif jj log -r "$remote_rev & ::$local_rev" --no-graph -T '"y"' 2>/dev/null | grep -q y; then
        echo remote-ancestor
    else
        echo diverged
    fi
}

# Probe a 3-way merge of L and R before mutating bookmarks. The probe shares
# conflict semantics with the actual rebase (both reduce to a 3-way merge of
# common-ancestor / L / R), so a clean probe guarantees a clean rebase — and
# we leave a clear retry surface on conflict.
handle_diverged() {
    local local_rev=$1 remote_rev=$2
    local probe_change conflict_files
    # resolve-by-attrs is the .gitattributes-driven auto-resolver. Looked up
    # once here so both the probe-resolution path and the post-rebase path
    # can use it. Empty if not installed — both paths check.
    local resolver="$SCRIPT_DIR/bin/resolve-by-attrs"
    [ -x "$resolver" ] || resolver=""
    if ! jj new --no-edit "$local_rev" "$remote_rev" -m "rebase-probe" 2>/dev/null; then
        log CRITICAL "REBASE-PROBE-FAIL ${SYNC_BM} local=$local_rev remote=$remote_rev; skipping push"
        echo "WARNING: failed to create rebase probe for $SYNC_BM; skipping push" >&2
        return 0
    fi
    probe_change=$(jj log -r 'latest("'"$local_rev"'"+ & "'"$remote_rev"'"+, 1)' --no-graph -T 'change_id' 2>/dev/null | head -1)
    if [ -z "$probe_change" ]; then
        log CRITICAL "REBASE-PROBE-FAIL ${SYNC_BM}: could not locate probe commit"
        echo "WARNING: could not locate rebase probe for $SYNC_BM; skipping push" >&2
        return 0
    fi
    if jj log -r "$probe_change" --no-graph -T 'if(conflict, "conflict")' 2>/dev/null | grep -q conflict; then
        conflict_files=$(jj resolve --list -r "$probe_change" 2>/dev/null | awk 'NF {print $1}' | paste -sd, -)
        # Best-effort: try to clear the probe's conflicts via .gitattributes
        # merge=<driver> directives. We pass `-r <probe>` to the resolver so
        # @ stays where it was — using `jj edit` would carry the working-copy
        # snapshot onto the probe and corrupt its content.
        local remaining
        if [ -n "$resolver" ]; then
            "$resolver" -r "$probe_change" >/dev/null 2>&1 || true
            remaining=$(jj resolve --list -r "$probe_change" 2>/dev/null | awk 'NF {print $1}' | paste -sd, -)
        else
            remaining="$conflict_files"
        fi

        if [ -n "$remaining" ]; then
            log ERROR "REBASE-CONFLICT ${SYNC_BM} files=${remaining} local=$local_rev remote=$remote_rev"
            echo "WARNING: rebase has conflicts in ${remaining}; skipping push for $SYNC_BM" >&2
            jj abandon "$probe_change" 2>/dev/null || true
            # Mark that the bookmark sync hit a conflict so step_rebase_local_chain
            # doesn't follow up by rebasing the working copy onto the remote tip
            # (that would re-introduce the conflict markers into @- and silently
            # diverge from the snapshot we just pushed).
            SYNC_CONFLICT=1
            return 0
        fi
        log INFO "RESOLVED-BY-ATTRS ${SYNC_BM} files=${conflict_files} (cleared by .gitattributes drivers)"
        # Probe is now clean — fall through to the linear-rebase path below.
        # The real rebase will re-create the conflict, so we must run the
        # resolver again on the rebased tip before push.
    fi
    jj abandon "$probe_change" 2>/dev/null || true
    # Save op id so we can rewind if the rebase ends up in a state we can't
    # auto-resolve. Without this, a partial driver resolution would litter
    # the working copy with first-class conflict commits that the user has
    # to clean up manually.
    local pre_rebase_op
    pre_rebase_op=$(jj op log --no-graph --limit 1 -T 'id.short()' 2>/dev/null)
    if ! jj rebase -s 'roots(::'"$local_rev"' ~ ::'"$remote_rev"')' -d "$remote_rev" 2>/dev/null; then
        log CRITICAL "REBASE-FAIL ${SYNC_BM} local=$local_rev remote=$remote_rev"
        echo "WARNING: jj rebase failed for $SYNC_BM; skipping push" >&2
        return 0
    fi
    # If the rebase produced first-class conflicts at @- (it will when probe
    # was driver-resolved, since rebase doesn't re-apply driver merges),
    # try resolve-by-attrs once more on @-. If anything remains, rewind to
    # the pre-rebase op so the working copy doesn't carry conflict markers.
    if jj log -r '@-' --no-graph -T 'if(conflict, "conflict")' 2>/dev/null | grep -q conflict; then
        if [ -n "$resolver" ] && [ -n "$pre_rebase_op" ]; then
            local post_change post_remaining
            post_change=$(jj log -r '@-' --no-graph -T 'change_id' 2>/dev/null)
            "$resolver" -r "$post_change" >/dev/null 2>&1 || true
            post_remaining=$(jj resolve --list -r "$post_change" 2>/dev/null | awk 'NF {print $1}' | paste -sd, -)
            if [ -n "$post_remaining" ]; then
                log ERROR "REBASE-CONFLICT ${SYNC_BM} files=${post_remaining} local=$local_rev remote=$remote_rev (after rebase auto-resolve attempt)"
                echo "WARNING: rebase has conflicts in ${post_remaining}; rewinding and skipping push for $SYNC_BM" >&2
                jj op restore "$pre_rebase_op" 2>/dev/null || true
                SYNC_CONFLICT=1
                return 0
            fi
        else
            # No resolver available; rewind so we don't push conflict markers.
            log ERROR "REBASE-CONFLICT ${SYNC_BM} (rebased commit conflicted; no resolver available)"
            [ -n "$pre_rebase_op" ] && jj op restore "$pre_rebase_op" 2>/dev/null || true
            SYNC_CONFLICT=1
            return 0
        fi
    fi
    # Push the rebased local tip. The rebased commit follows @- (since we
    # rebased commits reachable from @-); set a transient local bookmark there
    # for jj git push to consume, then push.
    jj bookmark create "$SYNC_BM" -r "@-" 2>/dev/null \
        || jj bookmark set "$SYNC_BM" -r "@-" --allow-backwards 2>/dev/null
    # jj 0.40+ requires the local bookmark to be tracking the remote one
    # before push — otherwise it errors "Non-tracking remote bookmark exists".
    jj bookmark track "${SYNC_BM}@${SYNC_REMOTE}" 2>/dev/null || true
    local rebased_rev
    rebased_rev=$(jj log -r "@-" --no-graph -T 'commit_id' 2>/dev/null)
    if timeout_cmd "push $SYNC_BM (rebased)" jj git push --remote "$SYNC_REMOTE" --bookmark "$SYNC_BM"; then
        log INFO "PUSH-OK ${SYNC_BM}@${SYNC_REMOTE} rev=$rebased_rev (rebased local=$local_rev remote=$remote_rev)"
    fi
}

# Compare against the REMOTE bookmark (NAME@REMOTE) directly — no local
# bookmark needs to exist for the comparison. We only create a transient
# local bookmark when we're about to push, because `jj git push --bookmark X`
# requires X to exist locally.
#
# After fetch, a bare bookmark name like "master" can become ambiguous if both
# local and remote diverge. Resolving against `@-` (commit_id) before fetch
# bypasses that — @- is always a stable revset.
step_sync_remote_bookmark() {
    [ -n "$SYNC_BM" ] || return 0

    # Skip cleanly when the configured remote isn't set up in jj. Common case:
    # a sub-repo inherits sync.remote-bookmark via a parent --when.repositories
    # scope but has no `backup` (or whichever) remote of its own. Logged at
    # INFO so it doesn't trip the ERROR notification.
    if ! jj git remote list 2>/dev/null | awk '{print $1}' | grep -qx "$SYNC_REMOTE"; then
        log INFO "SKIP ${SYNC_BM}@${SYNC_REMOTE}: remote '${SYNC_REMOTE}' not configured"
        return 0
    fi

    local local_rev remote_rev
    local_rev=$(jj log -r "@-" --no-graph -T 'commit_id' 2>/dev/null)

    if ! timeout_cmd "fetch ${SYNC_BM}@${SYNC_REMOTE}" jj git fetch --remote "$SYNC_REMOTE" --branch "$SYNC_BM"; then
        # Skip push: stale ${SYNC_BM}@${SYNC_REMOTE} would route us to a
        # wrong-path push (e.g. "new bookmark" full-history push on transient
        # timeout). Next sync_repo run retries from a fresh fetch.
        log INFO "SKIP-PUSH ${SYNC_BM}: fetch failed; will retry next run"
        return 0
    fi
    log INFO "FETCH-OK ${SYNC_BM}@${SYNC_REMOTE}"

    remote_rev=$(jj log -r "${SYNC_BM}@${SYNC_REMOTE}" --no-graph -T 'commit_id' 2>/dev/null)

    if [ -z "$remote_rev" ]; then
        # Remote bookmark doesn't exist yet — push our local @- to create it.
        # Need a local bookmark for jj git push.
        jj bookmark create "$SYNC_BM" -r "@-" 2>/dev/null \
            || jj bookmark set "$SYNC_BM" -r "@-" --allow-backwards 2>/dev/null
        if timeout_cmd "push $SYNC_BM (new)" jj git push --remote "$SYNC_REMOTE" --bookmark "$SYNC_BM" --allow-new; then
            log INFO "PUSH-OK ${SYNC_BM}@${SYNC_REMOTE} rev=$local_rev (new)"
            # Track post-push so future runs see ${SYNC_BM}@${SYNC_REMOTE}
            # as tracked and can push without --allow-new.
            jj bookmark track "${SYNC_BM}@${SYNC_REMOTE}" 2>/dev/null || true
        fi
        return 0
    fi

    case "$(ancestry_class "$local_rev" "$remote_rev")" in
        equal)
            log INFO "SKIP ${SYNC_BM}@${SYNC_REMOTE} already at $remote_rev"
            ;;
        local-ancestor)
            # Remote is ahead of local. The local working copy stays where it
            # is (don't yank @ around without user intent). step_rebase_local
            # below moves any local mutable commits onto the new remote tip.
            log INFO "FAST-FORWARD ${SYNC_BM}@${SYNC_REMOTE} local=$local_rev <- remote=$remote_rev"
            ;;
        remote-ancestor)
            # Local is ahead of remote. Set transient local bookmark at @- and push.
            jj bookmark create "$SYNC_BM" -r "@-" 2>/dev/null \
                || jj bookmark set "$SYNC_BM" -r "@-" --allow-backwards 2>/dev/null
            jj bookmark track "${SYNC_BM}@${SYNC_REMOTE}" 2>/dev/null || true
            if timeout_cmd "push $SYNC_BM (ahead)" jj git push --remote "$SYNC_REMOTE" --bookmark "$SYNC_BM"; then
                log INFO "PUSH-OK ${SYNC_BM}@${SYNC_REMOTE} rev=$local_rev (ahead)"
            fi
            ;;
        diverged)
            handle_diverged "$local_rev" "$remote_rev"
            ;;
    esac
}

# Rebase any local mutable commits between @- and the remote bookmark onto
# the remote bookmark tip. Keeps the local working copy parented on a current
# remote even when the user's @- is behind a fast-forwarded remote.
#
# Skipped when the bookmark sync hit a conflict (SYNC_CONFLICT=1): rebasing
# a conflicting local chain onto the remote would write conflict markers into
# the working copy AND quietly desynchronize @- from the snapshot we already
# pushed. The user should resolve the divergence manually.
step_rebase_local_chain() {
    [ -n "$SYNC_BM" ] || return 0
    [ "${SYNC_CONFLICT:-0}" = "1" ] && return 0
    jj rebase -s "roots(mutable() & ::@ ~ ::${SYNC_BM}@${SYNC_REMOTE})" -d "${SYNC_BM}@${SYNC_REMOTE}" 2>/dev/null || true
}

# --- main ---------------------------------------------------------------------
log INFO "START"

# Read sync configuration. Both keys are independently optional:
#   sync.remote-bookmark = "BOOKMARK@REMOTE"   (e.g. "main@backup")
#     Drives the bookmark-sync flow: jj git fetch --branch + jj git push.
#   sync.snapshot-url    = "git@server:path"
#     Drives the per-host snapshot flow: raw git push to URL with no jj
#     remote tracking. Snapshots happen FIRST so they always land before
#     the bookmark-sync flow makes any local changes.
SYNC_BM=""
SYNC_REMOTE=""
remote_bookmark=$(jj config get sync.remote-bookmark 2>/dev/null || true)
if [ -n "$remote_bookmark" ]; then
    case "$remote_bookmark" in
        *@*)
            SYNC_BM="${remote_bookmark%@*}"
            SYNC_REMOTE="${remote_bookmark##*@}"
            ;;
        *)
            log ERROR "BAD-CONFIG sync.remote-bookmark='$remote_bookmark' must be 'BOOKMARK@REMOTE' format"
            exit 1
            ;;
    esac
    if [ -z "$SYNC_BM" ] || [ -z "$SYNC_REMOTE" ]; then
        log ERROR "BAD-CONFIG sync.remote-bookmark='$remote_bookmark' has empty bookmark or remote"
        exit 1
    fi
fi
SNAPSHOT_URL=$(jj config get sync.snapshot-url 2>/dev/null || true)

if [ -z "$SYNC_BM" ] && [ -z "$SNAPSHOT_URL" ]; then
    log INFO "NO-SYNC-CONFIG: neither sync.remote-bookmark nor sync.snapshot-url set"
    exit 0
fi

jj workspace update-stale 2>/dev/null || true

# Surface files that jj refuses to snapshot (size limit). Those files
# silently bypass the whole sync — flag them as ERROR so the user can
# either delete or raise snapshot.max-new-file-size per repo.
check_refused_snapshots

snapshot_at_to_push_rev
resolve_git_dir
resolve_workspace_name

# Generalize absolute home-directory paths to portable placeholders before
# push. `jj fix` runs whatever fix tools are configured globally (see
# jj.configsymlink/config.toml — currently `generalize-paths`); this is
# generic plumbing, not specific to that one tool. Restricted to local-only
# commits (`<bookmark>@<remote>..@-` when a remote bookmark is configured,
# else just `@-`) so we never rewrite commits that are already on the
# remote — that would create divergence on push.
step_run_jj_fix() {
    local revset="@-"
    if [ -n "$SYNC_BM" ]; then
        # Confirm the remote bookmark exists locally before using it as
        # an ancestor anchor. If fetch hasn't run yet (e.g. first sync on
        # a new clone) it might not, so fall back to just @-.
        if jj log -r "${SYNC_BM}@${SYNC_REMOTE}" --no-graph -T '"y"' 2>/dev/null | grep -q y; then
            revset="${SYNC_BM}@${SYNC_REMOTE}..@-"
        fi
    fi
    # Quiet unless something changed; jj fix prints "Nothing changed."
    # when the tools were no-ops, which is the steady-state expectation.
    jj fix -s "$revset" 2>/dev/null || true
}
step_run_jj_fix

# CRITICAL ORDER: snapshot push FIRST (purely additive, no local state mutation).
# Whatever the user has in the working copy gets backed up to the snapshot URL
# before any rebase / bookmark advance / merge probe can possibly disturb it.
step_push_workspace_snapshot
step_push_local_bookmark_snapshots

# Bookmark sync runs AFTER the safety-net push. May rebase local commits and
# advance/create the local bookmark for push purposes.
step_sync_remote_bookmark
step_rebase_local_chain
