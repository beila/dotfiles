#!/usr/bin/env bash
# Trace mode for manual debugging: SYNC_REPO_DEBUG=1 sync_repo …
# Off by default — systemd-driven runs are noisy enough already, and the
# leveled logger captures everything important to ~/hjdocs/logs/.
if [ "${SYNC_REPO_DEBUG:-0}" = "1" ]; then
    set -x
fi
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
DOTFILES_ROOT=$(dirname "$SCRIPT_DIR")
GIT=${GIT_EXECUTABLE:-git}
GIT_SUBREPO=${GIT_SUBREPO:-git-subrepo}
MACHINE_NAME=$(hostnamectl --pretty 2>/dev/null | grep -v '\.')
MACHINE_NAME=${MACHINE_NAME:-$(hostname -s)}

# SSH hardening for all git/jj subprocesses. ConnectTimeout kills stalled
# handshakes fast; ServerAlive detects half-open connections (VPN drop, proxy
# freeze). BatchMode prevents password prompts that would deadlock under
# systemd. Caller can override by exporting GIT_SSH_COMMAND beforehand.
export GIT_SSH_COMMAND="${GIT_SSH_COMMAND:-ssh -o ConnectTimeout=10 -o ServerAliveInterval=15 -o ServerAliveCountMax=3 -o BatchMode=yes}"

# Outer timeout for each git/jj network call. Catches total process hangs
# that survive ssh-level timeouts (proxy wrappers, DNS stalls, etc.).
SYNC_REPO_CMD_TIMEOUT=${SYNC_REPO_CMD_TIMEOUT:-60}

cd "$1" || {
    echo "Error: No such directory as $1"; exit
}

# Per-repo lock to prevent concurrent syncs. Must key off the BACKING repo, not
# the workspace, because multiple jj workspaces (e.g. ~/dev/{pro,pro2,sawt}/src/IgnitionX)
# share one .jj store + op log under ~/brazil-repos/IgnitionX/.jj. Concurrent
# runs on different workspaces would otherwise race the shared op log (visible
# as branching `jj workspace update-stale` ops) and clobber Step 1's shared
# sync.bookmark (e.g. taygeta/pro), producing divergent change_ids.
# jj git root / git rev-parse --git-dir return the shared .git path; jj root
# would return the per-workspace path and miss this.
LOCK_PATH=$(jj git root 2>/dev/null || git rev-parse --git-dir 2>/dev/null | xargs -I{} readlink -f {} 2>/dev/null || echo "$1")
LOCKFILE="/tmp/sync_repo_$(echo "$LOCK_PATH" | tr / _).lock"
exec 9>"$LOCKFILE"
flock -n 9 || { echo "sync_repo already running for $LOCK_PATH, skipping"; exit 0; }

# --- structured logging + error classification --------------------------------
# Uses the shared leveled logger at script/logger/log.sh. It writes to
# ~/hjdocs/logs/<machine>/sync_repo.<repo-basename>.<date>[.<time>].log and
# dispatches notifications for ERROR and above via bin/notify-webhook.
# Notifications auto-suppress when stderr is a TTY (interactive runs don't
# ping the phone); override with LOG_NOTIFY_MODE={always|never}.
LOG_TAG=sync_repo
# LOG_CONTEXT disambiguates between multiple workspaces / worktrees of the
# same repo. If we tried to use just `basename "$LOCK_PATH"` we'd get e.g.
# "IgnitionX" from both ~/dev/pro/src/IgnitionX and ~/dev/pro2/src/IgnitionX
# and the log files would collide.
#
# Strategy: take the path relative to $HOME, drop any 'dev/' / 'brazil-repos/'
# prefix noise, replace '/' with '-'. Keeps log file names short and unique.
_rel_home=${LOCK_PATH#$HOME/}
_rel_home=${_rel_home#dev/}
_rel_home=${_rel_home#brazil-repos/}
LOG_CONTEXT=$(printf '%s' "$_rel_home" | tr / -)
# shellcheck source=/dev/null
source "$DOTFILES_ROOT/script/logger/log.sh"

# classify_cmd <tag> <cmd...>
# Run <cmd...>, capture stderr, classify failure as NETWORK (usually transient
# -> WARN) or OTHER (-> ERROR). Returns the original exit code.
# Sets $_LAST_CLASSIFICATION to OK / TIMEOUT / BENIGN-DEL / NETWORK-ERR / OTHER-ERR
# so callers can branch on the kind of failure (e.g. push_force_replace only
# proceeds with the push if the preceding delete was successful or benign).
# Network-pattern heuristics based on git/ssh/curl error strings.
_LAST_CLASSIFICATION=""
classify_cmd() {
    local tag=$1; shift
    local err rc
    err=$(mktemp "/tmp/sync_repo_err.XXXXXX")
    "$@" 2>"$err"
    rc=$?
    _LAST_CLASSIFICATION=OK
    if [ $rc -ne 0 ]; then
        if [ $rc -eq 124 ] || [ $rc -eq 137 ]; then
            # timeout(1) exit codes: 124 (SIGTERM expired), 137 (SIGKILL after grace).
            _LAST_CLASSIFICATION=TIMEOUT
            log WARN "TIMEOUT $tag: exceeded ${SYNC_REPO_CMD_TIMEOUT}s; killed"
        elif grep -qE 'remote ref does not exist|unable to delete.*remote ref|does not appear to be a git repository' "$err"; then
            # Benign: deleting a branch that isn't on the remote. Happens on
            # every run for push-del of hostname-prefixed bookmarks after their
            # first failed push, or when a bookmark was never pushed. Log at
            # DEBUG so we keep a trace without paging anyone.
            _LAST_CLASSIFICATION=BENIGN-DEL
            log DEBUG "BENIGN-DEL $tag: $(head -1 "$err")"
        elif grep -qE 'Could not resolve hostname|Could not read from remote repository|Connection (refused|timed out|reset)|Network is unreachable|No route to host|Temporary failure in name resolution|kex_exchange_identification|Operation timed out|Failed to connect to|SSL_ERROR|remote end hung up|RPC failed|Another user is currently pushing' "$err"; then
            # 'Another user is currently pushing' is gitfarm's message when the
            # repo is locked by a concurrent git-receive-pack. Transient — the
            # next sync_repo run will retry.
            _LAST_CLASSIFICATION=NETWORK-ERR
            log WARN "NETWORK-ERR $tag: $(head -2 "$err" | tr '\n' ' ')"
        else
            _LAST_CLASSIFICATION=OTHER-ERR
            log ERROR "OTHER-ERR $tag (rc=$rc): $(head -2 "$err" | tr '\n' ' ')"
        fi
        # Forward stderr to the process stderr so set -x / systemd journal still see it
        cat "$err" >&2
    fi
    rm -f "$err"
    return $rc
}

# push_force_replace <tag> <remote> <ref> <branch>
# Emulate force-push via delete+push for servers that reject --force (gitfarm).
# Only push if the delete actually removed the ref OR the ref didn't exist —
# otherwise the push would fail non-fast-forward and the bogus OTHER-ERR masks
# the real cause (concurrent push, transient network, server hook). Next
# sync_repo run retries the cycle cleanly.
#
# Pushes via the remote NAME (not URL) so git updates the local tracking refs
# under refs/remotes/<remote>/* — Step 4's `jj git import` then sees the new
# SHAs and jj's view of @backup bookmarks stays in sync.
push_force_replace() {
    local tag=$1 remote=$2 ref=$3 branch=$4
    timeout_cmd "push-del $tag" git --git-dir="$GIT_DIR" push "$remote" --delete "$branch"
    local del_class=$_LAST_CLASSIFICATION
    case "$del_class" in
        OK|BENIGN-DEL)
            timeout_cmd "push $tag" git --git-dir="$GIT_DIR" push "$remote" "${ref}:${branch}" || true
            ;;
        *)
            log WARN "SKIP-PUSH $tag: delete failed (${del_class:-unknown}); will retry next run"
            ;;
    esac
}

# timeout_cmd <tag> <cmd...>
# classify_cmd wrapped in timeout(1). --kill-after sends SIGKILL 10s after
# the initial SIGTERM if the child refuses to die. Total max wall time:
# $SYNC_REPO_CMD_TIMEOUT + 10s.
timeout_cmd() {
    local tag=$1; shift
    classify_cmd "$tag" timeout --kill-after=10 "$SYNC_REPO_CMD_TIMEOUT" "$@"
}

log INFO "START"

if jj root &>/dev/null 2>&1; then
    # If no 'backup' remote, just snapshot the working copy and exit
    if ! jj git remote list 2>/dev/null | grep -q '^backup '; then
        jj status &>/dev/null
        exit 0
    fi
    jj workspace update-stale 2>/dev/null || true

    # Commit current change if non-empty, OR jj new if @ is an empty merge (so Step 0 has a
    # stable single-rev CHANGE_ID to push instead of the merge @ itself).
    # Single jj call snapshots @ atomically (change_id|empty|merge|has_desc|parent_change_id) —
    # avoids races with concurrent jj. PARENT_CHANGE_ID is a single change_id for non-merge, ignored
    # for merge (not used in the merge path).
    AT_INFO=$(jj log -r @ --no-graph -T 'change_id ++ "|" ++ if(empty, "1", "0") ++ "|" ++ if(parents.len() > 1, "1", "0") ++ "|" ++ if(description, "1", "0") ++ "|" ++ parents.map(|p| p.change_id()).join(",")' 2>/dev/null)
    IFS='|' read -r CHANGE_ID IS_EMPTY IS_MERGE HAS_DESC PARENT_CHANGE_ID <<<"$AT_INFO"
    if [ "$IS_EMPTY" = "0" ] || [ "$IS_MERGE" = "1" ]; then
        jj new
        # Skip describe if @- was empty (nothing to commit-msg) or already has a description
        if [ "$IS_EMPTY" = "0" ] && [ "$HAS_DESC" = "0" ]; then
            if ! MSG=$(VERBOSE=1 "$DOTFILES_ROOT/bin/commit-msg" "$CHANGE_ID"); then
                echo "commit-msg failed" >&2
                exit 1
            fi
            jj describe "$CHANGE_ID" -m "$MSG"
        fi
        PUSH_REV=${CHANGE_ID}
    else
        PUSH_REV=${PARENT_CHANGE_ID}
    fi

    # Steps in order (numbered as they appear below):
    # 0. Force-push the workspace-named bookmark MACHINE_NAME/<workspace> so
    #    the current @ commit is preserved on the remote even if later steps
    #    fail; bookmark is then deleted locally.
    # 1. Advance local sync.bookmark to the new commit and force-push all
    #    hostname-prefixed local bookmarks (MACHINE_NAME/<name>). Pushed via
    #    raw git delete+push because the backup server doesn't support
    #    --force-with-lease.
    # 2. Fetch the backup remote, then — depending on ancestry between local
    #    and remote tips — push, fast-forward, or rebase+push the
    #    sync.bookmark. Skipped if sync.bookmark is unset or fetch failed.
    # 3. Rebase any remaining mutable chain below @ onto the updated bookmark.
    # 4. Reconcile jj's view with raw git by `jj git import`.
    # Resolve the git dir. jj git root is the canonical source, but for
    # colocated worktrees where jj's operation log is in a degraded state
    # (e.g. stale workspace) it can return empty. Fall back to git's own
    # view so sync can proceed via raw git while jj recovers.
    GIT_DIR=$(jj git root 2>/dev/null)
    if [ -z "$GIT_DIR" ] || [ ! -d "$GIT_DIR" ] && [ ! -f "$GIT_DIR" ]; then
        GIT_DIR=$(git rev-parse --git-dir 2>/dev/null | xargs -I{} readlink -f {} 2>/dev/null)
    fi
    BACKUP_URL=$(git --git-dir="$GIT_DIR" remote get-url backup 2>/dev/null)
    CURRENT_BM=$(jj config get sync.bookmark 2>/dev/null || true)

    # If neither jj nor git can point us at a 'backup' remote URL, exit cleanly.
    # Not an error: the repo simply isn't set up for backup yet.
    if [ -z "$BACKUP_URL" ]; then
        log INFO "NO-BACKUP-URL skipping push steps (git has no 'backup' remote)"
        exit 0
    fi

    # Step 0: force-push workspace-named bookmark (hostname/workspace) to backup and delete locally.
    # Pushes PUSH_REV. Empty merges are `jj new`-ed above so
    # PUSH_REV always resolves to a single revision even when @ was a merge commit.
    # Uses raw git delete+push because backup server doesn't support --force-with-lease.
    # Workspace name: match current @ commit against `jj workspace list` (op log is shared across
    # workspaces so `jj op log` returns the last-active workspace, not the current one).
    CURRENT_COMMIT=$(jj log -r @ --no-graph -T 'commit_id' 2>/dev/null)
    WORKSPACE_NAME=$(jj workspace list -T 'self.name() ++ " " ++ self.target().commit_id() ++ "\n"' 2>/dev/null | awk -v c="$CURRENT_COMMIT" '$2 == c {print $1; exit}')
    if [ -n "$WORKSPACE_NAME" ] && [ -n "$PUSH_REV" ]; then
        WS_BM="${MACHINE_NAME}/${WORKSPACE_NAME}"
        WS_BRANCH="refs/heads/${WS_BM}"
        jj bookmark create "$WS_BM" -r "$PUSH_REV" 2>/dev/null || jj bookmark set "$WS_BM" -r "$PUSH_REV" --allow-backwards 2>/dev/null || true
        WS_REF=$(jj log -r "$WS_BM" --no-graph -T 'commit_id' 2>/dev/null)
        if [ -n "$WS_REF" ]; then
            push_force_replace "$WS_BM" backup "$WS_REF" "$WS_BRANCH"
        fi
        jj bookmark delete "$WS_BM" 2>/dev/null || true
    fi

    # Step 1: advance bookmark to latest commit and push hostname-prefixed refs (delete + push, server doesn't support --force)
    if [ -n "$CURRENT_BM" ]; then
        jj bookmark set "$CURRENT_BM" -r "$PUSH_REV" 2>/dev/null || true
    fi
    REMOTE_REFS=$(timeout --kill-after=10 "$SYNC_REPO_CMD_TIMEOUT" \
        git --git-dir="$GIT_DIR" ls-remote "$BACKUP_URL" "refs/heads/${MACHINE_NAME}/*" 2>/dev/null)
    for bm in $(jj bookmark list -T 'name ++ "\n"' 2>/dev/null | grep -v "^${MACHINE_NAME}/" | sort -u); do
        REF=$(jj log -r "$bm" --no-graph -T 'commit_id' 2>/dev/null) || continue
        REMOTE_REF=$(echo "$REMOTE_REFS" | awk -v ref="refs/heads/${MACHINE_NAME}/${bm}" '$2 == ref {print $1}')
        if [ "$REF" != "$REMOTE_REF" ]; then
            push_force_replace "${MACHINE_NAME}/${bm}" backup "$REF" "refs/heads/${MACHINE_NAME}/${bm}"
        fi
    done
    # Sync jj's view of the freshly-updated refs/remotes/backup/* tracking refs
    # immediately, so subsequent jj queries (and any early exit before Step 4)
    # see the right SHAs for taygeta/*@backup bookmarks.
    jj git import 2>/dev/null || true

    # Step 2: fetch from backup, reconcile sync.bookmark with remote, push.
    #
    # Four cases by ancestry of LOCAL_BM_REV vs REMOTE_REV:
    #   - equal:        no-op SKIP
    #   - local is ancestor of remote:  fast-forward local, nothing to push
    #   - remote is ancestor of local:  push local (ahead)
    #   - diverged:     pre-flight conflict probe via `jj new --no-edit L R`;
    #                   if the probe is conflicted, abandon and skip the push.
    #                   Otherwise abandon the probe and `jj rebase` local-only
    #                   commits onto remote, producing a fast-forward push.
    #
    # The probe shares conflict semantics with the rebase (both reduce to a
    # 3-way merge of common-ancestor / L / R), so a clean probe guarantees a
    # clean rebase. Bookmark commit_ids are not rewritten until the probe is
    # known clean, leaving a clear retry surface on conflict.
    #
    # IMPORTANT: after `jj git fetch`, the bare bookmark name (`$CURRENT_BM`, e.g. "master")
    # can become ambiguous if the remote has diverged (local and remote both claim `master`).
    # Any revset using the bare name then fails. We resolve the local bookmark to a
    # commit_id BEFORE fetch and use THAT in all post-fetch revsets.
    if [ -n "$CURRENT_BM" ]; then
        LOCAL_BM_REV=$(jj log -r "$CURRENT_BM" --no-graph -T 'commit_id' 2>/dev/null)
        FETCH_OK=0
        if timeout_cmd "fetch $CURRENT_BM" jj git fetch --all-remotes; then
            log INFO "FETCH-OK $CURRENT_BM"
            FETCH_OK=1
        fi
        # Skip push when fetch failed: stale ${CURRENT_BM}@backup leads to
        # wrong-path pushes (e.g. "new bookmark" full-history push on
        # transient timeout). Next run reconciles.
        if [ "$FETCH_OK" = "0" ]; then
            log INFO "SKIP-PUSH $CURRENT_BM: fetch failed; will retry next run"
        else
        # Ensure the remote-tracking bookmark is tracked before push (jj 0.40+ rejects
        # pushes to untracked remote bookmarks).
        jj bookmark track "${CURRENT_BM}@backup" 2>/dev/null || true
        REMOTE_REV=$(jj log -r "${CURRENT_BM}@backup" --no-graph -T 'commit_id' 2>/dev/null)
        if [ -z "$REMOTE_REV" ]; then
            # Remote doesn't exist yet, just push.
            if timeout_cmd "push $CURRENT_BM (new)" jj git push --remote backup --bookmark "$CURRENT_BM" --allow-new; then
                log INFO "PUSH-OK $CURRENT_BM rev=$LOCAL_BM_REV (new)"
            fi
        elif [ "$LOCAL_BM_REV" = "$REMOTE_REV" ]; then
            log INFO "SKIP $CURRENT_BM already at $REMOTE_REV"
        elif jj log -r "$LOCAL_BM_REV & ::$REMOTE_REV" --no-graph -T '"y"' 2>/dev/null | grep -q y; then
            # Local is ancestor of remote: fast-forward local, no push.
            jj bookmark set "$CURRENT_BM" -r "$REMOTE_REV" --allow-backwards 2>/dev/null || true
            log INFO "FAST-FORWARD $CURRENT_BM local=$LOCAL_BM_REV -> remote=$REMOTE_REV"
        elif jj log -r "$REMOTE_REV & ::$LOCAL_BM_REV" --no-graph -T '"y"' 2>/dev/null | grep -q y; then
            # Remote is ancestor of local: push local.
            if timeout_cmd "push $CURRENT_BM (ahead)" jj git push --remote backup --bookmark "$CURRENT_BM"; then
                log INFO "PUSH-OK $CURRENT_BM rev=$LOCAL_BM_REV (ahead)"
            fi
        else
            # Diverged: probe with a no-edit merge to detect conflicts, then
            # rebase if clean (so the push is a fast-forward).
            if jj new --no-edit "$LOCAL_BM_REV" "$REMOTE_REV" -m "rebase-probe" 2>/dev/null; then
                PROBE_CHANGE=$(jj log -r 'latest("'"$LOCAL_BM_REV"'"+ & "'"$REMOTE_REV"'"+, 1)' --no-graph -T 'change_id' 2>/dev/null | head -1)
                if [ -z "$PROBE_CHANGE" ]; then
                    log CRITICAL "REBASE-PROBE-FAIL $CURRENT_BM: could not locate probe commit"
                    echo "WARNING: could not locate rebase probe for $CURRENT_BM; skipping push" >&2
                elif jj log -r "$PROBE_CHANGE" --no-graph -T 'if(conflict, "conflict")' 2>/dev/null | grep -q conflict; then
                    # Conflict: abandon probe, leave bookmarks untouched, log + skip.
                    CONFLICT_FILES=$(jj resolve --list -r "$PROBE_CHANGE" 2>/dev/null | awk 'NF {print $1}' | paste -sd, -)
                    log ERROR "REBASE-CONFLICT $CURRENT_BM files=${CONFLICT_FILES:-<unknown>} local=$LOCAL_BM_REV remote=$REMOTE_REV"
                    echo "WARNING: rebase has conflicts in ${CONFLICT_FILES:-<unknown>}; skipping push for $CURRENT_BM" >&2
                    jj abandon "$PROBE_CHANGE" 2>/dev/null || true
                else
                    # Clean: abandon probe, rebase local-only chain onto remote, push.
                    jj abandon "$PROBE_CHANGE" 2>/dev/null || true
                    if jj rebase -s 'roots(::'"$LOCAL_BM_REV"' ~ ::'"$REMOTE_REV"')' -d "$REMOTE_REV" 2>/dev/null; then
                        REBASED_REV=$(jj log -r "$CURRENT_BM" --no-graph -T 'commit_id' 2>/dev/null)
                        if timeout_cmd "push $CURRENT_BM (rebased)" jj git push --remote backup --bookmark "$CURRENT_BM"; then
                            log INFO "PUSH-OK $CURRENT_BM rev=$REBASED_REV (rebased local=$LOCAL_BM_REV remote=$REMOTE_REV)"
                        fi
                    else
                        log CRITICAL "REBASE-FAIL $CURRENT_BM local=$LOCAL_BM_REV remote=$REMOTE_REV"
                        echo "WARNING: jj rebase failed for $CURRENT_BM; skipping push" >&2
                    fi
                fi
            else
                log CRITICAL "REBASE-PROBE-FAIL $CURRENT_BM local=$LOCAL_BM_REV remote=$REMOTE_REV; skipping push"
                echo "WARNING: failed to create rebase probe for $CURRENT_BM; skipping push" >&2
            fi
        fi
        jj bookmark track "${CURRENT_BM}@backup" 2>/dev/null || true
        fi
    fi

    # Step 3: rebase local mutable chain onto updated bookmark
    if [ -n "$CURRENT_BM" ]; then
        # Find the oldest mutable ancestor of @ that's not already on the bookmark
        jj rebase -s 'roots(mutable() & ::@ ~ ::'"$CURRENT_BM"')' -d "$CURRENT_BM" 2>/dev/null || true
    fi

    # Step 4: sync jj's view of remote refs after raw git pushes
    jj git import 2>/dev/null || true
    # Untrack hostname-prefixed remote bookmarks: these are per-host snapshots
    # pushed via raw git, not branches we want jj to follow. Without this, jj
    # starts tracking them after import/fetch, polluting `jj bookmark list` and
    # interfering with future `jj git push` operations.
    for bm in $(jj bookmark list --all-remotes -T 'name ++ "@" ++ remote ++ "\n"' 2>/dev/null | grep -E "^${MACHINE_NAME}/.+@backup$"); do
        jj bookmark untrack "$bm" 2>/dev/null || true
    done
    # Clean up empty no-description orphan heads left by git operations forking @
    jj abandon 'heads(empty() & description(exact:"")) ~ @ ~ bookmarks()' 2>/dev/null || true
else
    # Skip if no 'backup' remote (avoid touching unrelated git repos discovered by sync_all)
    if ! $GIT remote | grep -qx 'backup'; then
        exit 0
    fi
    $GIT submodule foreach bash -c "$GIT add --verbose --all .
        $GIT commit --verbose -m \"Change from ${MACHINE_NAME}\" && WILL_PUSH=yes
        $GIT pull --ff --verbose --no-edit --recurse-submodules=no
        test \$WILL_PUSH && $GIT push || true"

    $GIT add --verbose --all .
    MSG=$("$DOTFILES_ROOT/bin/commit-msg" 2>/dev/null) || MSG="Change from ${MACHINE_NAME}"
    [ -z "$MSG" ] && MSG="Change from ${MACHINE_NAME}"
    $GIT commit --verbose --no-allow-empty -m "$MSG"
    $GIT pull --ff --verbose --no-edit

    $GIT_SUBREPO pull --verbose --all || $GIT_SUBREPO clean --verbose --all
    $GIT push --verbose
fi
