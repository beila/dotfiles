#!/usr/bin/env bash
# resolve-by-attrs — auto-resolve conflicts in a colocated jj/git repo
# according to .gitattributes merge=<name> directives and gitconfig
# [merge "<name>"] driver entries. Always exits 0 (best-effort helper);
# unresolvable conflicts are left in place for the human.
#
# Usage:  resolve-by-attrs [-r REVSET] [DIR]
#         resolve-by-attrs --help
#
#   -r/--rev REVSET   Resolve conflicts at REVSET instead of @. The revset
#                     must select a single commit. Useful for callers like
#                     sync_repo that have a probe/rebase commit at @- they
#                     want to clean up without disturbing @.
#   DIR               Repo directory (defaults to current working directory).
#
# Why this exists:
#   jj has no per-path merge-driver registry like git's gitattributes. The
#   built-in :theirs/:ours tools cover the common cases, but the whole point
#   of using gitattributes is to keep the policy in the repo (versioned)
#   instead of in user-specific gitconfig. This wrapper reads .gitattributes
#   the way git does (via `git check-attr`, which handles macros, hierarchy,
#   negation, core.attributesFile, etc.), then dispatches each conflicted
#   path to the right jj merge tool.
#
# Mapping from `merge=<name>` to behaviour:
#   theirs               -> jj built-in :theirs (side #2 wins)
#   ours                 -> jj built-in :ours   (side #1 wins)
#   union                -> emulated: concatenate left + right into output
#   text / binary / "" / unset / unspecified
#                        -> leave alone (jj's default merge already handles it)
#   <other>              -> look up `git config merge.<other>.driver`; if set,
#                           run the driver against the jj resolver placeholders
#                           with git's %A/%B/%O/%P/%L/%S/%X/%Y expansions; if
#                           not, leave alone.
#
# Stdout: one line per conflicted path describing the action, then a summary.
# Exit:   always 0 (sync_repo can call this unconditionally).

set -u

err()  { printf '\033[31m✗\033[0m %s\n' "$*" >&2; }
info() { printf '\033[36m→\033[0m %s\n' "$*"; }
ok()   { printf '\033[32m✓\033[0m %s\n' "$*"; }
warn() { printf '\033[33m!\033[0m %s\n' "$*" >&2; }

REV="@"
DIR="."
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    -r|--rev)
      REV="$2"; shift 2 ;;
    --)
      shift; DIR="${1:-.}"; break ;;
    -*)
      err "unknown option: $1"; exit 0 ;;
    *)
      DIR="$1"; shift ;;
  esac
done

if [[ ! -d "$DIR" ]]; then
  err "not a directory: $DIR"
  exit 0
fi
cd "$DIR" || exit 0

# We need a colocated repo (.git visible) so `git check-attr` can read the
# attributes. Without it, gitattributes is dead weight anyway. Bail cleanly.
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  info "no git work tree at $DIR — nothing to do"
  exit 0
fi

# List conflicted paths at REV. `jj resolve --list` prints
#   <path>    <N>-sided conflict
# one per line. Strip the trailing "    N-sided conflict" so paths with
# spaces survive intact. If --list says no conflicts, exit early.
list_out=$(jj resolve --list -r "$REV" 2>&1) || true
if echo "$list_out" | grep -qi 'no conflicts found\|no conflicts'; then
  info "no conflicts at $REV — nothing to do"
  exit 0
fi
# If --list errored for any other reason (corrupt repo, etc.), treat as no-op.
if [[ -z "$list_out" ]] || ! echo "$list_out" | grep -q 'conflict'; then
  info "no conflicts at $REV — nothing to do"
  exit 0
fi

# Parse paths. The trailer is "<spaces><N>-sided conflict" — strip from the
# right via sed. Skip blank/error lines.
mapfile -t PATHS < <(
  echo "$list_out" \
    | sed -E 's/[[:space:]]+[0-9]+-sided conflict[[:space:]]*$//' \
    | grep -v '^[[:space:]]*$' \
    | grep -v '^Error:'
)

if [[ ${#PATHS[@]} -eq 0 ]]; then
  info "no conflicts at $REV — nothing to do"
  exit 0
fi

# Build a transient jj config file once per run that registers the merge
# tools we need. :theirs / :ours are built-in (jj 0.41+) so we only need to
# define the "shim" tool that proxies to either git's merge.<name>.driver
# or our own union emulation. Each shim invocation reads its behaviour out
# of an env var so we don't have to rewrite the toml per file.
WORK=$(mktemp -d /tmp/resolve-by-attrs.XXXXXX)
trap 'rm -rf "$WORK"' EXIT

cat > "$WORK/jj-config.toml" <<EOF
[merge-tools.shim]
program = "$WORK/shim"
merge-args = ["\$left", "\$right", "\$base", "\$output"]
EOF

# The shim. RESOLVER_ACTION says what to do; RESOLVER_DRIVER carries the git
# driver template if applicable. For union, we run a 3-way merge with
# `git merge-file --union`: it merges left + right against the base and
# unions overlapping hunks rather than naive-cat'ing the whole file. This
# matches git's built-in `merge=union` driver — the common-ancestor lines
# appear once, both branches' unique additions appear in order.
cat > "$WORK/shim" <<'SHIM'
#!/usr/bin/env bash
set -u
left=$1; right=$2; base=$3; output=$4
case "${RESOLVER_ACTION:-}" in
  union)
    # 3-way merge with --union; left = ours, right = theirs, base = ancestor.
    # Result is written to a copy of left, so seed output with left first.
    cp -- "$left" "$output"
    git merge-file --union -- "$output" "$base" "$right" >/dev/null 2>&1 || true
    ;;
  driver)
    # Expand git's merge-driver placeholders and run the resulting command.
    #   %A   ours/output (file driver writes to)
    #   %B   theirs
    #   %O   base
    #   %P   pathname (best effort)
    #   %L   conflict marker size
    #   %S   ours-revision label   (no jj equivalent — substitute "local")
    #   %X   base-revision label   (substitute "base")
    #   %Y   theirs-revision label (substitute "other")
    # The label placeholders matter for tools like mergiraf that pass them
    # along even when not strictly required: they exit non-zero rather than
    # accept literal "%S"/"%X"/"%Y" as branch names. Substituting a stable
    # dummy keeps the merge working — the only loss is that conflict-marker
    # labels lose meaningful revision names.
    cmd="${RESOLVER_DRIVER:-}"
    # Seed output with left's content (git's contract: %A is the current/
    # ours file, pre-populated, that the driver mutates in place). Use
    # `cat >` instead of `cp` because jj creates $left read-only, and `cp`
    # preserves source mode — leaving $output read-only would break drivers
    # like mergiraf that try to write to %A.
    cat -- "$left" > "$output"
    cmd=${cmd//%A/$output}
    cmd=${cmd//%B/$right}
    cmd=${cmd//%O/$base}
    cmd=${cmd//%P/${RESOLVER_PATH:-unknown}}
    cmd=${cmd//%L/7}
    cmd=${cmd//%S/local}
    cmd=${cmd//%X/base}
    cmd=${cmd//%Y/other}
    sh -c "$cmd"
    ;;
  *)
    # Unknown action — leave the conflict alone by writing a marker that
    # forces jj to keep the conflict. The simplest way: exit non-zero so jj
    # treats this as "tool failed, keep conflict".
    exit 1
    ;;
esac
SHIM
chmod +x "$WORK/shim"

resolved=0
skipped=0
unhandled=0

for p in "${PATHS[@]}"; do
  # `git check-attr -z` outputs <path>\0<attr>\0<value>\0. The third NUL-
  # delimited field is the resolved attribute value (`unspecified` / `unset`
  # / `set` / a string). Anything but a real string means "leave alone".
  attr=$(git check-attr -z merge -- "$p" 2>/dev/null \
         | awk -v RS='\0' 'NR==3 {print; exit}')
  case "$attr" in
    theirs)
      if jj resolve --tool=:theirs -r "$REV" -- "$p" >/dev/null 2>&1; then
        ok "$p: merge=theirs -> :theirs"
        resolved=$((resolved+1))
      else
        warn "$p: :theirs failed"
        unhandled=$((unhandled+1))
      fi
      ;;
    ours)
      if jj resolve --tool=:ours -r "$REV" -- "$p" >/dev/null 2>&1; then
        ok "$p: merge=ours -> :ours"
        resolved=$((resolved+1))
      else
        warn "$p: :ours failed"
        unhandled=$((unhandled+1))
      fi
      ;;
    union)
      if RESOLVER_ACTION=union RESOLVER_PATH="$p" \
         jj --config-file "$WORK/jj-config.toml" resolve --tool=shim -r "$REV" -- "$p" \
         >/dev/null 2>&1; then
        ok "$p: merge=union -> concatenated"
        resolved=$((resolved+1))
      else
        warn "$p: union shim failed"
        unhandled=$((unhandled+1))
      fi
      ;;
    text|binary|''|unspecified|unset|set)
      # Default behaviour — leave it for the human / jj's normal flow.
      info "$p: merge=${attr:-(none)} — leaving conflicted"
      skipped=$((skipped+1))
      ;;
    *)
      # Custom driver. Look it up; if missing, treat as skip.
      driver=$(git config "merge.${attr}.driver" 2>/dev/null || true)
      if [[ -z "$driver" ]]; then
        warn "$p: merge=$attr but no [merge.$attr] driver configured — leaving conflicted"
        skipped=$((skipped+1))
        continue
      fi
      if RESOLVER_ACTION=driver RESOLVER_DRIVER="$driver" RESOLVER_PATH="$p" \
         jj --config-file "$WORK/jj-config.toml" resolve --tool=shim -r "$REV" -- "$p" \
         >/dev/null 2>&1; then
        ok "$p: merge=$attr -> driver"
        resolved=$((resolved+1))
      else
        # Driver exited non-zero. Per git's merge-driver contract, rc≠0
        # means "merge had unresolvable hunks". jj treats that as "tool
        # failed" and keeps the original first-class conflict — which is
        # what the user wants anyway, since jj's conflict view is richer
        # than text markers. So this isn't a tool error; it's a partial
        # merge that fell back to manual.
        warn "$p: merge=$attr -> driver couldn't fully resolve, leaving conflicted"
        unhandled=$((unhandled+1))
      fi
      ;;
  esac
done

remaining=$((skipped + unhandled))
if [[ $resolved -eq 0 ]] && [[ $remaining -eq 0 ]]; then
  info "no conflicts at @ — nothing to do"
elif [[ $remaining -eq 0 ]]; then
  ok "resolved $resolved conflict(s)"
else
  info "resolved $resolved, left $remaining for human"
fi
exit 0
