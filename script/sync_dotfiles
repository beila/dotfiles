#!/usr/bin/env bash
set -x
GIT=${GIT_EXECUTABLE:-git}
GIT_SUBREPO=${GIT_SUBREPO:-git-subrepo}
MACHINE_NAME=$(hostnamectl --pretty 2>/dev/null | grep -v '\.')
MACHINE_NAME=${MACHINE_NAME:-$(hostname -s)}
cd "$1" || {
    echo "Error: No such directory as $1"; exit
}

# Per-repo lock to prevent concurrent syncs (use jj/git root so workspaces sharing a repo lock together)
LOCK_PATH=$(jj root 2>/dev/null || git rev-parse --show-toplevel 2>/dev/null || echo "$1")
LOCKFILE="/tmp/sync_dotfiles_$(echo "$LOCK_PATH" | tr / _).lock"
exec 9>"$LOCKFILE"
flock -n 9 || { echo "sync_dotfiles already running for $LOCK_PATH, skipping"; exit 0; }

if jj root &>/dev/null 2>&1; then
    jj workspace update-stale 2>/dev/null || true

    # Commit current change if non-empty
    if ! jj log -r @ --no-graph -T 'if(empty, "empty")' 2>/dev/null | grep -q empty; then
        CHANGE_ID=$(jj log -r @ --no-graph -T 'change_id' 2>/dev/null)
        jj new
        # Skip describe if already has a description
        if jj log -r "$CHANGE_ID" --no-graph -T 'if(description, "has_desc", "empty")' 2>/dev/null | grep -q empty; then
            MSG=$("$1/bin/commit-msg" "$CHANGE_ID" 2>/dev/null) || MSG="Change from ${MACHINE_NAME}"
            # Strip markdown fences that LLMs sometimes wrap around output
            MSG=$(echo "$MSG" | sed '/^```/d' | head -1)
            [ -z "$MSG" ] && MSG="Change from ${MACHINE_NAME}"
            jj describe "$CHANGE_ID" -m "$MSG"
        fi
    fi

    # Requirements:
    # 1. Commit current change with AI-generated message (skip if empty)
    # 2. Force-push all local bookmarks with hostname prefix (MACHINE_NAME/bookmark)
    #    — pushed FIRST so working copy is preserved even if merge creates conflict
    # 3. Fetch remote, merge tracked bookmark forward, push (no force)
    #    — if no remote changes, master and taygeta/master end up at the same commit
    if jj git remote list 2>/dev/null | grep -q '^hj '; then
        GIT_DIR=$(jj git root 2>/dev/null)
        HJ_URL=$(git --git-dir="$GIT_DIR" remote get-url hj 2>/dev/null)
        PUSH_REV=${CHANGE_ID:-$(jj log -r '@-' --no-graph -T 'change_id' 2>/dev/null)}
        CURRENT_BM=$(jj bookmark list -r "..$PUSH_REV" -T 'name ++ "\n"' 2>/dev/null | head -1)

        # Step 1: advance bookmark to latest commit and push hostname-prefixed refs (delete + push, server doesn't support --force)
        if [ -n "$CURRENT_BM" ]; then
            jj bookmark set "$CURRENT_BM" -r "$PUSH_REV" 2>/dev/null || true
        fi
        REMOTE_REFS=$(git --git-dir="$GIT_DIR" ls-remote "$HJ_URL" "refs/heads/${MACHINE_NAME}/*" 2>/dev/null)
        for bm in $(jj bookmark list -T 'name ++ "\n"' 2>/dev/null | grep -v "^${MACHINE_NAME}/" | sort -u); do
            REF=$(jj log -r "$bm" --no-graph -T 'commit_id' 2>/dev/null) || continue
            REMOTE_REF=$(echo "$REMOTE_REFS" | awk -v ref="refs/heads/${MACHINE_NAME}/${bm}" '$2 == ref {print $1}')
            if [ "$REF" != "$REMOTE_REF" ]; then
                git --git-dir="$GIT_DIR" push "$HJ_URL" --delete "refs/heads/${MACHINE_NAME}/${bm}" 2>/dev/null || true
                git --git-dir="$GIT_DIR" push "$HJ_URL" "$REF:refs/heads/${MACHINE_NAME}/${bm}" 2>/dev/null || true
            fi
        done

        # Step 2: fetch from hj, merge tracked bookmark forward, push
        if [ -n "$CURRENT_BM" ]; then
            jj git fetch --all-remotes 2>/dev/null || true
            REMOTE_REV="${CURRENT_BM}@hj"
            # Check if diverged (remote is not ancestor of local)
            if ! jj log -r "$REMOTE_REV & ancestors($CURRENT_BM)" --no-graph 2>/dev/null | grep -q .; then
                # Diverged: create a merge commit
                jj new "$CURRENT_BM" "$REMOTE_REV" -m "Merge ${REMOTE_REV} into $CURRENT_BM" 2>/dev/null || true
                # Skip push if merge has conflicts
                if jj log -r @ --no-graph -T 'if(conflict, "conflict")' 2>/dev/null | grep -q conflict; then
                    echo "WARNING: merge has conflicts, skipping push of $CURRENT_BM" >&2
                    jj bookmark set "$CURRENT_BM" -r @ 2>/dev/null || true
                    jj new 2>/dev/null || true
                else
                    jj bookmark set "$CURRENT_BM" -r @ 2>/dev/null || true
                    jj new 2>/dev/null || true
                    jj git push --remote hj --bookmark "$CURRENT_BM" --allow-new 2>/dev/null || true
                fi
            else
                jj git push --remote hj --bookmark "$CURRENT_BM" --allow-new 2>/dev/null || true
            fi
            jj bookmark track "${CURRENT_BM}@hj" 2>/dev/null || true
        fi

        # Step 3: rebase local mutable chain onto updated bookmark
        if [ -n "$CURRENT_BM" ]; then
            # Find the oldest mutable ancestor of @ that's not already on the bookmark
            jj rebase -s 'roots(mutable() & ::@ ~ ::'"$CURRENT_BM"')' -d "$CURRENT_BM" 2>/dev/null || true
        fi

        # Step 4: sync jj's view of remote refs after raw git pushes
        jj git import 2>/dev/null || true
        # Clean up empty no-description orphan heads left by git operations forking @
        jj abandon 'heads(empty() & description(exact:"")) ~ @' 2>/dev/null || true
    fi
else
    $GIT submodule foreach bash -c "$GIT add --verbose --all .
        $GIT commit --verbose -m \"Change from ${MACHINE_NAME}\" && WILL_PUSH=yes
        $GIT pull --ff --verbose --no-edit --recurse-submodules=no
        test \$WILL_PUSH && $GIT push || true"

    $GIT add --verbose --all .
    MSG=$("$1/bin/commit-msg" 2>/dev/null) || MSG="Change from ${MACHINE_NAME}"
    MSG=$(echo "$MSG" | sed '/^```/d' | head -1)
    [ -z "$MSG" ] && MSG="Change from ${MACHINE_NAME}"
    $GIT commit --verbose --no-allow-empty -m "$MSG"
    $GIT pull --ff --verbose --no-edit

    $GIT_SUBREPO pull --verbose --all || $GIT_SUBREPO clean --verbose --all
    $GIT push --verbose
fi
