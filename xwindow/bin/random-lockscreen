#!/usr/bin/env bash
# Pick a random image from $WALLPAPER_DIR and set it as the GNOME screensaver
# background. Runs daily via random-lockscreen.timer.
#
# Structured logging and actionable errors: if the wallpaper dir is missing,
# empty, or gsettings can't be invoked, the error says exactly what's wrong
# and where to look.

set -u

LOG_TAG=random-lockscreen
DOTFILES_ROOT=${DOTFILES_ROOT:-$HOME/.dotfiles}
# shellcheck source=/dev/null
source "$DOTFILES_ROOT/script/logger/log.sh"

WALLPAPER_DIR="${WALLPAPER_DIR:-$HOME/Pictures/Favourites}"

if [ ! -d "$WALLPAPER_DIR" ]; then
    log ERROR "wallpaper directory not found: $WALLPAPER_DIR. Create it or set WALLPAPER_DIR= (e.g. in private-dotfiles/env.zsh)"
    exit 1
fi

# Collect candidates. Anchor depth at 1 so we don't recurse into unexpected
# subfolders like trash or drafts. HEIC included: gnome-shell on this box
# inherits a Nix-store GDK_PIXBUF_MODULE_FILE that has no HEIF loader, so
# a raw HEIC URI silently renders as the primary fallback colour (i.e. black).
# We convert HEIC → JPG into a cache dir below so the lock screen always
# gets a renderable URI regardless of gdk-pixbuf's loader set.
mapfile -t candidates < <(find "$WALLPAPER_DIR" -maxdepth 1 -type f \
    \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.heic' -o -iname '*.webp' \) \
    2>/dev/null)

if [ "${#candidates[@]}" -eq 0 ]; then
    log WARN "no wallpapers found in $WALLPAPER_DIR (looking for jpg/jpeg/png/heic/webp at depth 1)"
    exit 0
fi

PIC=$(printf '%s\n' "${candidates[@]}" | shuf -n1)

# HEIC → JPG conversion (cached). Keyed on source mtime so re-runs reuse the
# cached JPG; if the source is replaced (mtime changes), we re-convert.
# ffmpeg over ImageMagick because Ubuntu's `convert-im6.q16` ships a buggy
# HEIC reader (`error/heic.c/IsHEIFSuccess/139`); ffmpeg unwraps the embedded
# HEVC/MJPEG stream cleanly via the system libavcodec.
if [[ "${PIC,,}" == *.heic ]]; then
    CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/random-lockscreen"
    mkdir -p "$CACHE_DIR"
    SRC_MTIME=$(stat -c %Y "$PIC" 2>/dev/null || echo 0)
    CACHED="$CACHE_DIR/$(basename "${PIC%.*}").${SRC_MTIME}.jpg"
    if [ ! -f "$CACHED" ]; then
        # Drop other cached JPGs for this source (older mtimes) before generating
        # the new one so we don't leak per-mtime files indefinitely.
        find "$CACHE_DIR" -maxdepth 1 -type f -name "$(basename "${PIC%.*}").*.jpg" -delete 2>/dev/null
        # -frames:v 1 -update 1: write a single JPG frame, not a sequence.
        if ! ffmpeg -nostdin -hide_banner -loglevel error -y \
                -i "$PIC" -frames:v 1 -update 1 -q:v 2 "$CACHED" 2>/dev/null; then
            log WARN "HEIC → JPG conversion failed for $PIC; falling back to a non-HEIC candidate"
            PIC=$(printf '%s\n' "${candidates[@]}" | grep -ivE '\.heic$' | shuf -n1)
            if [ -z "$PIC" ]; then
                log ERROR "no non-HEIC candidates available after conversion failure"
                exit 1
            fi
        else
            PIC="$CACHED"
        fi
    else
        PIC="$CACHED"
    fi
fi

if ! command -v gsettings >/dev/null 2>&1; then
    log ERROR "gsettings not installed. This script expects a GNOME/glib session. Install glib or disable random-lockscreen.timer."
    exit 1
fi

# gsettings needs an active DBus session. Under systemd --user the session
# variables should be inherited. If they're missing, the set calls fail with
# 'Cannot autolaunch D-Bus without X11' or similar.
err=$(mktemp "/tmp/random-lockscreen-err.XXXXXX")
fail=0
for kv in \
    'picture-uri file://'"$PIC" \
    'picture-options scaled' \
    'primary-color #000000' \
; do
    key=${kv%% *}
    val=${kv#* }
    if ! gsettings set org.gnome.desktop.screensaver "$key" "$val" 2>"$err"; then
        reason=$(head -1 "$err")
        case "$reason" in
            *"autolaunch D-Bus"*|*"Cannot autolaunch"*)
                log ERROR "gsettings needs a D-Bus session. Check DBUS_SESSION_BUS_ADDRESS is set (systemctl --user import-environment or re-login)."
                fail=1
                break
                ;;
            *"No such schema"*)
                log ERROR "org.gnome.desktop.screensaver schema not found. Is GNOME installed? Try 'gsettings list-schemas | grep screensaver'"
                fail=1
                break
                ;;
            *)
                log WARN "gsettings set $key failed: $reason"
                ;;
        esac
    fi
done
rm -f "$err"

if [ "$fail" -eq 0 ]; then
    log INFO "set wallpaper to $(basename "$PIC")"
fi
exit $fail
