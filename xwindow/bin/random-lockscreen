#!/bin/bash
# Pick a random image from ~/Pictures/Favourites and set as lock screen background
# Run daily via systemd timer or cron
DIR="$HOME/Pictures/Favourites"
PIC=$(find "$DIR" -maxdepth 1 -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' \) | shuf -n1)
if [ -n "$PIC" ]; then
    gsettings set org.gnome.desktop.screensaver picture-uri "file://$PIC"
    gsettings set org.gnome.desktop.screensaver picture-options "zoom"
fi
