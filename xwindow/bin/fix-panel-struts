#!/bin/bash
# Fix gnome-panel bottom bar struts for xmonad
# gnome-panel doesn't set _NET_WM_STRUT on the bottom panel,
# so xmonad's avoidStruts doesn't reserve space for it.
sleep 3
wid=$(xwininfo -root -tree 2>/dev/null | grep "Bottom Expanded Edge Panel" | awk '{print $1}')
if [ -n "$wid" ]; then
    size=$(dconf read /org/gnome/gnome-panel/layout/toplevels/bottom-panel/size 2>/dev/null)
    size=${size:-24}
    xprop -id "$wid" -f _NET_WM_STRUT 32c -set _NET_WM_STRUT "0,0,0,$size"
    xmonad --restart
fi
