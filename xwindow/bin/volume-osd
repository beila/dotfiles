#!/bin/bash
# Change volume and show OSD via dzen2.
# Usage: volume-osd up|down|toggle
action="$1"
case "$action" in
    up)     amixer -q set Master 5%+ ;;
    down)   amixer -q set Master 5%- ;;
    toggle) amixer -q set Master toggle ;;
esac

vol=$(amixer get Master | grep -oP '\d+%' | head -1)
mute=$(amixer get Master | grep -oP '\[o[fn]+\]' | head -1)
if [ "$mute" = "[off]" ]; then
    label="MUTED"
else
    label="VOL: $vol"
fi

pkill -f "dzen2.*vol-osd" 2>/dev/null
echo "  $label  " | dzen2 -p 2 -x 100 -y 100 -w 500 -h 100 \
    -fn "JetBrains Mono:size=28:style=Bold" \
    -bg "#1a1a2e" -fg "#50fa7b" -title-name "vol-osd" &
