#!/bin/bash
# Change volume and show OSD via dzen2.
# Uses a FIFO so rapid key presses update text without flicker.
# Usage: volume-osd up|down|toggle
FIFO="/tmp/volume-osd-fifo"
LOCKFILE="/tmp/volume-osd-lock"

start_dzen() {
    rm -f "$FIFO"
    mkfifo "$FIFO"
    (tail -f "$FIFO" | dzen2 -p -x 100 -y 100 -w 1240 -h 100 \
        -fn "JetBrainsMono Nerd Font:size=36:style=Bold" \
        -bg "#0d0d1a" -fg "#50fa7b" -title-name "vol-osd") &
    sleep 0.2
}

[ -p "$FIFO" ] || start_dzen

case "$1" in
    up)     amixer -q set Master 5%+ ;;
    down)   amixer -q set Master 5%- ;;
    toggle) amixer -q set Master toggle ;;
esac

vol=$(amixer get Master | grep -oP '\d+%' | head -1)
mute=$(amixer get Master | grep -oP '\[o[fn]+\]' | head -1)
pct=${vol%\%}

if [ "$mute" = "[off]" ]; then
    text="  󰝟  MUTED"
else
    bar=""
    filled=$((pct / 5))
    for ((i=0; i<20; i++)); do
        if [ $i -lt $filled ]; then bar+="━"; else bar+="┄"; fi
    done
    text="  󰕾  $bar  $vol"
fi

echo "$text" > "$FIFO"

echo $$ > "$LOCKFILE"
(sleep 2; [ "$(cat "$LOCKFILE" 2>/dev/null)" = "$$" ] && pkill -f "dzen2.*vol-osd" && rm -f "$FIFO") &
