#!/bin/bash
# Cycle to next audio input (source) and show OSD via dzen2.
# Uses wpctl (PipeWire). Skips sources that fail to set.
# Filters out video (camera) sources.

sources=$(wpctl status | sed -n '/Sources:/,/Source endpoints/p' | grep '│.*[0-9]\.' | grep -v 'Camera\|V4L2\|Video')
mapfile -t ids < <(echo "$sources" | awk '{for(i=1;i<=NF;i++) if($i ~ /^[0-9]+\.$/) print substr($i,1,length($i)-1)}')
current=$(echo "$sources" | grep '\*' | awk '{for(i=1;i<=NF;i++) if($i ~ /^[0-9]+\.$/) print substr($i,1,length($i)-1)}')

total=${#ids[@]}
for i in "${!ids[@]}"; do
    if [ "${ids[$i]}" = "$current" ]; then
        for ((j=1; j<total; j++)); do
            next_i=$(( (i + j) % total ))
            wpctl set-default "${ids[$next_i]}" 2>/dev/null
            sleep 0.2
            new=$(wpctl status | sed -n '/Sources:/,/Source endpoints/p' | grep -v 'Camera\|V4L2\|Video' | grep '\*' | awk '{for(k=1;k<=NF;k++) if($k ~ /^[0-9]+\.$/) print substr($k,1,length($k)-1)}')
            [ "$new" != "$current" ] && break
        done
        break
    fi
done

name=$(wpctl status | sed -n '/Sources:/,/Source endpoints/p' | grep -v 'Camera\|V4L2\|Video' | grep '\*' | sed 's/.*\*\s*[0-9]*\.\s*//' | sed 's/\[vol:.*//' | xargs)

pkill -f "dzen2.*mic-osd" 2>/dev/null
echo "  MIC: $name  " | dzen2 -p 3 -x 100 -y 220 -w 1000 -h 100 \
    -fn "JetBrains Mono:size=28:style=Bold" \
    -bg "#1a1a2e" -fg "#ff79c6" -title-name "mic-osd" &
