#!/bin/bash
# Weather genmon script for xfce4-panel
# Uses wttr.in API вҖ” no API key needed
data=$(curl -sf "https://wttr.in/London?format=%c+%t" 2>/dev/null | sed 's/+\([0-9]\)/\1/')
if [ -n "$data" ]; then
    echo "<txt>$data</txt>"
    raw=$(curl -sf 'https://wttr.in/London?format=%l%0A%C%0A%t%0A%f%0A%h%0A%w%0A%S%0A%s' 2>/dev/null)
    summary=$(echo "$raw" | awk 'NR==1{loc=$0} NR==2{cond=$0} NR==3{temp=$0} NR==4{feel=$0} NR==5{hum=$0} NR==6{wind=$0} NR==7{rise=$0} NR==8{set=$0} END{
      gsub(/\+/,"",temp); gsub(/\+/,"",feel)
      printf "%s  вҖ”  %s\n\nрҹҢЎпёҸ Temp:     %s (feels %s)\nрҹ’§ Humidity: %s\nрҹ’Ё Wind:     %s\nрҹҢ… Sun:      %s вҖ“ %s", loc, cond, temp, feel, hum, wind, rise, set}')
    forecast=$(curl -sf 'https://wttr.in/London?format=j1' 2>/dev/null | python3 -c "
import sys,json
from datetime import datetime,timedelta
d=json.load(sys.stdin)
today=datetime.now().date()
now=int(datetime.now().strftime('%H'))
lines=[]
for h in d['weather'][0]['hourly']:
    hour=int(h['time'])//100
    if hour<now: continue
    lines.append(('  '+f'{hour:02d}:00', f\"{h['tempC']:>3}В°C   \", h['chanceofrain'], h['weatherDesc'][0]['value']))
for day in d['weather'][1:3]:
    dt=datetime.strptime(day['date'],'%Y-%m-%d').date()
    diff=(dt-today).days
    label='Tomorrow' if diff==1 else dt.strftime('%A')
    lines.append((label, f\"{day['mintempC']:>2}вҖ“{day['maxtempC']:>2}В°C\", day['hourly'][4]['chanceofrain'], day['hourly'][4]['weatherDesc'][0]['value'].strip()))
first_today=True
for label,temp,rain,desc in lines:
    if first_today and label.startswith('  '):
        print('Today')
        first_today=False
    print(f'{label:<10} {temp:>8}  рҹҢ§ {rain:>3}%  {desc}')
" 2>/dev/null)
    tooltip=$(printf "%s\n\nрҹ“… Forecast\n%s" "$summary" "$forecast")
    echo "<tool>$tooltip</tool>"
else
    echo "<txt>вҳҒ --</txt>"
    echo "<tool>Weather unavailable</tool>"
fi
