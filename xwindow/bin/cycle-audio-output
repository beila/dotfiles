#!/bin/bash
# Cycle to next audio output (sink) and show OSD via persistent dzen2.
# Uses wpctl (PipeWire). Skips sinks that fail to set.
FIFO="/tmp/audio-out-osd-fifo"
LOCKFILE="/tmp/audio-out-osd-lock"

start_dzen() {
    rm -f "$FIFO"
    mkfifo "$FIFO"
    (tail -f "$FIFO" | dzen2 -p -x 100 -y 100 -w 900 -h 120 \
        -fn "JetBrainsMono Nerd Font:size=36:style=Bold" \
        -bg "#0d0d1a" -fg "#8be9fd" -title-name "audio-out-osd") &
    sleep 0.2
}

[ -p "$FIFO" ] || start_dzen

sinks=$(wpctl status | sed -n '/Sinks:/,/Sink endpoints/p' | grep '│.*[0-9]\.')
mapfile -t ids < <(echo "$sinks" | awk '{for(i=1;i<=NF;i++) if($i ~ /^[0-9]+\.$/) print substr($i,1,length($i)-1)}')
current=$(echo "$sinks" | grep '\*' | awk '{for(i=1;i<=NF;i++) if($i ~ /^[0-9]+\.$/) print substr($i,1,length($i)-1)}')

total=${#ids[@]}
for i in "${!ids[@]}"; do
    if [ "${ids[$i]}" = "$current" ]; then
        for ((j=1; j<total; j++)); do
            next_i=$(( (i + j) % total ))
            wpctl set-default "${ids[$next_i]}" 2>/dev/null
            sleep 0.2
            new=$(wpctl status | sed -n '/Sinks:/,/Sink endpoints/p' | grep '\*' | awk '{for(k=1;k<=NF;k++) if($k ~ /^[0-9]+\.$/) print substr($k,1,length($k)-1)}')
            [ "$new" != "$current" ] && break
        done
        break
    fi
done

name=$(wpctl status | sed -n '/Sinks:/,/Sink endpoints/p' | grep '\*' | sed 's/.*\*\s*[0-9]*\.\s*//' | sed 's/\[vol:.*//' | xargs)
echo "  󰓃  $name" > "$FIFO"

echo $$ > "$LOCKFILE"
(sleep 3; [ "$(cat "$LOCKFILE" 2>/dev/null)" = "$$" ] && pkill -f "dzen2.*audio-out-osd" && rm -f "$FIFO") &
