#!/bin/bash
# System monitor genmon script — sparkline graphs with color
# Shows: CPU, MEM, IO wait, Network in panel with Pango markup
#
# Rendering: braille pairs (U+2800-block). One cell shows 2 samples, each at 5
# height levels (0-4 dots). Halves panel cell count vs the old 1-sample/cell
# block sparkline, so we double the displayed history (CELLS=8, 16 samples).
HIST=/tmp/sysmon-history
# DejaVu Sans Mono braille is narrower than the panel's default font, so we can
# fit more cells in the same horizontal budget than the old block-sparkline did.
CELLS=15
# Polling period (seconds) — must match `update-period` in xfce4-panel.xml's
# sysmon-genmon plugin entry (currently 20000ms = 20s). Used for the network
# byte-rate calculation; if you change one, change the other.
POLL_SEC=20
LEN=$(( CELLS * 2 ))  # 30 samples × 20s = 10 minutes

# Braille pair lookup. Index = L*5 + R, where L,R ∈ 0..4 (dot height per side).
# Generated from L bits {0,0x40,0x44,0x46,0x47} + R bits {0,0x80,0xA0,0xB0,0xB8}
# added to 0x2800. See `python3 - <<EOF ... EOF` block in commit history.
BRAILLE_PAIR=(
    ⠀ ⢀ ⢠ ⢰ ⢸
    ⡀ ⣀ ⣠ ⣰ ⣸
    ⡄ ⣄ ⣤ ⣴ ⣼
    ⡆ ⣆ ⣦ ⣶ ⣾
    ⡇ ⣇ ⣧ ⣷ ⣿
)

# Map a sample to dot height 0..4. -1 means "no data" (history not filled yet)
# and renders as 0 dots; any real reading 0..100 renders at least 1 dot so
# idle/trickle activity stays distinguishable from "no data".
height() {
    local pct=$1 idx
    (( pct < 0 )) && { echo 0; return; }
    (( pct > 100 )) && pct=100
    idx=$(( (pct * 4 + 50) / 100 ))
    (( idx == 0 )) && idx=1
    echo "$idx"
}

# Severity tier for one dot-height 0..4: 2=red, 1=yellow, 0=green.
# Color is a pure function of the rendered dot height (NOT the raw percent), so
# a given bar height always shows the same color — the 50/75 percent thresholds
# the old version used fell inside height bands, splitting one height into two
# colors (e.g. a 2-dot bar green below 50% but yellow above). Mapping (relaxed,
# matches height()'s <37.5 / <62.5 / <87.5 / ≥87.5 bands):
#   h1,h2 → green   h3 → yellow   h4 → red
# inv=1 flips the scale (battery: a short bar is bad → red) by mirroring the
# height (eff = 5-h). Height 0 (no data) maps to green so padding never colours
# the panel.
severity() {
    local h=$1 inv=${2:-0} eff
    (( h == 0 )) && { echo 0; return; }
    eff=$h
    (( inv )) && eff=$(( 5 - h ))
    if   (( eff >= 4 )); then echo 2
    elif (( eff >= 3 )); then echo 1
    else                       echo 0
    fi
}

# Render a single braille cell from two samples + inv flag, coloured by the
# worse of the two severities (max). Severity is derived from each sample's
# quantized height so the color can never disagree with the displayed bar.
color_pair() {
    local l=$1 r=$2 inv=${3:-0}
    local lh rh sl sr sev color
    lh=$(height "$l"); rh=$(height "$r")
    sl=$(severity "$lh" "$inv"); sr=$(severity "$rh" "$inv")
    sev=$(( sl > sr ? sl : sr ))
    case $sev in
        2) color="#ff5555" ;;
        1) color="#f1fa8c" ;;
        *) color="#50fa7b" ;;
    esac
    printf "<span color='%s'>%s</span>" "$color" "${BRAILLE_PAIR[lh*5+rh]}"
}

read_hist() { grep "^$1 " "$HIST" 2>/dev/null | cut -d' ' -f2-; }
push_hist() {
    local key=$1 val=$2 old count tmp
    old=$(read_hist "$key")
    count=$(echo "$old" | wc -w)
    (( count >= LEN )) && old=$(echo "$old" | cut -d' ' -f2-)
    tmp=$(mktemp)
    grep -v "^$key " "$HIST" 2>/dev/null > "$tmp"
    echo "$key ${old:+$old }$val" >> "$tmp"
    mv "$tmp" "$HIST"
}

spark() {
    local key=$1 inv=${2:-0} vals padded out=""
    vals=$(read_hist "$key")
    # Left-pad with -1 ("no data") so empty cells stay blank instead of
    # rendering a 1-dot floor that looks like a real low reading.
    # shellcheck disable=SC2206
    local arr=( $vals )
    local count=${#arr[@]}
    local pad=$(( LEN - count ))
    (( pad < 0 )) && pad=0
    local padded_arr=()
    for (( i=0; i<pad; i++ )); do padded_arr+=( -1 ); done
    padded_arr+=( "${arr[@]}" )
    # Pair up adjacent samples into braille cells.
    for (( i=0; i<LEN; i+=2 )); do
        out+=$(color_pair "${padded_arr[i]}" "${padded_arr[i+1]}" "$inv")
    done
    # Wrap in a face that actually contains braille (U+2800-block) glyphs.
    # JetBrainsMono Nerd Font has no braille, so Pango falls back to a
    # proportional Sans, which spaces the dot pairs apart on the panel.
    # DejaVu Sans Mono has the full block at fixed pitch.
    echo "<span face='DejaVu Sans Mono'>$out</span>"
}

# Resolve a hwmon directory by its `name` file. hwmon indices (hwmon0, hwmon1…)
# reshuffle across boots depending on driver probe order, so we match on the
# stable driver name instead of a hard-coded number. Echoes the dir, or nothing.
hwmon_by_name() {
    local want=$1 d
    for d in /sys/class/hwmon/*; do
        [ -r "$d/name" ] && [ "$(cat "$d/name")" = "$want" ] && { echo "$d"; return 0; }
    done
    return 1
}

# --- CPU & IO (delta via awk for large numbers) ---
read -r _ cu cn cs ci cio cirq csirq _ < /proc/stat
prev=$(cat /tmp/sysmon-cpu-prev 2>/dev/null)
if [ -n "$prev" ]; then
    read -r cpu iow <<< "$(echo "$prev $cu $cn $cs $ci $cio $cirq $csirq" | awk '{
        pt=$1+$2+$3+$4+$5+$6+$7; pi=$4; pio=$5
        nt=$8+$9+$10+$11+$12+$13+$14; ni=$11; nio=$12
        dt=nt-pt; busy=(dt-(ni-pi)-(nio-pio)); dio=nio-pio
        if(dt>0){printf "%d %d", busy*100/dt, dio*100/dt} else{print "0 0"}
    }')"
else
    cpu=0; iow=0
fi
echo "$cu $cn $cs $ci $cio $cirq $csirq" > /tmp/sysmon-cpu-prev
push_hist cpu "$cpu"
push_hist iow "$iow"

# --- Memory ---
read -r memtotal memavail < <(awk '/MemTotal/{t=$2} /MemAvailable/{a=$2} END{print t,a}' /proc/meminfo)
mem=$(( (memtotal-memavail)*100/memtotal ))
push_hist mem "$mem"

# --- Network ---
iface=$(awk '$2=="00000000"{print $1; exit}' /proc/net/route)
drx=0; dtx=0; net_pct=0
if [ -n "$iface" ]; then
    read -r rx tx < <(awk -v i="$iface:" '$1==i{print $2, $10}' /proc/net/dev)
    prev_net=$(cat /tmp/sysmon-net-prev 2>/dev/null)
    if [ -n "$prev_net" ]; then
        read -r prx ptx <<< "$prev_net"
        drx=$(( (rx-prx)/POLL_SEC ))
        dtx=$(( (tx-ptx)/POLL_SEC ))
        net_pct=$(( (drx+dtx) / 104858 ))
        (( net_pct > 100 )) && net_pct=100
    fi
    echo "$rx $tx" > /tmp/sysmon-net-prev
fi
push_hist net "$net_pct"

# --- Battery ---
bat=/sys/class/power_supply/BAT0
bat_pct=0; bat_status=""
if [ -d "$bat" ]; then
    bat_pct=$(cat "$bat/capacity")
    bat_status=$(cat "$bat/status")
fi
push_hist bat "$bat_pct"

# --- Temperature & fan ---
# Temp: CPU package die temp in m°C. Preferred source coretemp/"Package id 0"
# (temp1_input); fall back to the x86_pkg_temp thermal zone, then thinkpad CPU.
# Normalize 40–100°C → 0–100% so the existing height()/severity() quantizer
# colours it like the other metrics: green ≤~77°C, yellow ~78–92°C, red ≥~92°C.
# Idle here is ~66°C and crit is 105°C, so this range keeps idle green while
# still hitting red before thermal throttling.
temp_c=-1
coretemp_dir=$(hwmon_by_name coretemp)
pkg_zone=$(grep -l '^x86_pkg_temp$' /sys/class/thermal/thermal_zone*/type 2>/dev/null | head -1)
pkg_zone=${pkg_zone%/type}
thinkpad_dir=$(hwmon_by_name thinkpad)
if [ -n "$coretemp_dir" ] && [ -r "$coretemp_dir/temp1_input" ]; then
    temp_c=$(( $(cat "$coretemp_dir/temp1_input") / 1000 ))
elif [ -n "$pkg_zone" ] && [ -r "$pkg_zone/temp" ]; then
    temp_c=$(( $(cat "$pkg_zone/temp") / 1000 ))
elif [ -n "$thinkpad_dir" ] && [ -r "$thinkpad_dir/temp1_input" ]; then
    temp_c=$(( $(cat "$thinkpad_dir/temp1_input") / 1000 ))
fi
temp_pct=-1
if (( temp_c >= 0 )); then
    temp_pct=$(( (temp_c - 40) * 100 / 60 ))
    (( temp_pct < 0 )) && temp_pct=0
    (( temp_pct > 100 )) && temp_pct=100
fi
push_hist temp "$temp_pct"

# Fan: thinkpad_acpi fan1_input (RPM). Tooltip-only — no panel sparkline.
# Reuses $thinkpad_dir resolved above for the temp fallback.
fan_rpm=-1
[ -n "$thinkpad_dir" ] && [ -r "$thinkpad_dir/fan1_input" ] && fan_rpm=$(cat "$thinkpad_dir/fan1_input")

# --- Panel ---
bat_icon="🔋"
[ "$(cat /sys/class/power_supply/AC/online 2>/dev/null)" = "1" ] && bat_icon="🔌"
(( bat_pct < 20 )) && [ "$bat_status" != "Charging" ] && bat_icon="🪫"
echo "<txt>⚡$(spark cpu) 🧊 $(spark mem) 💽 $(spark iow) 🌐 $(spark net) 🌡️$(spark temp) ${bat_icon}$(spark bat 1)</txt>"

# --- Tooltip ---
used_mb=$(( (memtotal-memavail)/1024 ))
total_mb=$(( memtotal/1024 ))
read -r swaptotal swapfree < <(awk '/SwapTotal/{t=$2} /SwapFree/{f=$2} END{print t,f}' /proc/meminfo)
loadavg=$(cut -d' ' -f1-3 /proc/loadavg)
hr() { local b=$1; if ((b>1073741824)); then echo "$((b/1073741824))G"; elif ((b>1048576)); then echo "$((b/1048576))M"; elif ((b>1024)); then echo "$((b/1024))K"; else echo "${b}B"; fi; }
swap_used=$(( (swaptotal-swapfree)/1024 ))
swap_total=$(( swaptotal/1024 ))
prev_cores=/tmp/sysmon-cores-prev
cur_cores=/tmp/sysmon-cores-cur
awk '/^cpu[0-9]+/' /proc/stat > "$cur_cores"
if [ -f "$prev_cores" ]; then
    cores_tip=$(paste "$prev_cores" "$cur_cores" | awk 'NF>=20{
        pt=$2+$3+$4+$5+$6+$7+$8; pu=$2+$3+$4
        nt=$13+$14+$15+$16+$17+$18+$19; nu=$13+$14+$15
        dt=nt-pt; du=nu-pu
        pct=dt>0 ? int(du*100/dt) : 0
        c[NR-1]=pct
    } END {
        s=0
        while(s<length(c)) {
            e=s+3; if(e>=length(c)) e=length(c)-1
            printf "%2d-%2d:", s, e
            for(i=s;i<=e;i++) printf " %3d%%", c[i]
            printf "\n"; s=e+1
        }
    }')
else
    cores_tip="(waiting for first sample)"
fi
cp "$cur_cores" "$prev_cores"

# Human-readable temp/fan for the tooltip ("n/a" when the sensor is missing).
temp_tip="n/a"; (( temp_c >= 0 )) && temp_tip="${temp_c}°C (pkg)"
fan_tip="n/a";  (( fan_rpm >= 0 )) && fan_tip="${fan_rpm} RPM"

printf -v tip "CPU:  %s%%  (load: %s)\n%s\nMem:  %s%% (%s/%s MB)\nIO:   %s%% iowait\nNet:  ↓%s/s ↑%s/s\nTemp: %s\nFan:  %s\nSwap: %s/%s MB\nBat:  %s%% (%s)\nUp:   %s" \
    "$cpu" "$loadavg" \
    "$cores_tip" \
    "$mem" "$used_mb" "$total_mb" \
    "$iow" \
    "$(hr $drx)" "$(hr $dtx)" \
    "$temp_tip" \
    "$fan_tip" \
    "$swap_used" "$swap_total" \
    "$bat_pct" "${bat_status:-AC}" \
    "$(uptime -p | sed 's/up //')"
echo "<tool>$tip</tool>"
