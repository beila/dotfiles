# :A = resolve symlink to absolute path, :h = dirname (applied twice to go up two levels)
export DOTFILES_ROOT="${0:A:h:h}"

# all of our zsh files
typeset -U config_files
config_files=(${DOTFILES_ROOT}/**/*.zsh)

# load the path files
for file in ${(M)config_files:#*/path.zsh}
do
  #echo "sourcing path from: $file"
  source $file
done
