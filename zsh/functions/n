#!env zsh
# Run an arbitrary command inside a nix devshell, wrapped by `logrun`.
# First arg may be one of:
#   +name / #name          — shortcut for .#name in the current-dir flake
#   .#name, XXX#YYY        — full nix installable (the "usual nix arg")
#   path:/github:/flake:…  — URL-form flake refs
# Otherwise uses the current dir's flake (. or path:.).
local installable=""
case "$1" in
    [+#]*)
        installable=".#${1#[+#]}"; shift ;;
    *'#'*|path:*|github:*|flake:*|gitlab:*|sourcehut:*|git+*|tarball+*|file+*|hg+*)
        installable="$1"; shift ;;
esac

nix_develop_command() {
    which nix &> /dev/null || return
    local i="$installable"
    if [[ -z "$i" ]]; then
        test -f flake.nix || return
        if git ls-files 2>/dev/null | grep -qx 'flake.nix'; then
            i="."
        else
            i="path:."
        fi
    fi
    echo "nix develop ${(q-)i} --ignore-env --impure --keep VERBOSE --keep LOGRUN_PID --keep LOGRUN_MOVE_FILE --command"
}

logrun --name "${*:-nix}" --log-dir "${build_dir:-/tmp/logrun/${${PWD#$HOME/}//\//-}}" -c "
    set -x
    time $(nix_develop_command) ${(j: :)${(q-)@}}
"
