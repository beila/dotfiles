#!env zsh
# Like `n` but invokes `just --justfile ~/.justfile run $@` inside the devshell
# (so the command runs through the user-justfile `run` recipe, which executes
# it in a zsh shell with nonomatch/set -x).
# See `n` for first-arg semantics.
local installable=""
case "$1" in
    [+#]*)
        installable=".#${1#[+#]}"; shift ;;
    *'#'*|path:*|github:*|flake:*|gitlab:*|sourcehut:*|git+*|tarball+*|file+*|hg+*)
        installable="$1"; shift ;;
esac

nix_develop_command() {
    which nix &> /dev/null || return
    local i="$installable"
    if [[ -z "$i" ]]; then
        test -f flake.nix || return
        if git ls-files 2>/dev/null | grep -qx 'flake.nix'; then
            i="."
        else
            i="path:."
        fi
    fi
    echo "nix develop ${(q-)i} --ignore-env --impure --keep VERBOSE --keep LOGRUN_PID --keep LOGRUN_MOVE_FILE --command"
}

logrun --name "${*:-nix}" --log-dir "${build_dir:-/tmp/logrun/${${PWD#$HOME/}//\//-}}" -c "
    set -x
    time $(nix_develop_command) just --justfile ~/.justfile run ${(j: :)${(q-)@}}
"
