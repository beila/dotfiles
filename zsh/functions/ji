#!env zsh
# Like `j` but without --ignore-env/--keep VERBOSE (lighter nix develop invocation).
# See `j` for first-arg semantics.
local installable=""
case "$1" in
    [+#]*)
        installable=".#${1#[+#]}"; shift ;;
    *'#'*|path:*|github:*|flake:*|gitlab:*|sourcehut:*|git+*|tarball+*|file+*|hg+*)
        installable="$1"; shift ;;
esac

nix_develop_command() {
    which nix &> /dev/null || return
    local i="$installable"
    if [[ -z "$i" ]]; then
        test -f flake.nix || return
        if git ls-files 2>/dev/null | grep -qx 'flake.nix'; then
            i="."
        else
            i="path:."
        fi
    fi
    echo "nix develop $i --impure --command"
}

set -x
$(nix_develop_command) just "$@"
