#!/usr/bin/env bash
# evolution-reauth — refresh the M365 OAuth token for Evolution IN PLACE.
#
# Why this exists: the amazon-role-evolution token is short-lived (Conditional
# Access caps the browser-flow refresh token to ~1h), so it dies daily. The
# vendor's recovery path (`evolution-setup -r` + `-c`) works but its reset
# wipes the local mail cache (~/.var/app/org.gnome.Evolution/cache/evolution)
# and mints a NEW account UID, forcing a full re-download of every message.
#
# This script refreshes ONLY the token, keyed to the EXISTING collection UID,
# so the same account + cache are reused — no re-download. It sidesteps the two
# evolution-setup bugs (reuses-expired-token; skips store when account exists)
# by clearing the stale token first and storing the new one directly.
#
# CRUCIAL (why the naive version failed): a *running* flatpak Evolution reads
# secrets over the Secret Service session bound to ITS sandbox instance. A
# fresh `flatpak run --command=secret-tool …` is a DIFFERENT sandbox instance
# whose stored secret the running app cannot see. So when Evolution is already
# open we must store INTO its live namespace via `flatpak enter <pid>`. When
# it's not running, the host keyring (plain secret-tool) is what a fresh launch
# reads. We write to whichever is relevant (and the host keyring always, so a
# later fresh launch also works).
#
# Usage: evolution-reauth        (opens browser/broker sign-in as needed)
set -uo pipefail

MSAL_PY=/usr/lib/amazon/amazon-core-env/bin/python3
MSAL_HELPER=/usr/lib/amazon-role-evolution/msal_auth.py
SRC_DIRS=(
    "$HOME/.config/evolution/sources"
    "$HOME/.var/app/org.gnome.Evolution/config/evolution/sources"
)

die() { echo "evolution-reauth: $*" >&2; exit 1; }

[ -x "$MSAL_PY" ] || die "MSAL python not found ($MSAL_PY) — is amazon-role-evolution installed?"
[ -f "$MSAL_HELPER" ] || die "MSAL helper not found ($MSAL_HELPER)"

# Locate the current microsoft365 [Collection] source — its basename is the UID
# Evolution looks the token up under. Regenerated by evolution-setup on reset,
# so resolve it dynamically rather than hardcoding.
collection_file=""
for d in "${SRC_DIRS[@]}"; do
    [ -d "$d" ] || continue
    for f in "$d"/*.source; do
        [ -f "$f" ] || continue
        if rg -q 'BackendName=microsoft365' "$f" 2>/dev/null && rg -q '^\[Collection\]' "$f" 2>/dev/null; then
            collection_file="$f"; break 2
        fi
    done
done
[ -n "$collection_file" ] || die "no microsoft365 [Collection] source found — run 'evolution-setup -c' once first"

COLLECTION_UID="$(basename "$collection_file" .source)"
EMAIL="$(rg -m1 '^Email=' "$collection_file" | cut -d= -f2-)"
[ -n "$EMAIL" ] || die "couldn't read Email= from $collection_file"
LEGACY_UID="OAuth2::Microsoft365[${EMAIL}]"
echo "evolution-reauth: refreshing token for $EMAIL (uid $COLLECTION_UID)"

# Is a flatpak Evolution already running? If so, capture its instance PID so we
# can store the secret into ITS namespace (see header). `flatpak ps` columns:
# instance  pid  app  runtime — the first column is the instance id used by
# `flatpak enter`.
EVO_INSTANCE="$(flatpak ps --columns=instance,application 2>/dev/null | awk '$2=="org.gnome.Evolution"{print $1; exit}')"

# secret-tool invocations for each relevant namespace:
#   host_st   → host keyring (what a fresh launch reads)
#   live_st   → the running instance's namespace (what the open app reads), if any
host_st() { secret-tool "$@"; }
live_st() { [ -n "$EVO_INSTANCE" ] && flatpak enter "$EVO_INSTANCE" secret-tool "$@"; }

# 1. Clear stale tokens under BOTH keys evolution-setup/EDS use, in every namespace.
#    (check_existing_token looks up the legacy key; EDS reads the collection UID.)
clear_key() {
    host_st clear "e-source-uid" "$1" 2>/dev/null || true
    live_st clear "e-source-uid" "$1" 2>/dev/null || true
}
clear_key "$COLLECTION_UID"
clear_key "$LEGACY_UID"

# 2. Acquire a fresh token (broker if on-VPN, else browser — helper decides).
tok="$("$MSAL_PY" "$MSAL_HELPER" 2>/dev/null)"
# Helper may prefix non-JSON noise; keep from first brace.
tok="{${tok#*\{}"
echo "$tok" | jq empty 2>/dev/null || die "MSAL returned no valid token (sign-in cancelled or failed)"
access="$(echo "$tok" | jq -r '.access_token // empty')"
[ -n "$access" ] || die "MSAL returned empty access_token"

blob="$(echo "$tok" | jq -c '{refresh_token: (.refresh_token // ""), access_token: .access_token, expires_after: .expires_after}')"
label="Evolution Data Source - Microsoft365[${EMAIL}]"

# 3. Store under the EXISTING collection UID. Always write the host keyring (so a
#    later fresh launch works); also write the running instance's namespace (so
#    the currently-open app sees it without a restart).
store_into() {
    # $1 = a function name (host_st / live_st) that fronts secret-tool
    printf '%s' "$blob" | "$1" store --label "$label" \
        "e-source-uid" "$COLLECTION_UID" \
        "eds-origin" "evolution-data-server" \
        "xdg:schema" "org.gnome.Evolution.Data.Source" 2>/dev/null
}
store_into host_st && echo "  stored in host keyring" || echo "  WARN host keyring store failed" >&2
if [ -n "$EVO_INSTANCE" ]; then
    store_into live_st && echo "  stored into running Evolution (instance $EVO_INSTANCE)" \
        || echo "  WARN live-instance store failed" >&2
fi

# 4. Tell the user how to apply it.
if [ -n "$EVO_INSTANCE" ]; then
    echo "evolution-reauth: done. In Evolution, hit Send/Receive (F12) — mail cache is preserved, no re-download."
else
    echo "evolution-reauth: done. Launch Evolution — it will use the fresh token (mail cache preserved, no re-download)."
fi
