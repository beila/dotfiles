#!/usr/bin/env bash
# Pick a zellij session via fzf, write choice to CYCLE_PICK_FILE, then detach.
# Alt-s cycles through entries. Enter confirms. Esc cancels.
# Intended to run inside a zellij pane (launched by zellij-cycle).
set -euo pipefail

pick=$(zellij ls -n 2>/dev/null | grep -v EXITED | awk -F" \\[" '{print $1}' \
    | fzf --cycle --prompt="session> " --bind="alt-s:down") || exit 0
echo "$pick" > "$CYCLE_PICK_FILE"
zellij action detach
