#!/usr/bin/env bash
# Pick a zellij session via fzf, then run a callback with the chosen name.
# Alt-s cycles through entries. Enter confirms. Esc cancels.
# Usage: zellij-pick-session <on-select-command>
# The callback can use $* for the chosen session name.
set -euo pipefail

CALLBACK="${1:-}"
if [ -z "$CALLBACK" ] || [ "$CALLBACK" = "CYCLE_SWITCH_CMD" ]; then
    echo "Usage: zellij-pick-session <on-select-command>" >&2
    exit 1
fi

pick=$(zellij ls -n 2>/dev/null | grep -v EXITED | awk -F" \\[" '{print $1}' \
    | fzf --cycle --prompt="session> " --bind="alt-s:down") || exit 0

run_detached() {
    sleep 0.5
    set -- $pick
    eval "$CALLBACK"
}
run_detached & disown
zellij action close-pane 2>/dev/null || true
