#!/usr/bin/env bash
# vpn-watch — kill the running openconnect (or other) VPN process when
# NetworkManager reports connectivity loss.
#
# Why: openconnect installs DNS + routes that point everything at the VPN
# concentrator. If you change Wi-Fi (home -> café -> office) without first
# disconnecting the VPN, the tunnel stays "up" but the underlying transport
# is gone — the box thinks it's online, every DNS lookup goes to the dead
# tunnel, and the network is effectively inaccessible until you notice and
# manually kill openconnect. This watcher tears the tunnel down the moment
# NetworkManager says connectivity is no longer FULL, so the next reconnect
# starts from a clean state.
#
# Designed to be spawned in the background by `vpn-up`, but also runs
# standalone if you've started a VPN tunnel some other way and want a
# watchdog.
#
# Behaviour:
#   - Waits up to $VPN_STARTUP_WAIT seconds for the VPN process to appear
#     (so vpn-up can fork us before its inner command actually launches it).
#   - Monitors org.freedesktop.NetworkManager Connectivity via D-Bus.
#     States: 0 UNKNOWN, 1 NONE, 2 PORTAL, 3 LIMITED, 4 FULL.
#     We treat any transition out of FULL (4) as "lost".
#   - Debounce $VPN_DEBOUNCE_SEC: if connectivity recovers to FULL within
#     the window, ignore. Avoids killing on brief AP-roam flaps.
#   - On confirmed loss: `sudo -n pkill -TERM <process>` and exit. The
#     parent (vpn-up) primed the sudo cache so this works without prompting.
#   - Periodically re-primes the sudo cache via `sudo -nv` so the kill stays
#     possible after the watcher has been running for a while.
#
# Env:
#   VPN_PROCESS_NAME    process to SIGTERM on loss (default "openconnect").
#                       Looked up via pgrep -x; works fine when there's at
#                       most one such process at a time.
#   VPN_PROCESS_PID     specific PID to watch instead of looking up by name.
#                       Preferred when the caller knows which one to track
#                       (e.g. vpn-up sets this for the foreground VPN child).
#   VPN_DEBOUNCE_SEC    debounce window in seconds (default 5)
#   VPN_SUDO_REFRESH    sudo cache refresh interval in seconds (default 240,
#                       under the typical sudo timestamp_timeout of 5-15 min)
#   VPN_STARTUP_WAIT    seconds to wait for VPN process at start (default 30)

set -uo pipefail

LOG_TAG=vpn-watch
DOTFILES_ROOT=${DOTFILES_ROOT:-$HOME/.dotfiles}
# shellcheck source=/dev/null
source "$DOTFILES_ROOT/script/logger/log.sh"

VPN_PROCESS_NAME=${VPN_PROCESS_NAME:-openconnect}
VPN_PROCESS_PID=${VPN_PROCESS_PID:-}
VPN_DEBOUNCE_SEC=${VPN_DEBOUNCE_SEC:-5}
VPN_SUDO_REFRESH=${VPN_SUDO_REFRESH:-240}
VPN_STARTUP_WAIT=${VPN_STARTUP_WAIT:-30}

# is_vpn_alive — return 0 if the watched VPN process is still running.
# When VPN_PROCESS_PID is set we check that exact PID; otherwise fall back
# to pgrep -x by name.
is_vpn_alive() {
    if [ -n "$VPN_PROCESS_PID" ]; then
        kill -0 "$VPN_PROCESS_PID" 2>/dev/null
    else
        pgrep -x "$VPN_PROCESS_NAME" >/dev/null
    fi
}

# kill_vpn — SIGTERM the VPN process. PID-targeted when known.
kill_vpn() {
    if [ -n "$VPN_PROCESS_PID" ]; then
        sudo -n kill -TERM "$VPN_PROCESS_PID"
    else
        sudo -n pkill -TERM -x "$VPN_PROCESS_NAME"
    fi
}

# nm_connectivity — print the integer 0-4, or empty if NM unreachable.
# We don't bail when NM is missing: in that case the watcher just monitors
# the VPN process and exits when it dies, doing no kills (which is the
# safest fallback behaviour).
nm_connectivity() {
    gdbus call --system \
        --dest org.freedesktop.NetworkManager \
        --object-path /org/freedesktop/NetworkManager \
        --method org.freedesktop.DBus.Properties.Get \
        org.freedesktop.NetworkManager Connectivity 2>/dev/null \
        | grep -oP "uint32 \K[0-9]+"
}

# Wait for the VPN process to appear. vpn-up forks us early so the inner
# command (e.g. amazon-vpn) gets a chance to spawn it.
elapsed=0
while ! is_vpn_alive; do
    if [ "$elapsed" -ge "$VPN_STARTUP_WAIT" ]; then
        log INFO "VPN process never appeared after ${VPN_STARTUP_WAIT}s; exiting"
        exit 0
    fi
    sleep 1
    elapsed=$((elapsed + 1))
done

# Background sudo-cache refresher. Stops itself when the cache expires
# (so we don't loop pointlessly) or when the parent shell goes away.
sudo_refresher() {
    while sleep "$VPN_SUDO_REFRESH"; do
        sudo -nv 2>/dev/null || {
            log WARN "sudo cache expired; later kill may fail"
            return
        }
    done
}
sudo_refresher &
REFRESHER_PID=$!
trap 'kill "$REFRESHER_PID" 2>/dev/null || true' EXIT

last_state=$(nm_connectivity)
log INFO "watching VPN ${VPN_PROCESS_PID:-$VPN_PROCESS_NAME}; initial connectivity=${last_state:-unknown}"

while is_vpn_alive; do
    state=$(nm_connectivity)
    if [ -n "$state" ] && [ "$state" != "4" ] && [ "${last_state:-}" = "4" ]; then
        log INFO "connectivity dropped FULL -> $state; debouncing ${VPN_DEBOUNCE_SEC}s"
        sleep "$VPN_DEBOUNCE_SEC"
        new_state=$(nm_connectivity)
        if [ "$new_state" = "4" ]; then
            log INFO "connectivity recovered to FULL; not killing"
            last_state="4"
            continue
        fi
        log INFO "connectivity still $new_state; killing VPN"
        if kill_vpn; then
            log INFO "killed VPN"
        elif ! is_vpn_alive; then
            log INFO "VPN already gone (race); no-op"
        else
            log ERROR "kill failed (sudo expired or permission denied); VPN still running"
        fi
        exit 0
    fi
    last_state=$state
    sleep 1
done

log INFO "VPN exited; watcher exiting"
