#!/bin/bash
# Send a KakaoTalk message to myself (나에게 보내기)
# Usage: notify-webhook "message text"
# DISABLED: KakaoTalk 나에게 보내기 doesn't trigger push notifications
# TODO: replace with Telegram bot
exit 0
TOKENS="${DOTFILES_ROOT:-$HOME/.dotfiles}/private-dotfiles/kakao-tokens.json"
[ ! -f "$TOKENS" ] && exit 0

access_token=$(jq -r .access_token "$TOKENS")
refresh_token=$(jq -r .refresh_token "$TOKENS")
client_id=$(jq -r .client_id "$TOKENS")
client_secret=$(jq -r .client_secret "$TOKENS")

msg="${1:-alert from $(hostnamectl --pretty 2>/dev/null || hostname)}"

# Try sending
resp=$(curl -sf -o /dev/null -w '%{http_code}' -X POST https://kapi.kakao.com/v2/api/talk/memo/default/send \
  -H "Authorization: Bearer $access_token" \
  -d "template_object={\"object_type\":\"text\",\"text\":\"$msg\",\"link\":{}}")

# If 401, refresh token and retry
if [ "$resp" = "401" ]; then
  new=$(curl -sf -X POST https://kauth.kakao.com/oauth/token \
    -d "grant_type=refresh_token" \
    -d "client_id=$client_id" \
    -d "client_secret=$client_secret" \
    -d "refresh_token=$refresh_token")
  [ -z "$new" ] && exit 1
  new_at=$(echo "$new" | jq -r '.access_token // empty')
  new_rt=$(echo "$new" | jq -r '.refresh_token // empty')
  [ -z "$new_at" ] && exit 1
  jq --arg at "$new_at" --arg rt "${new_rt:-$refresh_token}" \
    '.access_token=$at | .refresh_token=$rt' "$TOKENS" > "$TOKENS.tmp" && mv "$TOKENS.tmp" "$TOKENS"
  curl -sf -X POST https://kapi.kakao.com/v2/api/talk/memo/default/send \
    -H "Authorization: Bearer $new_at" \
    -d "template_object={\"object_type\":\"text\",\"text\":\"$msg\",\"link\":{}}" >/dev/null
fi
