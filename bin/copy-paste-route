#!/usr/bin/env bash
# copy-paste-route — universal copy/paste dispatcher for X11.
#
# Bound by xmonad to Super+C / Super+V. Looks at the focused window's class
# and emits the correct keystroke for that app via xdotool:
#   - ghostty (any class variant): Ctrl+Shift+C / Ctrl+Shift+V (terminal default)
#   - everything else (firefox, native GTK, vivaldi, …): Ctrl+C / Ctrl+V
#
# This keeps the user's muscle memory at one combo (Super+C / Super+V) while
# delivering whatever the focused app actually expects. nvim is intentionally
# NOT special-cased — keep `yy` / `p` on the unnamed register; for system
# clipboard from within nvim, use the existing `"+y` / `"+p` flow.
#
# Env knobs (test surface):
#   COPY_PASTE_XDOTOOL          path to xdotool binary; default `xdotool`
#   COPY_PASTE_GHOSTTY_CLASSES  space-separated class names treated as ghostty;
#                               default covers known modern + legacy variants
#   LOG_TAG                     overridable; default copy-paste-route
#
# Failure modes:
#   - missing xdotool binary             → ERROR + exit 127
#   - getactivewindow / getwindowclassname fails (no X / no window) →
#                                          fall through to default Ctrl+C/V
#                                          (don't strand the user with a no-op)
#   - bad arg                            → exit 2 with usage

set -u

LOG_TAG="${LOG_TAG:-copy-paste-route}"
DOTFILES_ROOT="${DOTFILES_ROOT:-$HOME/.dotfiles}"
# shellcheck source=/dev/null
source "$DOTFILES_ROOT/script/logger/log.sh"

XDOTOOL="${COPY_PASTE_XDOTOOL:-xdotool}"

# Terminal emulators that need Ctrl+Shift+C/V instead of Ctrl+C/V.
# Override via $COPY_PASTE_TERMINAL_CLASSES if a new terminal is installed.
# `$COPY_PASTE_GHOSTTY_CLASSES` kept as a back-compat alias so existing
# tests / docs continue to work. Single-line on purpose: bash's
# line-continuation inside ${X:-...} parameter expansion is fragile under
# `set -u` and historically caused "action: unbound variable" errors with
# misleading line numbers on failure.
# Includes neovide: not strictly a terminal, but we want the same Ctrl+Shift+C/V
# keystroke so the same nvim mapping covers both terminal-nvim and neovide.
DEFAULT_TERMINAL_CLASSES="ghostty com.mitchellh.ghostty Ghostty gnome-terminal-server Gnome-terminal Alacritty alacritty kitty kitty-shell wezterm org.wezfurlong.wezterm foot xterm XTerm UXTerm urxvt URxvt rxvt-unicode konsole org.kde.konsole tilix com.gexperts.Tilix terminator Terminator neovide Neovide"
TERMINAL_CLASSES="${COPY_PASTE_TERMINAL_CLASSES:-${COPY_PASTE_GHOSTTY_CLASSES:-$DEFAULT_TERMINAL_CLASSES}}"

action="${1:-}"
case "$action" in
    copy|paste) ;;
    *)
        echo "usage: copy-paste-route {copy|paste}" >&2
        exit 2
        ;;
esac

if ! command -v "$XDOTOOL" >/dev/null 2>&1; then
    log ERROR "xdotool not found at \`$XDOTOOL\` — install via home.nix or pass COPY_PASTE_XDOTOOL"
    exit 127
fi

# Determine focused window class. Both calls can fail (no X, no focused
# window) — treat that as "use default Ctrl+C/V" rather than aborting.
wid=$("$XDOTOOL" getactivewindow 2>/dev/null) || wid=""
class=""
if [ -n "$wid" ]; then
    class=$("$XDOTOOL" getwindowclassname "$wid" 2>/dev/null) || class=""
fi

# Use the dedicated XF86Copy / XF86Paste keysyms instead of Ctrl+C/V or
# Ctrl+Shift+C/V. Reasoning: when xmonad's Super+C/V binding fires,
# Super is still physically held — combining Super with Ctrl+Shift+V
# yields Super+Ctrl+Shift+V which no app has bound, falling through to
# `^V` typed at the prompt. With XF86Copy / XF86Paste, the user-held
# Super becomes Super+XF86Paste — also not bound anywhere — and the
# receiving app strips the modifier and acts on the bare XF86Paste,
# which all major apps treat as clipboard ops:
#   - ghostty: `keybind = paste=paste_from_clipboard` by default
#   - firefox / vivaldi / native GTK: standard clipboard handlers
#   - xterm and other VTE-based: respond to XF86Paste
# This sidesteps the wait-for-Super-release dance entirely.
case "$action" in
    copy)  combo="XF86Copy" ;;
    paste) combo="XF86Paste" ;;
esac

log DEBUG "action=$action wid=${wid:-?} class=${class:-?} → $combo"

# Wait until the user's physical Super key is released before dispatching.
# Reason: X11 modifier handling means even XF86Paste with Super-still-held
# arrives as `Super+XF86Paste`, which apps that only bind `XF86Paste`
# silently ignore — that's why the first Super+V press feels dead until
# you've released Super, and subsequent presses (when Super is already
# up) work fine.
#
# 300ms timeout: keyd's `overloadt2(meta, prog1, 150)` already delays
# Super-down by 150ms before xmonad sees the binding fire, so by the
# time we get here the user's press-release cycle for V is usually
# already complete or finishing. 300ms covers slow releases without
# making fast presses feel laggy. Bail early if Super is still held —
# better to dispatch a slightly-broken keystroke than visibly hang.
#
# wait-for-key-release is a tiny C binary (~6ms cold start). Skipped if
# not on PATH — falls through to xdotool which still has --clearmodifiers.
WAIT="${COPY_PASTE_WAIT:-wait-for-key-release}"
if command -v "$WAIT" >/dev/null 2>&1; then
    "$WAIT" --timeout-ms 300 Super_L 2>/dev/null || true
fi

# Don't `exec` — it replaces the shell and skips log.sh's EXIT trap.
# --clearmodifiers + --window are defence-in-depth (synthetic-event
# modifier hygiene + focus-shift race protection).
if [ -n "$wid" ]; then
    "$XDOTOOL" key --clearmodifiers --window "$wid" "$combo"
else
    "$XDOTOOL" key --clearmodifiers "$combo"
fi
