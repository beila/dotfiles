#!/usr/bin/env bash
# Korean text-to-speech via edge-tts (requires internet)
# Usage: say-ko "한국어 텍스트" or echo "텍스트" | say-ko
#
# Voice is chosen from VOICE_POOL by the shared caller-key mapping in
# say-voice.sh (the single place hashing lives). $EDGE_TTS_VOICE still wins.
source "$(dirname "$0")/say-voice.sh"
VOICE_POOL=(ko-KR-SunHiNeural ko-KR-InJoonNeural ko-KR-HyunsuMultilingualNeural)

VOICE="${EDGE_TTS_VOICE:-${VOICE_POOL[$(say_pick_index "${#VOICE_POOL[@]}")]}}"
if [ $# -gt 0 ]; then
    TEXT="$*"
else
    TEXT="$(cat)"
fi
[ -z "$TEXT" ] && exit 0
TMP="$(mktemp /tmp/say-ko-XXXXXX.mp3)"
trap 'rm -f "$TMP"' EXIT
RATE="${EDGE_TTS_RATE:-+50%}"
uv run --quiet --with edge-tts -- edge-tts --voice "$VOICE" --rate "$RATE" --text "$TEXT" --write-media "$TMP" 2>/dev/null \
  && ffmpeg -v quiet -i "$TMP" -f wav -acodec pcm_s16le -ar 24000 -ac 1 pipe:1 2>/dev/null \
  | aplay -q 2>/dev/null
