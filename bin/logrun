#!/usr/bin/env bash
# logrun — run a command, tee its output to a timestamped log file (ANSI
# stripped), and pipe the live stream through a decorator (spacer + watchlog).
#
# Extracted from the recurse-brazil justfile (now under
# ~/.dotfiles/work-dotfiles/recurse-brazil) so multiple projects (and ad-hoc
# commands) can share the same log + decorator pipeline.
#
# Usage:
#   logrun [OPTIONS] <command> [args...]
#   logrun [OPTIONS] -c '<shell snippet>'     # run via `bash -c`
#
# Options:
#   --name NAME          Name used in the log filename (default: derived from cmd)
#   --log-dir DIR        Directory for the log file (default: $build_dir if dir,
#                        else ./build if dir, else /tmp)
#   --log-path PATH      Explicit log file path (overrides --name + --log-dir)
#   --no-decorator       Skip the decorator pipeline (tee only)
#   --decorator "CMD"    Custom decorator pipeline (shell pipe syntax OK)
#   --fail-suffix EXT    Rename log to "<name>.${EXT}" on non-zero exit
#                        (default: "FAILED.txt"). Empty disables.
#   --auto               Stay invisible until threshold is crossed (no startup
#                        banner; decorator is plain passthrough). On
#                        ≥LOGRUN_AUTO_SECONDS (10) wall-clock OR ≥LOGRUN_AUTO_LINES
#                        (100) output lines, print "Log: <path>" to stderr and
#                        the decorator (bin/logrun-decorator) starts emitting
#                        idle indicators. Under threshold → log file removed
#                        regardless of exit code (the wrap stays invisible);
#                        a non-zero exit only reveals the log when the run
#                        also crossed a threshold.
#   --no-zshrc           With positional argv, exec the command directly
#                        instead of via `zsh -ic`. Skips ~800ms zshrc startup
#                        for plain externals (the widget passes this).
#   -c, --command STR    Run STR via `bash -c` instead of positional args.
#   -h, --help           Show this help.
#
# Environment (read on startup; any flag overrides):
#   log_path             Pre-set log file path (nested recipes pass this down)
#   build_dir            Preferred default log directory
#   LOGRUN_DECORATOR     Default decorator pipeline
#   LOGRUN_AUTO_SECONDS  --auto wall-clock threshold (default 10)
#   LOGRUN_AUTO_LINES    --auto line-count threshold (default 100)
#   LOGRUN_TUI_SKIPLIST  Space-separated TUI command names; if --auto is set
#                        and the captured log shows alt-screen entry from a
#                        command not in this list, print a hint to add it.
#
# Per-call opt-out: prefix the prompt command with `NOLOG=1` (e.g.
# `NOLOG=1 my-cmd`). That's interpreted by the zsh accept-line widget at
# zsh/zz-logrun-auto.zsh, NOT by logrun itself — logrun has no NOLOG
# handling because by the time logrun is invoked, the user already wanted
# logging. See zsh/AGENTS.md "logrun-auto widget".
#
# Exit status: the wrapped command's exit status.
set -uo pipefail

show_help() { sed -n '2,/^set /p' "$0" | sed -n 's/^# \{0,1\}//p' | sed '$d'; }

name=""
log_dir=""
log_path_explicit="${log_path:-}"
decorator=""
fail_suffix="FAILED.txt"
shell_mode=0
shell_cmd=""
auto_mode=0
no_zshrc=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)          name="$2"; shift 2 ;;
        --log-dir)       log_dir="$2"; shift 2 ;;
        --log-path)      log_path_explicit="$2"; shift 2 ;;
        --no-decorator)  decorator="cat"; shift ;;
        --decorator)     decorator="$2"; shift 2 ;;
        --fail-suffix)   fail_suffix="$2"; shift 2 ;;
        --auto)          auto_mode=1; shift ;;
        --no-zshrc)      no_zshrc=1; shift ;;
        -c|--command)    shell_mode=1; shell_cmd="$2"; shift 2 ;;
        -h|--help)       show_help; exit 0 ;;
        --)              shift; break ;;
        --*)             echo "logrun: unknown option: $1" >&2; exit 2 ;;
        *)               break ;;
    esac
done

# Capture the user-typed first word (for the alt-screen TUI hint and for
# auto-suggestion logic). `name` may already be set by the caller; fall
# back to first positional or the first word of the shell command.
if [[ -n "$name" ]]; then
    cmd_name="$name"
elif (( shell_mode )); then
    cmd_name="${shell_cmd%% *}"
else
    cmd_name="${1:-}"
fi
cmd_name="${cmd_name##*/}"

# Capture original positional argv joined (used as the log-name default
# when the caller didn't pass --name). This must run BEFORE the
# `set -- script -qefc ...` rewrite below clobbers $@ with the PTY
# wrapper invocation, otherwise the log filename would carry
# "script-qefc-zsh-ic-..." instead of the user's actual command.
if [[ $# -gt 0 ]]; then
    orig_argv_joined="$*"
else
    orig_argv_joined=""
fi

# Decide how to run the wrapped command. In --auto, every path wraps
# in `script -qefc` (PTY) when available so color-aware tools see a
# real tty on stdout. See AGENTS.md "PTY layer for color".
#   --no-zshrc        → exec the command directly (fast path, no zshrc replay).
#   shell_mode (-c)   → `zsh -ic '<body>'` so aliases/functions resolve.
#   positional argv   → rebuild as a quoted string + `zsh -ic` (same reason).
_logrun_pty_wrap() {
    # script -q quiet, -e propagate exit, -f flush after writes,
    # -c run command, /dev/null = no typescript file (we have our own log).
    if (( auto_mode )) && command -v script >/dev/null 2>&1; then
        echo "script -qefc"
    fi
}

# Probe the controlling tty's size and emit a `stty` prefix that resizes
# the PTY `script` will create. util-linux's `script` doesn't expose a
# size flag and only inherits the size from its STDIN, but logrun's stdin
# in the auto pipeline isn't always the user's tty (e.g. when invoked
# from a wrapper or sub-shell). Without this, ls/eza/git inside the PTY
# see the default 80x24 (or worse) and lay out content at the wrong
# width. Emits an empty string when no tty is reachable.
_logrun_pty_size_prefix() {
    # `</dev/tty` and its error if /dev/tty is missing both go through the
    # outer command; redirect bash's own redirection-error to /dev/null
    # by wrapping in a subshell with all stderr suppressed.
    local sz
    sz=$( { stty size </dev/tty; } 2>/dev/null ) || return
    [[ -n "$sz" ]] || return
    # sz is "ROWS COLS"; stty wants `rows R cols C`.
    set -- $sz
    [[ "$1" -gt 0 && "$2" -gt 0 ]] || return
    printf 'stty rows %s cols %s 2>/dev/null; ' "$1" "$2"
}

if (( shell_mode )); then
    pty_prefix=$(_logrun_pty_wrap)
    if [[ -n "$pty_prefix" ]]; then
        sz=$(_logrun_pty_size_prefix)
        set -- script -qefc "${sz}zsh -ic $(printf '%q' "$shell_cmd")" /dev/null
    else
        set -- zsh -ic "$shell_cmd"
    fi
elif [[ $# -gt 0 ]]; then
    if (( no_zshrc )); then
        pty_prefix=$(_logrun_pty_wrap)
        if [[ -n "$pty_prefix" ]]; then
            cmdline=""
            for arg in "$@"; do
                cmdline+=" $(printf '%q' "$arg")"
            done
            sz=$(_logrun_pty_size_prefix)
            set -- script -qefc "${sz}${cmdline}" /dev/null
        fi
    else
        # printf %q quotes each arg so paths-with-spaces round-trip
        # correctly through zsh's word splitter.
        cmdline=""
        for arg in "$@"; do
            cmdline+=" $(printf '%q' "$arg")"
        done
        pty_prefix=$(_logrun_pty_wrap)
        if [[ -n "$pty_prefix" ]]; then
            sz=$(_logrun_pty_size_prefix)
            set -- script -qefc "${sz}zsh -ic $(printf '%q' "$cmdline")" /dev/null
        else
            set -- zsh -ic "$cmdline"
        fi
    fi
fi

if [[ $# -eq 0 ]]; then
    echo "logrun: no command specified (use --help for usage)" >&2
    exit 2
fi

# ------------------------------------------------------------------- log path
if [[ -n "$log_path_explicit" ]]; then
    log_path="$log_path_explicit"
else
    # Derive a filesystem-safe name. If caller didn't pass --name, prefer
    # the original command body (captured before we rewrote $@ to wrap
    # in `script`/`zsh -ic`). Falls back to the live $* for legacy
    # callers that bypass the captured forms.
    if [[ -z "$name" ]]; then
        if [[ -n "$shell_cmd" ]]; then
            name="$shell_cmd"
        elif [[ -n "$orig_argv_joined" ]]; then
            name="$orig_argv_joined"
        else
            name="$*"
        fi
    fi
    sanitized="$name"
    sanitized=${sanitized//$'\n'/-}
    sanitized=${sanitized//[[:space:]]/-}
    sanitized=${sanitized//\//-}
    sanitized=${sanitized//|/-}
    sanitized=${sanitized//#/-}
    sanitized=${sanitized//&/-}
    sanitized=${sanitized//\*/-}
    sanitized=${sanitized//\$/-}
    sanitized=${sanitized//\\/-}
    sanitized=${sanitized//;/-}
    sanitized=${sanitized//(/-}
    sanitized=${sanitized//)/-}
    sanitized=${sanitized//</-}
    sanitized=${sanitized//>/-}
    sanitized=${sanitized//\`/-}
    sanitized=${sanitized//\'/}
    sanitized=${sanitized//\"/}
    sanitized=${sanitized:0:200}    # ext4/xfs filename limit is 255 bytes

    if [[ -z "$log_dir" ]]; then
        if [[ -n "${build_dir:-}" && -d "$build_dir" ]]; then
            log_dir="$build_dir"
        elif [[ -d build ]]; then
            log_dir="build"
        else
            log_dir="/tmp"
        fi
    fi
    mkdir -p "$log_dir"
    log_path="$log_dir/log-${sanitized}-$(date +%F-%H-%M-%S).txt"
fi

# --------------------------------------------------------------- auto-mode IPC
# In --auto mode, the strip-ansi side branch counts lines and watches for
# the alt-screen entry sequence. Side-channel files coordinate with the
# parent: $auto_lines_file (threshold marker) + $auto_tui_file (alt-screen
# detected). Allocated here (before the decorator block) so the decorator
# can poll $auto_lines_file.shown to know when to switch out of cat mode.
# These get cleaned up on EXIT.
auto_seconds="${LOGRUN_AUTO_SECONDS:-10}"
auto_lines="${LOGRUN_AUTO_LINES:-100}"
revealed=0
auto_lines_file=""
auto_tui_file=""
auto_timer_pid=""
if (( auto_mode )); then
    auto_lines_file=$(mktemp "/tmp/logrun-lines.XXXXXX")
    auto_tui_file="/tmp/logrun-tui.$$"
    rm -f "$auto_tui_file"
fi

# ------------------------------------------------------------------- decorator
# In --auto mode: bin/logrun-decorator is plain cat until the reveal
# marker file appears, then prints spacer-style breaks + idle indicators.
# This avoids the ~1s tail spacer/watchlog adds to every short --auto run
# while still surfacing idle hints on long ones. Marker file is touched by
# _logrun_on_reveal (threshold-trip or failure).
#
# Outside --auto: spacer | watchlog stack (always-on visual breaks).
# In both cases LOGRUN_DECORATOR overrides everything.
if [[ -z "$decorator" ]]; then
    if [[ -n "${LOGRUN_DECORATOR:-}" ]]; then
        decorator="$LOGRUN_DECORATOR"
    elif (( auto_mode )) && command -v logrun-decorator >/dev/null 2>&1; then
        decorator="logrun-decorator --activate-when-exists $(printf '%q' "$auto_lines_file.shown")"
    else
        # `watchlog` is the package; the binary it ships is `wl` (per its
        # README: "put | wl after your command"). Older builds may have
        # exposed it under the package name; check that as a fallback.
        parts=()
        command -v spacer >/dev/null 2>&1 && parts+=("spacer --right --force-color")
        if   command -v wl       >/dev/null 2>&1; then parts+=("wl")
        elif command -v watchlog >/dev/null 2>&1; then parts+=("watchlog")
        fi
        if [[ ${#parts[@]} -eq 0 ]]; then
            decorator="cat"
        else
            decorator=$(IFS='|'; echo "${parts[*]}")
        fi
    fi
fi

# ------------------------------------------------------------------- ANSI strip
# Drop CSI SGR/cursor-move/erase sequences so the log file is greppable.
# sed expr from https://stackoverflow.com/a/18000433 (referenced in the
# original justfile pattern). `-u` is GNU sed's line-buffered mode; it
# lets `tee` flush in real time when piping the live stream.
# Expressions, in order:
#   1. CSI sequences (\x1b[ ... [mGK])
#   2. OSC 8 hyperlinks (\x1b]…(\x07|\x1b\)) — uvx/rich/eza wrap link
#      text in `OSC 8 ; params ; URL ST … OSC 8 ; ; ST`. The visible text
#      between the two OSCs is preserved; only the escapes are stripped.
#   3. In-line carriage-return redraws — progress spinners (uv/uvx/pip/
#      cargo/docker pull) rewrite the same line with `\r` and only emit
#      `\n` at the very end; without this the log ends up with every
#      spinner frame concatenated into one giant line. `.*\r` is greedy
#      so it keeps only what follows the LAST `\r` — i.e. the final
#      frame the user actually saw. Runs LAST so OSC text inside earlier
#      frames is already neutralised.
strip_ansi=(sed -ur 's/\x1B\[([0-9]{1,3}(;[0-9]{1,2};?)?)?[mGK]//g; s/\x1B\][^\x07\x1B]*(\x07|\x1B\\)//g; s/.*\r//')

_logrun_on_reveal() {
    # Two markers, two purposes:
    #   "$auto_lines_file.shown"   touched by awk/timer so logrun-decorator
    #                              activates mid-run (synchronous; can't wait
    #                              for the deferred USR2 trap below).
    #   "$auto_lines_file.banner"  this trap's once-flag; controls whether
    #                              we've already emitted the "Log:" line.
    [[ -e "$auto_lines_file.banner" ]] && return
    : > "$auto_lines_file.banner"
    : > "$auto_lines_file.shown"   # idempotent; in case awk hasn't run
    echo "Log: $log_path" >&2
}
# Use a marker file rather than a shell variable for the "did we reveal?"
# state, because bash signal traps run async with respect to the main
# pipeline — a `revealed=1` set in the trap may not be visible to the
# post-run code. The marker file is checked synchronously after the
# pipeline returns.
trap _logrun_on_reveal USR2

# --------------------------------------------------------- mid-run relocation
# Let the wrapped command ask us to move the log file to a different
# directory partway through, by writing the target DIR to
# "$LOGRUN_MOVE_FILE" and sending SIGUSR1 to "$LOGRUN_PID". The filename
# (including timestamp) is preserved; only the directory changes. The
# `logrun-move` helper wraps that handshake.
#
# Why mv works mid-stream: `tee >(strip_ansi > "$log_path")` holds an open
# fd on the inode, not the pathname. Renaming the file doesn't touch the fd,
# so subsequent writes land in the renamed file automatically.
LOGRUN_MOVE_FILE=$(mktemp "/tmp/logrun-move.XXXXXX")
LOGRUN_NOLOG_FILE=$(mktemp "/tmp/logrun-nolog.XXXXXX")
export LOGRUN_PID=$$
export LOGRUN_MOVE_FILE
export LOGRUN_NOLOG_FILE
# Clean side-channel files on exit. The auto_lines_file/auto_tui_file are
# empty strings outside --auto mode so `rm -f ""` is a no-op.
trap 'rm -f "$LOGRUN_MOVE_FILE" "$LOGRUN_NOLOG_FILE" "$auto_lines_file" "$auto_lines_file.shown" "$auto_lines_file.banner" "$auto_tui_file"; \
      [[ -n "$auto_timer_pid" ]] && kill "$auto_timer_pid" 2>/dev/null; :' EXIT

_logrun_on_move() {
    local new_dir target
    new_dir=$(cat "$LOGRUN_MOVE_FILE" 2>/dev/null) || return
    [[ -n "$new_dir" ]] || return
    mkdir -p "$new_dir" 2>/dev/null || true
    target="$new_dir/$(basename "$log_path")"
    if [[ "$target" == "$log_path" ]]; then
        :   # no-op: already there
    elif mv "$log_path" "$target" 2>/dev/null; then
        log_path="$target"
        echo "Log moved to: $target" >&2
    fi
    : > "$LOGRUN_MOVE_FILE"
}
trap _logrun_on_move USR1

# ------------------------------------------------------------------- run it
# The startup banner is suppressed in --auto mode: it gets printed
# retroactively if/when a threshold is crossed (see _logrun_on_reveal),
# or once at the end if the run exited non-zero.
if ! (( auto_mode )); then
    echo "Log: $log_path" >&2
fi

# In --auto mode, kick off the wall-clock timer that signals SIGUSR2 to
# this script after $auto_seconds. The timer is reaped via the EXIT trap.
# Subshell stdio goes to /dev/null so the inner `sleep`, which `kill
# $auto_timer_pid` can't reach (it kills the bash subshell, not its
# child), can't hold the parent's stdio open after we exit. See AGENTS.md
# "Wallclock timer detached stdio".
if (( auto_mode )); then
    ( exec </dev/null >/dev/null 2>&1
      sleep "$auto_seconds" \
        && echo "wallclock" >> "$auto_lines_file" \
        && touch "$auto_lines_file.shown" 2>/dev/null \
        && kill -USR2 $$ 2>/dev/null ) &
    auto_timer_pid=$!
fi

# Pipeline:
#   cmd 2>&1                            — merge stderr into stdout
#   | tee >(filter > "$log_path")       — write a clean copy to the file
#   | eval "$decorator"                 — show the decorated stream on the tty
#
# `PIPESTATUS[0]` preserves the wrapped command's exit code regardless of
# what tee/decorator return. `unbuffer`/`stdbuf` aren't needed because
# both spacer and watchlog implement their own periodic timers.
#
# In --auto mode the file-side filter is awk (not sed): one pass strips
# ANSI for the log, counts lines (signalling SIGUSR2 + writing the
# marker file once $auto_lines is crossed), and flags alt-screen entry
# into $auto_tui_file. Awk runs on the SIDE branch (via fd 4), not the
# foreground — gawk's block-buffered stdin would otherwise delay the
# first line of output until enough bytes accumulate.
if (( auto_mode )); then
    parent_pid=$$
    # Pre-create the log so the FAILED-rename path has something to
    # rename when the command produces no output (e.g. `bash -c 'exit 7'`).
    : > "$log_path"
    # Open the awk process substitution as fd 4 so $! captures its pid
    # for a targeted `wait` later (bare `wait` would also block on the
    # wallclock timer).
    #
    # Prefer gawk when available; fall back to mawk with `-W interactive`.
    # Two distinct buffering problems force the choice:
    #
    #   1. mawk's input is block-buffered by default → threshold detection
    #      is delayed until the buffer fills. With `echo a; echo b;
    #      sleep 3; echo done` (LOGRUN_AUTO_LINES=2), plain mawk wouldn't
    #      process the `b` that crosses the threshold until the post-sleep
    #      `done` brought the buffer to flush size. By then the pipeline
    #      has effectively ended and the decorator has already closed its
    #      stdin. `-W interactive` puts mawk in line-buffered mode and
    #      fixes this — but introduces problem 2.
    #
    #   2. mawk in `-W interactive` mode caps a single record at ~8KB
    #      and silently truncates anything longer. Some tools (notably
    #      `uvx`/`uv`/`rich`/`textual` apps) emit large progress redraws
    #      or whole tables as a single 20+KB chunk with no LF until the
    #      end. Truncation drops everything past 8KB from the on-disk
    #      log even though the user saw it on the terminal — the regression
    #      that motivated installing gawk via home-manager.
    #
    # gawk is line-buffered on pipes by default (no flag needed) AND has
    # no record-size cap, so it's strictly better here. If neither gawk
    # nor mawk-with-`-W interactive` is available we fall back to plain
    # `awk` and accept whichever trade-off the host's awk implements.
    _awk_bin="awk"
    _awk_flags=""
    if command -v gawk >/dev/null 2>&1; then
        _awk_bin="gawk"
    elif awk --version 2>&1 | grep -q '^mawk'; then
        _awk_flags="-W interactive"
    fi
    exec 4> >("$_awk_bin" $_awk_flags \
                  -v line_thr="$auto_lines" \
                  -v lines_file="$auto_lines_file" \
                  -v shown_file="$auto_lines_file.shown" \
                  -v tui_file="$auto_tui_file" \
                  -v parent="$parent_pid" \
                  -v log_path="$log_path" '
        BEGIN { hit_lines=0; hit_tui=0 }
        {
            if (!hit_tui && index($0, "\033[?1049h") > 0) {
                hit_tui=1
                cmd = "touch " tui_file " 2>/dev/null"; system(cmd); close(cmd)
            }
            gsub(/\033\[[0-9]+(;[0-9]+)*;?[mGK]/, "")
            gsub(/\033\[[mGK]/, "")
            gsub(/\033\[\?1049[hl]/, "")
            gsub(/\033\[\?25[hl]/, "")
            # OSC 8 hyperlinks: ESC ] params ; URL ST … ESC ] ; ; ST.
            # uvx/rich/eza wrap link text this way. The visible text
            # between the two OSCs is preserved; only the escapes go.
            # ST is either BEL (\007) or ESC \ — match both.
            gsub(/\033\][^\007\033]*(\007|\033\\)/, "")
            # script(1) adds \r before \n on every line because the
            # PTY runs in canonical mode. Drop it from the log so the
            # file matches the non-PTY representation.
            sub(/\r$/, "")
            # Collapse in-line carriage-return redraws: progress
            # spinners (uv/uvx, pip, cargo, docker pull, …) rewrite the
            # same line with \r and only emit \n at the very end, so
            # without this every frame ends up concatenated into one
            # giant line. Keep only the text after the last remaining
            # \r — i.e. the final frame the user actually saw. Done
            # AFTER the trailing-\r strip so PTY-canonical "hello\r"
            # stays as "hello" instead of getting wiped to "".
            sub(/.*\r/, "")
            print > log_path
            fflush(log_path)
            if (!hit_lines && NR >= line_thr) {
                hit_lines=1
                # Touch the .shown marker IMMEDIATELY so logrun-decorator
                # (which polls it) activates mid-run. The parent USR2 trap
                # also touches it, but bash defers the trap until the
                # foreground pipeline returns — way too late for the
                # decorator, which has already closed its stdin by then.
                cmd = "touch " shown_file " 2>/dev/null"; system(cmd); close(cmd)
                cmd = "printf lines >> " lines_file; system(cmd); close(cmd)
                cmd = "kill -USR2 " parent " 2>/dev/null"; system(cmd); close(cmd)
            }
        }')
    parent_pid=$$
    awk_pid=$!
    # `4>&-` closes fd 4 in the wrapped process so descendants (notably
    # zsh helpers like gitstatus / zsh-async) don't inherit it and
    # block awk's EOF after we exit. tee's own fd 4 is unaffected —
    # the redirection only applies to "$@". See AGENTS.md "fd 4 isolation".
    # `tee -p` (warn-nopipe): when the decorator stage exits early and
    # SIGPIPEs tee's stdout, tee keeps running and continues writing to
    # fd 4 — otherwise the log file would be truncated mid-stream
    # (e.g. ninja output past the failure point would be visible on the
    # tty via the decorator but missing from the log).
    "$@" 2>&1 4>&- \
        | tee -p /dev/fd/4 \
        | eval "$decorator"
    exit_code=${PIPESTATUS[0]}
    # Close fd 4 so awk sees EOF and exits, then wait specifically for
    # it. Targeted wait avoids blocking on the wallclock timer.
    exec 4>&-
    [[ -n "$awk_pid" ]] && wait "$awk_pid" 2>/dev/null
else
    "$@" 2>&1 \
        | tee -p >("${strip_ansi[@]}" > "$log_path") \
        | eval "$decorator"
    exit_code=${PIPESTATUS[0]}
fi

# Stop the wall-clock timer; we no longer need it.
if [[ -n "$auto_timer_pid" ]]; then
    kill "$auto_timer_pid" 2>/dev/null
    auto_timer_pid=""
fi

# --------------------------------------------------------- nolog disposition
# The wrapped command called `logrun-nolog` → discard the log unconditionally.
if [[ -s "$LOGRUN_NOLOG_FILE" ]]; then
    rm -f "$log_path"
    exit "$exit_code"
fi

# ------------------------------------------------------- auto-mode disposition
if (( auto_mode )); then
    # Threshold-tripped iff the marker file is non-empty (set
    # synchronously by either the awk filter on line-count or the
    # wallclock timer). Don't rely on the in-trap variable — bash
    # async signal handling makes that flag unreliable here.
    [[ -s "$auto_lines_file" ]] && revealed=1

    if (( revealed )); then
        # Threshold tripped during the run. On non-zero exit, apply the
        # FAILED rename and surface the renamed path (the in-run trap
        # already printed the original path, so this becomes a "Log
        # renamed: …" line so the user doesn't think two separate logs
        # were created).
        if (( exit_code != 0 )) && [[ -n "$fail_suffix" ]]; then
            failed_path="${log_path%.txt}.${fail_suffix}"
            if mv "$log_path" "$failed_path" 2>/dev/null; then
                log_path="$failed_path"
                echo "Log renamed: $log_path" >&2
            fi
        fi
    else
        # Under threshold: the wrap stays invisible. Erase the log
        # regardless of exit code — a fast failure looks identical to
        # bare execution. The user gets the command's own stderr; if
        # they want a log, they can rerun without --auto or with
        # LOGRUN_AUTO_SECONDS=0.
        rm -f "$log_path"
    fi

    # Alt-screen hint: we saw a TUI we don't know about. Append it to
    # the user-skiplist file (default $HOME/.dotfiles/bin/logrun-tui-skiplist
    # — kept inside the dotfiles repo so entries sync across machines via
    # the same git/jj flow as everything else; .gitattributes maps it to
    # `merge=union` so concurrent appends auto-merge). The widget at
    # zsh/zz-logrun-auto.zsh reads it on every prompt with an mtime-cache,
    # so the next command sees the new entry without a shell restart.
    # $LOGRUN_TUI_SKIPLIST stays the canonical machine-default source
    # (set in home-manager); the file is the cross-machine user delta.
    if [[ -f "$auto_tui_file" && -n "$cmd_name" ]]; then
        skiplist_file="${LOGRUN_TUI_SKIPLIST_FILE:-$HOME/.dotfiles/bin/logrun-tui-skiplist}"
        skiplist_env=" ${LOGRUN_TUI_SKIPLIST:-} "
        skiplist_user=""
        [[ -f "$skiplist_file" ]] && skiplist_user=" $(grep -v '^#' "$skiplist_file" 2>/dev/null | tr '\n' ' ') "
        if [[ "$skiplist_env" != *" $cmd_name "* && "$skiplist_user" != *" $cmd_name "* ]]; then
            mkdir -p "$(dirname "$skiplist_file")" 2>/dev/null
            if [[ ! -s "$skiplist_file" ]]; then
                printf '# logrun TUI skiplist (auto-managed). One command name per line.\n' >> "$skiplist_file"
            fi
            printf '%s\n' "$cmd_name" >> "$skiplist_file"
            echo "logrun: detected TUI '$cmd_name' (alt-screen); added to $skiplist_file" >&2
        fi
    fi

    exit "$exit_code"
fi

# ------------------------------------------------------------------- fail tag
if (( exit_code != 0 )) && [[ -n "$fail_suffix" ]]; then
    failed_path="${log_path%.txt}.${fail_suffix}"
    if mv "$log_path" "$failed_path" 2>/dev/null; then
        log_path="$failed_path"
    fi
fi

echo "Log: $log_path" >&2
exit "$exit_code"
