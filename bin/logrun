#!/usr/bin/env bash
# logrun â€” run a command, tee its output to a timestamped log file (ANSI
# stripped), and pipe the live stream through a decorator (spacer + watchlog).
#
# Extracted from the recurse-brazil justfile (now under
# ~/.dotfiles/work-dotfiles/recurse-brazil) so multiple projects (and ad-hoc
# commands) can share the same log + decorator pipeline.
#
# Usage:
#   logrun [OPTIONS] <command> [args...]
#   logrun [OPTIONS] -c '<shell snippet>'     # run via `bash -c`
#
# Options:
#   --name NAME          Name used in the log filename (default: derived from cmd)
#   --log-dir DIR        Directory for the log file (default: $build_dir if dir,
#                        else ./build if dir, else /tmp)
#   --log-path PATH      Explicit log file path (overrides --name + --log-dir)
#   --no-decorator       Skip the decorator pipeline (tee only)
#   --decorator "CMD"    Custom decorator pipeline (shell pipe syntax OK)
#   --fail-suffix EXT    Rename log to "<name>.${EXT}" on non-zero exit
#                        (default: "FAILED.txt"). Empty disables.
#   --auto               Stay invisible until threshold is crossed (no startup
#                        banner; decorator=cat; output passes through). On
#                        â‰ĄLOGRUN_AUTO_SECONDS (10) wall-clock OR â‰ĄLOGRUN_AUTO_LINES
#                        (100) output lines, print "Log: <path>" to stderr and
#                        switch to spacer+watchlog. If neither tripped and exit
#                        code is 0, the log file is removed on exit.
#   --no-zshrc           With positional argv, exec the command directly
#                        instead of via `zsh -ic`. Skips ~800ms zshrc startup
#                        for plain externals (the widget passes this).
#   -c, --command STR    Run STR via `bash -c` instead of positional args.
#   -h, --help           Show this help.
#
# Environment (read on startup; any flag overrides):
#   log_path             Pre-set log file path (nested recipes pass this down)
#   build_dir            Preferred default log directory
#   LOGRUN_DECORATOR     Default decorator pipeline
#   LOGRUN_AUTO_SECONDS  --auto wall-clock threshold (default 10)
#   LOGRUN_AUTO_LINES    --auto line-count threshold (default 100)
#   LOGRUN_TUI_SKIPLIST  Space-separated TUI command names; if --auto is set
#                        and the captured log shows alt-screen entry from a
#                        command not in this list, print a hint to add it.
#
# Exit status: the wrapped command's exit status.
set -uo pipefail

show_help() { sed -n '2,/^set /p' "$0" | sed -n 's/^# \{0,1\}//p' | sed '$d'; }

name=""
log_dir=""
log_path_explicit="${log_path:-}"
decorator=""
fail_suffix="FAILED.txt"
shell_mode=0
shell_cmd=""
auto_mode=0
no_zshrc=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)          name="$2"; shift 2 ;;
        --log-dir)       log_dir="$2"; shift 2 ;;
        --log-path)      log_path_explicit="$2"; shift 2 ;;
        --no-decorator)  decorator="cat"; shift ;;
        --decorator)     decorator="$2"; shift 2 ;;
        --fail-suffix)   fail_suffix="$2"; shift 2 ;;
        --auto)          auto_mode=1; shift ;;
        --no-zshrc)      no_zshrc=1; shift ;;
        -c|--command)    shell_mode=1; shell_cmd="$2"; shift 2 ;;
        -h|--help)       show_help; exit 0 ;;
        --)              shift; break ;;
        --*)             echo "logrun: unknown option: $1" >&2; exit 2 ;;
        *)               break ;;
    esac
done

# Capture the user-typed first word (for the alt-screen TUI hint and for
# auto-suggestion logic). `name` may already be set by the caller; fall
# back to first positional or the first word of the shell command.
if [[ -n "$name" ]]; then
    cmd_name="$name"
elif (( shell_mode )); then
    cmd_name="${shell_cmd%% *}"
else
    cmd_name="${1:-}"
fi
cmd_name="${cmd_name##*/}"

# Decide how to run the wrapped command:
#   --no-zshrc             â†’ exec directly. Fastest, no shell startup
#                            (widget uses this for plain externals).
#   shell_mode (-c body)   â†’ run via `zsh -ic 'body'` so the user's
#                            aliases/functions resolve. In --auto mode
#                            we additionally wrap in `script -qefc` so
#                            the inner zsh's stdout is a PTY â€” that way
#                            color-aware tools (`ls --color=auto`,
#                            `git`, `grep --color=auto`) emit colour
#                            because their isatty(stdout) check inside
#                            the body sees a real tty, not logrun's
#                            tee pipe. util-linux script is universal
#                            on Linux; if absent, fall back to bare
#                            zsh -ic (color disappears but everything
#                            else still works).
#   positional argv        â†’ if ! --no-zshrc, rebuild as a quoted
#                            string and route through the same shell
#                            path so aliases resolve.
_logrun_pty_wrap() {
    if (( auto_mode )) && command -v script >/dev/null 2>&1; then
        # script -q quiet, -e propagate exit code, -f flush after writes,
        # -c run command, /dev/null skips the typescript file (we have
        # our own log path).
        echo "script -qefc"
    fi
}

if (( shell_mode )); then
    pty_prefix=$(_logrun_pty_wrap)
    if [[ -n "$pty_prefix" ]]; then
        set -- script -qefc "zsh -ic $(printf '%q' "$shell_cmd")" /dev/null
    else
        set -- zsh -ic "$shell_cmd"
    fi
elif [[ $# -gt 0 ]]; then
    if (( no_zshrc )); then
        # Fast path: exec the command directly, no shell startup. The
        # widget passes this for resolved external binaries â€” aliases /
        # functions would not be visible to a fresh process anyway, so
        # we don't need `zsh -ic` here. Saves ~800ms per prompt.
        :
    else
        # Positional argv (e.g. `logrun la`): rebuild as a shell-safe
        # command string and pipe it through zsh -ic so aliases/functions
        # resolve. With bash exec the alias `la` would just be "command
        # not found". printf %q quotes each arg so paths-with-spaces and
        # other specials round-trip correctly through zsh's word splitter.
        cmdline=""
        for arg in "$@"; do
            cmdline+=" $(printf '%q' "$arg")"
        done
        pty_prefix=$(_logrun_pty_wrap)
        if [[ -n "$pty_prefix" ]]; then
            set -- script -qefc "zsh -ic $(printf '%q' "$cmdline")" /dev/null
        else
            set -- zsh -ic "$cmdline"
        fi
    fi
fi

if [[ $# -eq 0 ]]; then
    echo "logrun: no command specified (use --help for usage)" >&2
    exit 2
fi

# ------------------------------------------------------------------- log path
if [[ -n "$log_path_explicit" ]]; then
    log_path="$log_path_explicit"
else
    # Derive a filesystem-safe name. If caller didn't pass --name, use the
    # full argv joined. The sanitisation (replace whitespace/special chars
    # with `-`, drop quotes, truncate to 200 chars) matches the existing
    # justfile pattern.
    if [[ -z "$name" ]]; then
        name="$*"
    fi
    sanitized="$name"
    sanitized=${sanitized//$'\n'/-}
    sanitized=${sanitized//[[:space:]]/-}
    sanitized=${sanitized//\//-}
    sanitized=${sanitized//|/-}
    sanitized=${sanitized//#/-}
    sanitized=${sanitized//&/-}
    sanitized=${sanitized//\*/-}
    sanitized=${sanitized//\$/-}
    sanitized=${sanitized//\\/-}
    sanitized=${sanitized//;/-}
    sanitized=${sanitized//(/-}
    sanitized=${sanitized//)/-}
    sanitized=${sanitized//</-}
    sanitized=${sanitized//>/-}
    sanitized=${sanitized//\`/-}
    sanitized=${sanitized//\'/}
    sanitized=${sanitized//\"/}
    sanitized=${sanitized:0:200}    # ext4/xfs filename limit is 255 bytes

    if [[ -z "$log_dir" ]]; then
        if [[ -n "${build_dir:-}" && -d "$build_dir" ]]; then
            log_dir="$build_dir"
        elif [[ -d build ]]; then
            log_dir="build"
        else
            log_dir="/tmp"
        fi
    fi
    mkdir -p "$log_dir"
    log_path="$log_dir/log-${sanitized}-$(date +%F-%H-%M-%S).txt"
fi

# ------------------------------------------------------------------- decorator
if (( auto_mode )); then
    # In --auto mode the user wants the terminal to look identical to a
    # bare command for short runs. spacer/watchlog would print idle
    # indicators and visual breaks even when nothing's interesting.
    # Pin to cat for the entire run.
    decorator="cat"
elif [[ -z "$decorator" ]]; then
    if [[ -n "${LOGRUN_DECORATOR:-}" ]]; then
        decorator="$LOGRUN_DECORATOR"
    else
        parts=()
        # spacer inserts a visual break when output stops; watchlog adds a
        # "time since last output" indicator when a command goes idle.
        command -v spacer   >/dev/null 2>&1 && parts+=("spacer --right --force-color")
        if   command -v watchlog >/dev/null 2>&1; then parts+=("watchlog")
        elif command -v wl       >/dev/null 2>&1; then parts+=("wl")
        fi
        if [[ ${#parts[@]} -eq 0 ]]; then
            decorator="cat"
        else
            decorator=$(IFS='|'; echo "${parts[*]}")
        fi
    fi
fi

# ------------------------------------------------------------------- ANSI strip
# Drop CSI SGR/cursor-move/erase sequences so the log file is greppable.
# sed expr from https://stackoverflow.com/a/18000433 (referenced in the
# original justfile pattern). `-u` is GNU sed's line-buffered mode; it
# lets `tee` flush in real time when piping the live stream.
strip_ansi=(sed -ur 's/\x1B\[([0-9]{1,3}(;[0-9]{1,2};?)?)?[mGK]//g')

# --------------------------------------------------------------- auto-mode IPC
# In --auto mode, the strip-ansi side branch counts lines and watches for
# the alt-screen entry sequence. Two side-channel files coordinate with
# the parent (this script):
#   $LOGRUN_LINES_FILE   strip-ansi 'tickles' SIGUSR2 once line threshold hits
#   $LOGRUN_TUI_FILE     strip-ansi creates this if it sees \x1b[?1049h
# These get cleaned up on EXIT.
auto_seconds="${LOGRUN_AUTO_SECONDS:-10}"
auto_lines="${LOGRUN_AUTO_LINES:-100}"
revealed=0
auto_lines_file=""
auto_tui_file=""
auto_timer_pid=""
if (( auto_mode )); then
    auto_lines_file=$(mktemp "/tmp/logrun-lines.XXXXXX")
    auto_tui_file="/tmp/logrun-tui.$$"
    rm -f "$auto_tui_file"
fi

_logrun_on_reveal() {
    [[ -e "$auto_lines_file.shown" ]] && return
    : > "$auto_lines_file.shown"
    echo "Log: $log_path" >&2
}
# Use a marker file rather than a shell variable for the "did we reveal?"
# state, because bash signal traps run async with respect to the main
# pipeline â€” a `revealed=1` set in the trap may not be visible to the
# post-run code. The marker file is checked synchronously after the
# pipeline returns.
trap _logrun_on_reveal USR2

# --------------------------------------------------------- mid-run relocation
# Let the wrapped command ask us to move the log file to a different
# directory partway through, by writing the target DIR to
# "$LOGRUN_MOVE_FILE" and sending SIGUSR1 to "$LOGRUN_PID". The filename
# (including timestamp) is preserved; only the directory changes. The
# `logrun-move` helper wraps that handshake.
#
# Why mv works mid-stream: `tee >(strip_ansi > "$log_path")` holds an open
# fd on the inode, not the pathname. Renaming the file doesn't touch the fd,
# so subsequent writes land in the renamed file automatically.
LOGRUN_MOVE_FILE=$(mktemp "/tmp/logrun-move.XXXXXX")
export LOGRUN_PID=$$
export LOGRUN_MOVE_FILE
# Clean side-channel files on exit. The auto_lines_file/auto_tui_file are
# empty strings outside --auto mode so `rm -f ""` is a no-op.
trap 'rm -f "$LOGRUN_MOVE_FILE" "$auto_lines_file" "$auto_lines_file.shown" "$auto_tui_file"; \
      [[ -n "$auto_timer_pid" ]] && kill "$auto_timer_pid" 2>/dev/null; :' EXIT

_logrun_on_move() {
    local new_dir target
    new_dir=$(cat "$LOGRUN_MOVE_FILE" 2>/dev/null) || return
    [[ -n "$new_dir" ]] || return
    mkdir -p "$new_dir" 2>/dev/null || true
    target="$new_dir/$(basename "$log_path")"
    if [[ "$target" == "$log_path" ]]; then
        :   # no-op: already there
    elif mv "$log_path" "$target" 2>/dev/null; then
        log_path="$target"
        echo "Log moved to: $target" >&2
    fi
    : > "$LOGRUN_MOVE_FILE"
}
trap _logrun_on_move USR1

# ------------------------------------------------------------------- run it
# The startup banner is suppressed in --auto mode: it gets printed
# retroactively if/when a threshold is crossed (see _logrun_on_reveal),
# or once at the end if the run exited non-zero.
if ! (( auto_mode )); then
    echo "Log: $log_path" >&2
fi

# In --auto mode, kick off the wall-clock timer that signals SIGUSR2 to
# this script after $auto_seconds. The timer is reaped via the EXIT trap.
if (( auto_mode )); then
    ( sleep "$auto_seconds" 2>/dev/null \
        && echo "wallclock" >> "$auto_lines_file" \
        && kill -USR2 $$ 2>/dev/null ) &
    auto_timer_pid=$!
fi

# Pipeline:
#   cmd 2>&1                            â€” merge stderr into stdout
#   | tee >(filter > "$log_path")       â€” write a clean copy to the file
#   | eval "$decorator"                 â€” show the decorated stream on the tty
#
# `PIPESTATUS[0]` preserves the wrapped command's exit code regardless of
# what tee/decorator return. `set +e` isn't needed because we removed `-e`
# at the top (we rely on explicit checks below).
#
# `unbuffer`/`stdbuf` aren't needed here because both spacer and watchlog
# implement their own periodic timers â€” the decorator flushes on a timer,
# not on input.
#
# In --auto mode, the file-side filter is awk instead of sed: it strips
# the same ANSI sequences AND counts lines (signalling SIGUSR2 to the
# parent on reaching $auto_lines) AND flags alt-screen entry by touching
# $auto_tui_file.
if (( auto_mode )); then
    # --auto contract:
    #   cmd 2>&1 | tee >(awk-analyze > log) | $decorator
    #
    # The user-visible stream goes through tee | $decorator (= cat in
    # auto mode) and inherits whatever buffering tee/cat does on the
    # tty side, which is line-buffered when stdout is a tty â€” so the
    # first line of output appears immediately, before any later
    # `sleep` blocks the second.
    #
    # The file-side process substitution does triple duty in one awk
    # pass: strip ANSI for the on-disk log, count lines (signalling
    # USR2 + writing the marker file once line_thr is crossed), and
    # flag alt-screen entry into the TUI marker file.
    #
    # Why this layout vs. awk on the foreground side: gawk reads its
    # stdin in block-buffered chunks even with `fflush()`, so an awk
    # in the foreground would hold the first line until enough bytes
    # accumulated â€” exactly the bug the user hit on `ls; sleep 12; ls`.
    # On the side branch the user sees raw stdout right away.
    parent_pid=$$
    # Pre-create the log file so the failure-path FAILED rename has
    # something to rename even when the command produced no output
    # (e.g. `bash -c 'exit 7'` â€” awk never sees an input line and
    # never opens log_path on its side).
    : > "$log_path"
    # Open the process substitution as fd 4 first so we can capture
    # its pid in $! and `wait` for just that one (not the auto-mode
    # wallclock timer which is also a background job). Without this,
    # bare `wait` blocks until the timer's `sleep $auto_seconds`
    # finishes â€” which is exactly what --auto was supposed to avoid
    # for short commands.
    exec 4> >(awk -v line_thr="$auto_lines" \
                  -v lines_file="$auto_lines_file" \
                  -v tui_file="$auto_tui_file" \
                  -v parent="$parent_pid" \
                  -v log_path="$log_path" '
        BEGIN { hit_lines=0; hit_tui=0 }
        {
            if (!hit_tui && index($0, "\033[?1049h") > 0) {
                hit_tui=1
                cmd = "touch " tui_file " 2>/dev/null"; system(cmd); close(cmd)
            }
            gsub(/\033\[[0-9]+(;[0-9]+)*;?[mGK]/, "")
            gsub(/\033\[[mGK]/, "")
            gsub(/\033\[\?1049[hl]/, "")
            gsub(/\033\[\?25[hl]/, "")
            print > log_path
            fflush(log_path)
            if (!hit_lines && NR >= line_thr) {
                hit_lines=1
                cmd = "printf lines >> " lines_file; system(cmd); close(cmd)
                cmd = "kill -USR2 " parent " 2>/dev/null"; system(cmd); close(cmd)
            }
        }')
    parent_pid=$$
    awk_pid=$!
    "$@" 2>&1 \
        | tee /dev/fd/4 \
        | eval "$decorator"
    exit_code=${PIPESTATUS[0]}
    # Close fd 4 so awk sees EOF and exits, then wait specifically for
    # it. Targeted wait avoids blocking on the wallclock timer.
    exec 4>&-
    [[ -n "$awk_pid" ]] && wait "$awk_pid" 2>/dev/null
else
    "$@" 2>&1 \
        | tee >("${strip_ansi[@]}" > "$log_path") \
        | eval "$decorator"
    exit_code=${PIPESTATUS[0]}
fi

# Stop the wall-clock timer; we no longer need it.
if [[ -n "$auto_timer_pid" ]]; then
    kill "$auto_timer_pid" 2>/dev/null
    auto_timer_pid=""
fi

# ------------------------------------------------------- auto-mode disposition
if (( auto_mode )); then
    # Threshold-tripped iff the marker file is non-empty (set
    # synchronously by either the awk filter on line-count or the
    # wallclock timer). Don't rely on the in-trap variable â€” bash
    # async signal handling makes that flag unreliable here.
    [[ -s "$auto_lines_file" ]] && revealed=1

    if (( exit_code != 0 )); then
        # Failure always reveals: user needs the log path to debug.
        # Apply FAILED rename FIRST so the banner shows the renamed path.
        if [[ -n "$fail_suffix" ]]; then
            failed_path="${log_path%.txt}.${fail_suffix}"
            if mv "$log_path" "$failed_path" 2>/dev/null; then
                log_path="$failed_path"
            fi
        fi
        # Reset the .shown marker if the in-run trap already printed â€”
        # we want one final banner with the renamed path.
        rm -f "$auto_lines_file.shown"
        _logrun_on_reveal
    elif (( revealed )); then
        # Threshold tripped during the run; the trap already printed
        # the banner. Nothing to do unless the path changed.
        :
    else
        # Quiet, successful run: nothing crossed the threshold. Erase
        # the log so the prompt looks identical to a bare command.
        rm -f "$log_path"
    fi

    # Alt-screen hint: we saw a TUI we don't know about. Print once so
    # the user can tune LOGRUN_TUI_SKIPLIST.
    if [[ -f "$auto_tui_file" && -n "$cmd_name" ]]; then
        skiplist=" ${LOGRUN_TUI_SKIPLIST:-} "
        if [[ "$skiplist" != *" $cmd_name "* ]]; then
            echo "logrun: '$cmd_name' looks like a TUI (alt-screen detected); add to LOGRUN_TUI_SKIPLIST" >&2
        fi
    fi

    exit "$exit_code"
fi

# ------------------------------------------------------------------- fail tag
if (( exit_code != 0 )) && [[ -n "$fail_suffix" ]]; then
    failed_path="${log_path%.txt}.${fail_suffix}"
    if mv "$log_path" "$failed_path" 2>/dev/null; then
        log_path="$failed_path"
    fi
fi

echo "Log: $log_path" >&2
exit "$exit_code"
