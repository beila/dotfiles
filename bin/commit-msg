#!/bin/bash
# Generate a commit message from the current jj/git diff.
# Pipeline: kiro-cli (--agent no-mcp) → ollama qwen2.5-coder:3b → file-list.
# Usage: commit-msg [revision]

log() { [ "${VERBOSE:-}" = 1 ] && echo "commit-msg: $*" >&2; }

REV="${1:-@}"

# Detect if REV is a merge and gather parent info (for jj only; git merges handled via diff).
# For each parent P we collect the cumulative diff of commits on P's side of the merge
# since the previous merge on that side. Passing the actual code diffs — not just commit
# descriptions — gives the LLM enough signal to write a specific merge message.
# If the diff is too large, we fall back to the per-commit description list.
#
# Revset for the linear run of commits on P's side:
#   (::P ~ ::others) ~ ::(merges() & (::P ~ ::others) ~ P)
#   ::P ~ ::others                                    — commits unique to P's side of the merge
#   merges() & (::P ~ ::others) ~ P                   — earlier merges on P's side (excluding P itself)
#   ::(...)                                           — ancestors of those earlier merges
#   outer ~                                           — drop those ancestors, keeping only the linear
#                                                       run from P back to (but excluding) the previous
#                                                       merge on this side
#
# The "start" of that run (for the diff) is `roots(unique_revset)-`, i.e. the commit immediately
# before the oldest commit on this side — which is the previous merge (or the point where
# this side's history begins, if no previous merge exists).
is_merge=0
merge_context=""
MAX_MERGE_DIFF_LINES=${MAX_MERGE_DIFF_LINES:-500}
if command -v jj &>/dev/null && jj root &>/dev/null 2>&1; then
    parent_count=$(jj log --ignore-working-copy -r "$REV" --no-graph -T 'parents.len()' 2>/dev/null)
    if [ -n "$parent_count" ] && [ "$parent_count" -gt 1 ]; then
        is_merge=1
        parent_ids=$(jj log --ignore-working-copy -r "$REV" --no-graph -T 'parents.map(|p| p.commit_id()).join("\n")' 2>/dev/null)
        merge_context="Merge commit with $parent_count parents."
        parent_idx=0
        while IFS= read -r pid; do
            [ -z "$pid" ] && continue
            parent_idx=$((parent_idx + 1))
            others=$(echo "$parent_ids" | grep -v "^${pid}$" | paste -sd'|' -)
            parent_desc=$(jj log --ignore-working-copy -r "$pid" --no-graph \
                -T 'commit_id.short(12) ++ " " ++ description.first_line()' 2>/dev/null)

            if [ -n "$others" ]; then
                unique_revset="(::${pid} ~ ::(${others})) ~ ::(merges() & (::${pid} ~ ::(${others})) ~ ${pid})"
            else
                unique_revset="::${pid} ~ ::(merges() & ::${pid} ~ ${pid})"
            fi

            # "start" commit = parent of the oldest unique commit (the previous merge on this side).
            start=$(jj log --ignore-working-copy -r "roots($unique_revset)-" --no-graph \
                -T 'commit_id ++ "\n"' 2>/dev/null | head -1)

            side_diff=""
            if [ -n "$start" ]; then
                side_diff=$(jj diff --ignore-working-copy --from "$start" --to "$pid" --git 2>/dev/null)
            fi
            side_diff_lines=$(printf '%s' "$side_diff" | wc -l)

            if [ -n "$side_diff" ] && [ "$side_diff_lines" -le "$MAX_MERGE_DIFF_LINES" ]; then
                merge_context="$merge_context

Parent $parent_idx ($parent_desc) — cumulative diff on this side since previous merge:
$side_diff"
            else
                # Diff too large or unavailable — list commits instead (descriptions + bookmarks).
                unique_commits=$(jj log --ignore-working-copy -r "$unique_revset" --no-graph \
                    -T '"  - " ++ commit_id.short(12) ++ " " ++ description.first_line() ++ if(bookmarks, " [" ++ bookmarks ++ "]", "") ++ "\n"' 2>/dev/null)
                if [ -n "$unique_commits" ]; then
                    reason=""
                    [ -n "$side_diff" ] && reason=" (diff $side_diff_lines lines > $MAX_MERGE_DIFF_LINES, using descriptions)"
                    merge_context="$merge_context

Parent $parent_idx ($parent_desc) — commits introduced on this side since previous merge$reason:
$unique_commits"
                else
                    merge_context="$merge_context

Parent $parent_idx ($parent_desc) — no unique commits (fast-forward side)"
                fi
            fi
        done <<< "$parent_ids"
        log "merge detected with $parent_count parents; gathered per-side context"
    fi
fi

# Compact diff: deleted files as names only, full diff for modified/added.
# Use --ignore-working-copy so snapshots don't shift change_offset (the `/N` suffix
# in `change_id/N` revsets) between the caller and the two jj diff calls below.
if command -v jj &>/dev/null && jj root &>/dev/null 2>&1; then
    diff=$({
        jj diff --ignore-working-copy -r "$REV" --types 2>/dev/null | awk '$1 ~ /-$/ {print "Deleted: " substr($0, index($0,$2))}'
        jj diff --ignore-working-copy -r "$REV" --git 2>/dev/null | awk '
            /^diff --git/{header=$0; deleted=0; next}
            /^deleted file/{deleted=1; next}
            {if(!deleted){if(header){print header; header=""} print}}'
    })
else
    diff=$({
        git diff --cached --diff-filter=D --name-only 2>/dev/null | sed 's/^/Deleted: /'
        git diff --cached --diff-filter=d 2>/dev/null
    })
    if [ -z "$diff" ]; then
        diff=$({
            git diff HEAD --diff-filter=D --name-only 2>/dev/null | sed 's/^/Deleted: /'
            git diff HEAD --diff-filter=d 2>/dev/null
        })
    fi
fi

if [ -z "$diff" ] && [ "$is_merge" = 0 ]; then
    log "no changes found"
    echo "No changes to describe." >&2
    exit 1
fi

log "diff size: $(echo "$diff" | wc -l) lines"

# Cap diff sent to LLMs so we don't blow past Bedrock's input limits.
# Distribute the budget across files (so a single huge file doesn't crowd
# out the rest), each file keeps its full diff if it fits its share, or
# gets truncated with a `... [path: N more lines truncated]` marker so the
# model knows it's looking at a sample.
MAX_DIFF_LINES=${MAX_DIFF_LINES:-5000}
total_lines=$(echo "$diff" | wc -l)
if [ "$total_lines" -gt "$MAX_DIFF_LINES" ]; then
    num_files=$(echo "$diff" | grep -c '^diff --git')
    [ "$num_files" -lt 1 ] && num_files=1
    per_file=$((MAX_DIFF_LINES / num_files))
    [ "$per_file" -lt 30 ] && per_file=30  # always fit the diff --git header + a few lines
    log "capping diff: $total_lines → ~$MAX_DIFF_LINES lines across $num_files files (≤$per_file lines/file)"
    diff=$(echo "$diff" | awk -v per="$per_file" '
        BEGIN { in_file=0; file_lines=0; current_file=""; }
        /^Deleted: / { print; next }
        /^diff --git/ {
            if (in_file && file_lines > per) {
                printf "... [%s: %d more lines truncated]\n", current_file, (file_lines - per)
            }
            in_file=1; file_lines=1; current_file=$0;
            sub(/^diff --git a\//, "", current_file);
            sub(/ b\/.*$/, "", current_file);
            print; next
        }
        {
            if (in_file) {
                file_lines++
                if (file_lines <= per) print
            }
        }
        END {
            if (in_file && file_lines > per) {
                printf "... [%s: %d more lines truncated]\n", current_file, (file_lines - per)
            }
        }
    ')
fi

if [ "$is_merge" = 1 ]; then
    PROMPT_BASE="Write a concise merge commit message. Use format like 'Merge <description of what's being merged>'. Keep it under 70 characters. Output ONLY the commit message, nothing else."
    if [ -n "$diff" ]; then
        PROMPT_INPUT=$(printf '%s\n\n%s\n\nResolved merge diff (changes beyond automatic merge):\n%s' "$PROMPT_BASE" "$merge_context" "$diff")
    else
        PROMPT_INPUT=$(printf '%s\n\n%s' "$PROMPT_BASE" "$merge_context")
    fi
else
    PROMPT_BASE="Write a concise git commit message for this diff. Use conventional commit format (type: description). Output ONLY the commit message, nothing else."
    PROMPT_INPUT=$(printf '%s\n\n%s' "$PROMPT_BASE" "$diff")
fi

strip_ansi() {
    sed 's/\x1b\[[0-9;]*m//g; s/\x1b\[[?][0-9]*[a-zA-Z]//g; s/\x1b\][^\x07]*\x07//g; s/.*\r//; s/^> //'
}

# Clean LLM output to a single commit message line
clean_msg() {
    sed '/^```/d' | sed '/^$/d' | head -1
}

# try_llm_cli <label> <command> [args...]
# Pipe $PROMPT_INPUT to the command, clean output, validate, and on success
# echo the message + exit 0. Caller falls through to the next fallback otherwise.
try_llm_cli() {
    local label=$1; shift
    local prompt_file err_file raw_msg rc msg
    prompt_file=$(mktemp /tmp/commit-msg-prompt.XXXXXX)
    err_file=$(mktemp /tmp/commit-msg-err.XXXXXX)
    printf '%s' "$PROMPT_INPUT" > "$prompt_file"
    log "trying $label"
    raw_msg=$(timeout 30 "$@" < "$prompt_file" 2>"$err_file")
    rc=$?
    log "$label exit code: $rc"
    [ -s "$err_file" ] && log "$label stderr: $(cat "$err_file")"
    log "$label raw output (${#raw_msg} bytes): $(echo "$raw_msg" | head -3)"
    msg=$(echo "$raw_msg" | strip_ansi | clean_msg)
    log "$label cleaned: $msg"
    rm -f "$prompt_file" "$err_file"
    # Reject empty output, non-zero exit (some CLIs print API errors to stdout
    # then exit non-zero), or output matching login / API-error markers.
    if [ "$rc" -eq 0 ] && [ -n "$msg" ] && ! echo "$msg" | grep -qiE 'opening browser|press .*cancel|please log in|please sign in|^log in |^sign in |▰|^API Error|^Error:'; then
        log "$label succeeded: $msg"
        echo "$msg"
        exit 0
    fi
    log "$label failed (empty or invalid output)"
}

# claude: skip if already inside a Claude Code session — recursive invocations
# spawn nested instances and inherit the parent's working state.
# --tools "": no tools available, purely text generation.
# --no-session-persistence: don't write a transcript for one-shot use.
if command -v claude &>/dev/null && [ -z "$CLAUDECODE" ]; then
    try_llm_cli claude claude --print --tools "" --no-session-persistence
else
    log "claude skipped ($(! command -v claude &>/dev/null && echo "not installed" || echo "called from within claude session"))"
fi

# kiro-cli: --agent no-mcp avoids spawning orphaned MCP server processes.
if command -v kiro-cli &>/dev/null; then
    try_llm_cli kiro-cli kiro-cli chat --no-interactive --wrap never --agent no-mcp
else
    log "kiro-cli skipped (not installed)"
fi

# Fallback: ollama local LLM — start on demand, stop after
# Skip if ollama can't generate within 5s (e.g. out of memory / no GPU).
# qwen2.5-coder:3b's small context wants a far tighter prompt than kiro-cli;
# we head-cap to 200 lines and tag the truncation so the model knows.
prompt_lines=$(echo "$PROMPT_INPUT" | wc -l)
if [ "$prompt_lines" -gt 200 ]; then
    truncated_prompt=$(printf '%s\n... [prompt truncated for ollama: %d more lines]\n' \
        "$(echo "$PROMPT_INPUT" | head -200)" "$((prompt_lines - 200))")
else
    truncated_prompt="$PROMPT_INPUT"
fi
MODEL="qwen2.5-coder:3b"
if ! curl -sf http://localhost:11434/api/tags &>/dev/null; then
    log "starting ollama"
    ollama serve &>/dev/null &
    ollama_pid=$!
    for _ in $(seq 50); do curl -sf http://localhost:11434/api/tags &>/dev/null && break; sleep 0.1; done
fi
trap 'kill $ollama_pid 2>/dev/null' EXIT
log "trying ollama ($MODEL)"
if curl -sf --max-time 5 http://localhost:11434/api/generate \
    -d '{"model":"'"$MODEL"'","prompt":"hi","stream":false}' &>/dev/null; then
    log "ollama health check passed"
    msg=$(curl -sf --max-time 30 http://localhost:11434/api/generate \
        -d "$(jq -n --arg model "$MODEL" --arg prompt "$truncated_prompt" \
            '{model: $model, prompt: $prompt, stream: false}')" \
        | jq -r '.response' | clean_msg)
    if [ -n "$msg" ]; then
        log "ollama succeeded: $msg"
        echo "$msg"
        exit 0
    fi
    log "ollama failed (empty response)"
else
    log "ollama health check failed (timeout or unavailable)"
fi

# Final fallback: merge summary or file list
# Cap to first N files + "and M more" suffix so descriptions stay readable.
FALLBACK_MAX_FILES=3
FALLBACK_MAX_LEN=200
if [ "$is_merge" = 1 ]; then
    # Extract first-line descriptions of parents for a simple merge message
    parents_desc=$(echo "$merge_context" | awk -F'  - [0-9a-f]{12} ' 'NR>1 {print $2}' | head -3 | paste -sd'; ' -)
    msg="Merge: $parents_desc"
else
    # Collect all changed paths (modified/added via diff --git headers + deletes via "Deleted:" lines)
    files=$({
        echo "$diff" | grep '^diff --git' | sed 's|diff --git a/||;s| b/.*||'
        echo "$diff" | grep '^Deleted: ' | sed 's|^Deleted: ||'
    } | awk 'NF && !seen[$0]++')
    total=$(printf '%s\n' "$files" | grep -c . || true)
    if [ "$total" -eq 0 ]; then
        msg="Change (no file list available)"
    elif [ "$total" -le "$FALLBACK_MAX_FILES" ]; then
        msg="Change $(printf '%s\n' "$files" | paste -sd, -)"
    else
        head_files=$(printf '%s\n' "$files" | head -"$FALLBACK_MAX_FILES" | paste -sd, -)
        msg="Change $head_files and $((total - FALLBACK_MAX_FILES)) more"
    fi
fi
# Hard cap total length as a safety net (long single filenames, weird merge parent descs)
if [ "${#msg}" -gt "$FALLBACK_MAX_LEN" ]; then
    msg="${msg:0:$((FALLBACK_MAX_LEN - 3))}..."
fi
log "using fallback: $msg"
echo "$msg"
