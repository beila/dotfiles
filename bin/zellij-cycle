#!/usr/bin/env bash
# Zellij session cycler — wraps zellij attach in a loop.
# On detach (Alt-tab), reattaches to the next active session.
# If a session was picked via zellij-pick-session, switches to that instead.
# Exits when the terminal is gone (ghostty killed).
# Usage: zellij-cycle <default-session-name>
set -euo pipefail

SESSION="${1:-main}"
PICK_FILE="/tmp/zellij-cycle-pick.$$"
export CYCLE_PICK_FILE="$PICK_FILE"

cleanup() { rm -f "$PICK_FILE"; }
trap cleanup EXIT

next_session() {
    local cur="$1"
    local sessions
    mapfile -t sessions < <(zellij ls -n 2>/dev/null | grep -v EXITED | awk -F" \\[" '{print $1}')
    local n=${#sessions[@]}
    [ "$n" -le 1 ] && echo "$cur" && return
    for i in "${!sessions[@]}"; do
        if [ "${sessions[$i]}" = "$cur" ]; then
            echo "${sessions[$(((i + 1) % n))]}"
            return
        fi
    done
    echo "${sessions[0]}"
}

while [ -t 0 ]; do
    zellij attach --create "$SESSION" 2>/dev/null || true
    # zellij exited (detached) — check for picked session, else cycle
    [ -t 0 ] || break
    if [ -f "$PICK_FILE" ]; then
        SESSION=$(cat "$PICK_FILE")
        rm -f "$PICK_FILE"
    else
        SESSION=$(next_session "$SESSION")
    fi
    clear
done
