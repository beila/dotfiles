#!/usr/bin/env bash
# Zellij session cycler — wraps zellij attach in a loop.
# On detach (Alt-tab), reattaches to the next active session.
# If a session was picked via zellij-pick-session, switches to that instead.
# Exits when the terminal is gone (ghostty killed).
# Usage: zellij-cycle <default-session-name>
set -euo pipefail

SESSION="${1:-main}"
PICK_FILE="/tmp/zellij-cycle-pick.$$"
CYCLE_PID_FILE="/tmp/zellij-cycle-pid.$$"
CONFIG_FILE="/tmp/zellij-cycle-config.$$"

cleanup() { rm -f "$PICK_FILE" "$CYCLE_PID_FILE" "$CONFIG_FILE"; }
trap cleanup EXIT

echo $$ > "$CYCLE_PID_FILE"

# Generate per-instance config: replace CYCLE_SWITCH_CMD with a callback
# that writes the chosen session ($*) to PICK_FILE and kills the attach child.
SWITCH_CMD="'echo \$* > $PICK_FILE \\&\\& pkill -P \\\$(cat $CYCLE_PID_FILE)'"
sed "s|CYCLE_SWITCH_CMD|$SWITCH_CMD|g" ~/.config/zellij/config.kdl > "$CONFIG_FILE"

next_session() {
    local cur="$1"
    local sessions
    mapfile -t sessions < <(zellij ls -n 2>/dev/null | grep -v EXITED | awk -F" \\[" '{print $1}')
    local n=${#sessions[@]}
    [ "$n" -le 1 ] && echo "$cur" && return
    for i in "${!sessions[@]}"; do
        if [ "${sessions[$i]}" = "$cur" ]; then
            echo "${sessions[$(((i + 1) % n))]}"
            return
        fi
    done
    echo "${sessions[0]}"
}

while [ -t 0 ]; do
    zellij --config "$CONFIG_FILE" attach --create "$SESSION" 2>/dev/null || true
    [ -t 0 ] || break
    if [ -f "$PICK_FILE" ]; then
        SESSION=$(cat "$PICK_FILE")
        rm -f "$PICK_FILE"
    else
        SESSION=$(next_session "$SESSION")
    fi
    clear
done
