#!/usr/bin/env bash
# Claude Code Stop hook: speaks the last paragraph of the assistant's final
# response. Korean (contains Hangul) → say-ko; otherwise → say.
#
# stdin: {"session_id": "...", "transcript_path": "/path/to/session.jsonl", ...}
# Output: print {"continue": true, "suppressOutput": true} so the hook is silent.
set -u

DOTFILES_ROOT="${DOTFILES_ROOT:-$HOME/.dotfiles}"
SAY="$DOTFILES_ROOT/bin/say"
MAX_CHARS=${CLAUDE_TTS_MAX_CHARS:-500}

# Always exit 0 — Stop hook errors would loop or block. Print no-op response on any failure.
trap 'printf "{\"continue\": true, \"suppressOutput\": true}\n"; exit 0' EXIT

# Read transcript path from stdin JSON.
input=$(cat)
transcript=$(printf '%s' "$input" | jq -r '.transcript_path // empty' 2>/dev/null)
[ -z "$transcript" ] || [ ! -f "$transcript" ] && exit 0

# Find the last assistant message and extract its text content.
text=$(tac "$transcript" | while IFS= read -r line; do
    role=$(printf '%s' "$line" | jq -r '.message.role // empty' 2>/dev/null)
    [ "$role" != "assistant" ] && continue
    # message.content is an array of blocks; concatenate text-block text fields.
    printf '%s' "$line" | jq -r '
        .message.content
        | if type == "array" then map(select(.type == "text") | .text) | join("\n")
          else . end
    ' 2>/dev/null
    break
done)

[ -z "$text" ] && exit 0

# Take the last non-empty paragraph (paragraphs separated by blank lines).
last_para=$(printf '%s' "$text" | awk -v RS='' 'NF {p=$0} END {print p}')
[ -z "$last_para" ] && exit 0

# Strip markdown noise and code-fence-only paragraphs.
cleaned=$(printf '%s' "$last_para" \
    | sed -E 's/`[^`]*`/ /g' \
    | sed -E 's/\*+([^*]+)\*+/\1/g' \
    | sed -E 's/\[([^]]+)\]\([^)]+\)/\1/g' \
    | sed -E 's/^[[:space:]]*[-*+>][[:space:]]+//' \
    | tr -s '[:space:]' ' ' \
    | sed 's/^ //; s/ $//')

[ -z "$cleaned" ] && exit 0

# Cap length so long responses don't read forever.
if [ "${#cleaned}" -gt "$MAX_CHARS" ]; then
    cleaned="${cleaned:0:$MAX_CHARS}"
fi

# Speak in the background so the hook returns immediately. setsid detaches
# from the Claude Code controlling tty so the audio outlives the turn. The
# `say` dispatcher routes Hangul → say-ko, otherwise → say-en.
[ -x "$SAY" ] && setsid "$SAY" "$cleaned" </dev/null >/dev/null 2>&1 &
disown 2>/dev/null || true

exit 0
