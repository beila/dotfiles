#!/usr/bin/env python3
"""logrun-decorator — passthrough until SIGUSR2, then spacer-style idle indicators.

Used by `logrun --auto` so short runs feel like a bare command (no
spacer/watchlog tail) while long runs still get visual breaks. logrun
sends SIGUSR2 when it crosses --auto's line/wallclock threshold. Until
that signal arrives we behave as plain `cat`.

Activated mode behavior (after SIGUSR2):
  - prints a thin "──── HH:MM:SS Xs" line each time stdout has been
    silent for `--after` seconds (default 1.0). Format mirrors
    `spacer --right --force-color` minus the date (always today in an
    interactive run, so it's just noise): dim dashes (left), yellow
    time, blue elapsed-since-previous-spacer (right). The elapsed
    value is wall time since the last spacer line (or program start),
    per spacer's source — NOT the just-finished idle gap; it shows
    you how long it's been since you last saw activity flagged.
  - lightweight idle indicator on stderr ("idle 5s", overwriting in
    place) when no output for `--idle` seconds (default 3); cleared on
    next byte. Mimics `watchlog`.

Single dependency: stdlib. Two writers (stdout, stderr) + one input
pump. `select()` on a 0.1s tick handles both timers without threads.
"""
from __future__ import annotations

import argparse
import os
import select
import shutil
import signal
import sys
import time

PARSER = argparse.ArgumentParser(description=__doc__.splitlines()[0])
PARSER.add_argument("--after", type=float, default=1.0,
                    help="seconds of idle before printing a spacer line (default: 1.0)")
PARSER.add_argument("--idle", type=float, default=3.0,
                    help="seconds before stderr 'idle Ns' indicator (default: 3.0)")
PARSER.add_argument("--no-color", action="store_true")
PARSER.add_argument("--activate-when-exists",
                    help="path to a marker file; this decorator stays in passthrough "
                         "mode until the file exists, then activates idle indicators. "
                         "Equivalent to receiving SIGUSR2.")
args = PARSER.parse_args()

def _ansi(code: str) -> str:
    return "" if args.no_color else f"\x1b[{code}m"


DIM = _ansi("2")
RESET = _ansi("0")
# Colors mirror powerlevel10k's right-prompt segments so spacer lines
# read as a continuation of the prompt's visual language:
#   COMMAND_EXECUTION_TIME_FOREGROUND=3 (yellow) → elapsed
#   TIME_FOREGROUND=6                   (cyan)  → wall-clock time
YELLOW = _ansi("33")
CYAN = _ansi("36")
DEFAULT_FG = _ansi("39")
ERASE_LINE = "\x1b[2K\r"

_active = False


def _activate(_signum, _frame):
    global _active
    _active = True


signal.signal(signal.SIGUSR2, _activate)


def _term_width():
    try:
        return shutil.get_terminal_size().columns
    except OSError:
        return 80


def _format_elapsed(seconds: float) -> str:
    # Compact, fixed-max-width formats so the time column aligns:
    #   < 60s   "1.5s" / "59.9s"      (≤ 5 chars)
    #   < 1h    "1m05s"               (5 chars; minutes 0-pad seconds)
    #   ≥ 1h    "1h05m"               (5 chars; drop seconds — at this
    #                                  scale, second-precision is noise)
    if seconds < 60:
        return f"{seconds:.1f}s"
    if seconds < 3600:
        m, s = divmod(int(seconds), 60)
        return f"{m}m{s:02d}s"
    h, rem = divmod(int(seconds), 3600)
    m, _ = divmod(rem, 60)
    return f"{h}h{m:02d}m"


_ELAPSED_WIDTH = 5  # fits "59.9s", "9m59s", "9h59m" — practical ceiling


def _spacer_line(elapsed: float):
    # Layout: dim dashes (left) · yellow elapsed · cyan time (right).
    # Order and colors match p10k's right-prompt segments
    # (command_execution_time → time) so the spacer reads as a
    # continuation of the prompt's visual language. Elapsed is right-
    # justified in a fixed _ELAPSED_WIDTH slot so the time column lines
    # up across spacer lines regardless of elapsed's natural length.
    cols = _term_width()
    time_str = time.strftime("%H:%M:%S")
    elapsed_raw = _format_elapsed(elapsed) if elapsed > 0.1 else ""
    elapsed_padded = elapsed_raw.rjust(_ELAPSED_WIDTH)
    tail_visible = f"{elapsed_padded} {time_str}"
    dashes = max(1, cols - len(tail_visible) - 1)
    if elapsed_raw:
        tail_colored = (
            f"{YELLOW}{elapsed_padded}{DEFAULT_FG} "
            f"{CYAN}{time_str}{DEFAULT_FG}"
        )
    else:
        # Pad with plain spaces; no color escapes so the slot stays empty.
        tail_colored = f"{' ' * _ELAPSED_WIDTH} {CYAN}{time_str}{DEFAULT_FG}"
    sys.stdout.write(f"{DIM}{'─' * dashes}{RESET} {tail_colored}\n")
    sys.stdout.flush()


def _idle_indicator(secs: int):
    sys.stderr.write(f"{ERASE_LINE}{DIM}idle {secs}s{RESET}")
    sys.stderr.flush()


def _idle_clear():
    sys.stderr.write(ERASE_LINE)
    sys.stderr.flush()


def main():
    global _active
    stdin_fd = sys.stdin.fileno()
    start = time.monotonic()
    last_output = start
    last_spacer = start  # for the "elapsed since last spacer" value
    spacer_pending = False
    idle_shown = False
    marker = args.activate_when_exists

    while True:
        # Short tick so we can run timers even when stdin is silent.
        rlist, _, _ = select.select([stdin_fd], [], [], 0.1)
        now = time.monotonic()

        if not _active and marker and os.path.exists(marker):
            _active = True

        if rlist:
            try:
                buf = os.read(stdin_fd, 65536)
            except OSError:
                buf = b""
            if not buf:
                break
            if idle_shown:
                _idle_clear()
                idle_shown = False
            sys.stdout.buffer.write(buf)
            sys.stdout.buffer.flush()
            last_output = now
            spacer_pending = True
            continue

        if not _active:
            continue

        idle_for = now - last_output
        # Print a spacer line once after the gap crosses --after, but only
        # when there's been output since the last spacer.
        if spacer_pending and idle_for >= args.after:
            _spacer_line(now - last_spacer)
            last_spacer = now
            spacer_pending = False
            last_output = now  # reset so the indicator timer doesn't double-count
            continue
        # Idle indicator after --idle (cumulative seconds, redrawn each tick).
        if idle_for >= args.idle:
            _idle_indicator(int(idle_for))
            idle_shown = True

    if idle_shown:
        _idle_clear()


if __name__ == "__main__":
    try:
        main()
    except (BrokenPipeError, KeyboardInterrupt):
        pass
