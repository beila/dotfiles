#!/usr/bin/env -S just --justfile

import? '~/.justfile'

[private]
default:
    @just --list --unsorted

all: sysroots toolchain mixed sye symbol_wrapper

clean: clean_mixed
    rm -rf sysroots/ install/

clean_all:
    rm -rf build/{llvm,sysroots} sysroots/ install/

build:
    nix develop --command bash -xc "./build_sysroots.sh && ./build_toolchain.sh && ./build_examples.sh mixed"

sysroots:
    nix develop --command ./build_sysroots.sh

toolchain:
    nix develop --command ./build_toolchain.sh

mixed:
    rm -rf build/examples/mixed/
    nix develop --command ./build_examples.sh mixed
    readelf --all build/examples/mixed/x86_64-unknown-linux-gnu/libmixed.so | grep toupper

clean_mixed:
    rm -rf build/examples/mixed/

musl:
    nix develop --command just _musl

_musl:
    #!/usr/bin/env zsh
    set -xe -o pipefail

    SCRIPT_DIR=$(pwd)
    targets=(
        "x86_64-unknown-linux-gnu"
        #"armv7-unknown-linux-gnueabihf"
        #"armv7-unknown-linux-gnueabi"
        #"aarch64-unknown-linux-gnu"
    )

    for target in "${targets[@]}"; do
        mkdir -p "$SCRIPT_DIR/build/sysroots/musl-${target}"
        cd "$SCRIPT_DIR/build/sysroots/musl-${target}"
        export AR="$SCRIPT_DIR/build/llvm/bin/llvm-ar"
        export RANLIB="$SCRIPT_DIR/build/llvm/bin/llvm-ranlib"
        export CC="$SCRIPT_DIR/build/llvm/bin/clang --no-default-config --target=${target} --rtlib=compiler-rt -fuse-ld=lld -fno-stack-protector --sysroot=$SCRIPT_DIR/sysroots/${target}/"
        export LIBCC="$SCRIPT_DIR/build/sysroots/builtins-${target}/lib/${target}/libclang_rt.builtins.a"
        "$SCRIPT_DIR/external/musl/configure" --target="${target}" --srcdir="$SCRIPT_DIR/external/musl" --prefix="$SCRIPT_DIR/sysroots/${target}/usr" --disable-gcc-wrapper --disable-shared
        make -j64 install
    done

    readelf --all build/sysroots/musl-x86_64-unknown-linux-gnu/lib/libc.a | grep iswupper_l

clean_musl:
    rm -rf build/sysroots/musl*

sye:
    nix develop ../syewasmbundle --command just _sye

_sye:
    #!/usr/bin/env zsh
    set -xe -o pipefail

    DIR=$(pwd)
    cd ../syewasmbundle
    BUILD_TARGET=x86_64-unknown-linux-gnu ./ci-build.sh --toolchain $DIR/toolchain.cmake

    readelf --all build-native/src/wasm_bundle/libsye_wasm_bundle.so |grep iswupper_l

clean_sye:
    #!/usr/bin/env zsh
    set -xe -o pipefail

    DIR=$(pwd)
    cd ../syewasmbundle
    rm -rf build-native

symbol_wrapper:
    #!/usr/bin/env zsh
    set -xe -o pipefail

    DIR=$(pwd)
    cd ../i/devc1/src/elf-loader/scripts

    nix develop --command python3 symbol_wrapper.py $DIR/build-native/src/wasm_bundle/libsye_wasm_bundle.so
