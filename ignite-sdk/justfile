#!/usr/bin/env -S just --justfile

#import? '~/.justfile'

[private]
default:
    @just --list --unsorted

all: sysroots toolchain sye

clean: 
    #!/usr/bin/env zsh
    setopt -o nullglob extendedglob
    set -x
    rm -rf build/^(log-|llvm)* install/ sysroots/

clean_all: clean clean_sye
    rm -rf build/llvm  # We don't usually need to change this

alias clean_everything := clean_all

sdk:
    ./build_sysroots.sh &&
    ./build_toolchain.sh &&
    ./build_examples.sh mixed || just merge_compile_commands $?

sysroots:
    ./build_sysroots.sh || just merge_compile_commands $?

    readelf --all build/sysroots/musl-x86_64-unknown-linux-gnu/lib/libc.a | grep vsnprintf

toolchain:
    ./build_toolchain.sh

mixed:
    rm -rf build/examples/mixed/

    ./build_examples.sh mixed || just merge_compile_commands $?

    readelf --all build/examples/mixed/x86_64-unknown-linux-gnu/libmixed.so | grep toupper

clean_examples:
    rm -rf build/examples

musl:
    #!/usr/bin/env zsh
    set -xe -o pipefail

    SCRIPT_DIR=$(pwd)
    targets=(
        "x86_64-unknown-linux-gnu"
        "armv7-unknown-linux-gnueabihf"
        "armv7-unknown-linux-gnueabi"
        "aarch64-unknown-linux-gnu"
    )

    for target in "${targets[@]}"; do
        mkdir -p "$SCRIPT_DIR/build/sysroots/musl-${target}"
        cd "$SCRIPT_DIR/build/sysroots/musl-${target}"
        export AR="$SCRIPT_DIR/build/llvm/bin/llvm-ar"
        export RANLIB="$SCRIPT_DIR/build/llvm/bin/llvm-ranlib"
        export CC="$SCRIPT_DIR/build/llvm/bin/clang --no-default-config --target=${target} --rtlib=compiler-rt -fuse-ld=lld -fno-stack-protector --sysroot=$SCRIPT_DIR/sysroots/${target}/"
        export LIBCC="$SCRIPT_DIR/build/sysroots/builtins-${target}/lib/${target}/libclang_rt.builtins.a"
        "$SCRIPT_DIR/external/musl/configure" --target="${target}" --srcdir="$SCRIPT_DIR/external/musl" --prefix="$SCRIPT_DIR/sysroots/${target}/usr" --disable-gcc-wrapper --disable-shared
        make -j64 install-headers
    done

clean_musl:
    rm -rf sysroots/
    rm -rf build/sysroots/musl* || true # in case * fails to expand

sye:
    #!/usr/bin/env bash
    set -xe -o pipefail

    targets=(
        "x86_64-unknown-linux-gnu"
        "armv7-unknown-linux-gnueabihf"
        "armv7-unknown-linux-gnueabi"
        "aarch64-unknown-linux-gnu"
    )

    for BUILD_TARGET in "${targets[@]}"; do
        cmake ../syewasmbundle \
            -Bbuild/sye/$BUILD_TARGET/ \
            -DBUILD_TARGET_TRIPLE=${BUILD_TARGET} \
            -DCMAKE_BUILD_TYPE=RelWithDebInfo \
            -DCMAKE_CXX_FLAGS="-fdata-sections -ffunction-sections -femulated-tls -v" \
            -DCMAKE_C_FLAGS="-fdata-sections -ffunction-sections -femulated-tls -v" \
            -DCMAKE_EXE_LINKER_FLAGS="-Wl,--exclude-libs,ALL -Wl,-gc-sections" \
            -DCMAKE_SHARED_LINKER_FLAGS="-Wl,--exclude-libs,ALL -Wl,-gc-sections -Wl,--trace-symbol,vsscanf" \
            -DCMAKE_TOOLCHAIN_FILE=$(pwd)/toolchain.cmake \
            -DPLATFORM_NAME=native \
            -G Ninja ||
                just merge_compile_commands $?
        cmake --build build/sye/$BUILD_TARGET/ --target sye_wasm_bundle
    done

    set +xe +o pipefail

    (diff --suppress-common-lines <(
            grep REG -R ../i/devc1/src/elf-loader/src |
                sed 's/.*(\(.*\)).*/\1/'|sort -u
        ) <(
            readelf -s --wide build/sye/*/src/wasm_bundle/libsye_wasm_bundle.so |
                awk '/ UND /{print $8}' | sort | uniq
        )
    ) | grep '^>'

clean_sye:
    rm -rf build/sye

syewasmbundle_integ_tests: sye
    #!/usr/bin/env zsh
    set -xe -o pipefail

    cmake --build build/sye/x86_64-unknown-linux-gnu --target test_integ_sye_wasm_bundle
    mkdir -p ../i/devc1/build_sye
    cp -f build/sye/x86_64-unknown-linux-gnu/tests/integration/libtest_integ_sye_wasm_bundle.so ../i/devc1/build_sye/
    just --justfile ../i/devc1/justfile sye pv --set-default-native-engine=Ignite --local-native-path=$(realpath $(pwd)/../i/devc1/build_sye/libtest_integ_sye_wasm_bundle.so) --log-level=ALL:INFO

symbol_wrapper:
    #!/usr/bin/env zsh
    set -xe -o pipefail

    DIR=$(pwd)
    cd ../i/devc1/src/elf-loader/scripts

    nd() { which nix &> /dev/null && test -f flake.nix && echo "nix develop --command" }
    $(nd) python3 symbol_wrapper.py $DIR/build/sye/src/wasm_bundle/libsye_wasm_bundle.so $DIR/sysroots/x86_64-unknown-linux-gnu

ignite_test_assets:
    ./build_examples.sh ignite-elf-test

clean_ignite_test_assets:
    rm -rf ../i/devc1/tests/assets/elf/build/*

ignite_test: ignite_test_assets
    #!/usr/bin/env bash
    set -eo pipefail
    DIR=$(pwd)
    cd ../i/devc1

    cp -vr ${DIR}/build/examples/ignite-elf-test/aarch64-unknown-linux-gnu/*.so tests/assets/elf/aarch64/ || true
    cp -vr ${DIR}/build/examples/ignite-elf-test/armv7-unknown-linux-gnueabi/*.so tests/assets/elf/armv7/ || true
    cp -vr ${DIR}/build/examples/ignite-elf-test/armv7-unknown-linux-gnueabihf/*.so tests/assets/elf/armv7_vfp/ || true
    cp -vr ${DIR}/build/examples/ignite-elf-test/x86_64-unknown-linux-gnu/*.so tests/assets/elf/x86_64/

    just unit '--gtest_filter=ElfLoaderTest.\*' --log-level=script:info,wasm:info
    #just unit '--gtest_filter=ElfLoaderTest.\*' --log-level=script_engine:trace,script:info,wasm:info

# Merge all compile_commands.json under build_dir
[group('Utilities')]
[no-exit-message]
merge_compile_commands exit_code="0":
    @rm -f build/compile_commands.json
    jq -s add $(find build/*/ -name compile_commands.json) > build/compile_commands.json
    exit {{ exit_code }}
