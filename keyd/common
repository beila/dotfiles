# keyd common bindings — included by all keyboard configs
# Not affected by GNOME keymap resets.
#
# Tap actions are handled by xmonad key bindings:
#   prog1/XF86Launch1 (Super tap)  → Albert toggle
#   prog2/XF86Launch2 (Alt_L tap)  → ghostty scratchpad 1
#   prog3/XF86Launch3 (Alt_R tap)  → ghostty scratchpad 2
#   Volume keys (Pause/ScrollLock/PrtSc) → volume-osd / cycle-audio

[main]

# overloadt2: only activates as modifier if held for timeout ms OR if another
# key is tapped while held. Prevents accidental modifier when typing fast.

# CapsLock: hold → Control, tap → Escape
capslock = overloadt2(control, esc, 150)

# Super: hold → Super, tap → prog1 (XF86Launch1, albert via xmonad)
leftmeta = overloadt2(meta, prog1, 150)

# Left Alt: hold → Alt, tap → prog2 (XF86Launch2, ghostty1 via xmonad)
leftalt = overloadt2(alt, prog2, 150)

# Right Alt: hold → Alt, tap → prog3 (XF86Launch3, ghostty2 via xmonad)
rightalt = overloadt2(alt, prog3, 150)

# Right Control: hold → Control, tap → apostrophe
rightcontrol = overloadt2(control, apostrophe, 150)

# Pause/ScrollLock/PrintScreen → volume keys
pause = volumeup
scrolllock = volumedown
sysrq = mute

[alt]
pause = brightnessup
scrolllock = brightnessdown
