# keyd common bindings — included by all keyboard configs
# Not affected by GNOME keymap resets.
#
# Tap actions are handled by xmonad key bindings:
#   prog1/f21 → XF86TouchpadToggle (Super tap)  → Albert toggle
#   prog2/f22 → XF86TouchpadOn     (Alt_L tap)  → ghostty scratchpad 1
#   prog3/f23 → XF86TouchpadOff    (Alt_R tap)  → ghostty scratchpad 2
#   Volume keys (Pause/ScrollLock/PrtSc) → volume-osd / cycle-audio
#
# Note: keyd v2.6.0 maps prog1/2/3 to f21/f22/f23 (evdev 191/192/193),
# NOT to KEY_PROG1/2/3 (evdev 148/149/202). The X keysyms are
# XF86TouchpadToggle/On/Off, not XF86Launch1/2/3.

[main]

# overloadt2: only activates as modifier if held for timeout ms OR if another
# key is tapped while held. Prevents accidental modifier when typing fast.

# CapsLock: hold → Control, tap → Escape
capslock = overloadt2(control, esc, 150)

# Super: hold → Super, tap → prog1 (XF86Launch1, albert via xmonad)
leftmeta = overloadt2(meta, prog1, 150)

# Left Alt: hold → Alt, tap → prog2 (XF86Launch2, ghostty1 via xmonad)
leftalt = overloadt2(alt, prog2, 150)

# Right Alt: hold → Alt, tap → prog3 (XF86Launch3, ghostty2 via xmonad)
rightalt = overloadt2(alt, prog3, 150)

# Right Control: hold → Control, tap → apostrophe
rightcontrol = overloadt2(control, apostrophe, 150)

# Pause/ScrollLock/PrintScreen → volume keys
pause = volumeup
scrolllock = volumedown
sysrq = mute

[alt]
pause = brightnessup
scrolllock = brightnessdown

# Super+C / Super+V → universal copy/paste.
#
# Emits a TWO-token macro on each press because no single keysym works
# everywhere on Linux:
#   1. bare `copy` / `paste` keysym (X11: XF86Copy / XF86Paste,
#      evdev: KEY_COPY / KEY_PASTE) — handled by ghostty
#      (default `keybind = copy=copy_to_clipboard:mixed` /
#      `keybind = paste=paste_from_clipboard`), firefox / GTK / Qt apps,
#      native VTE terminals. neovide silently drops these — its
#      get_special_key table (src/window/keyboard_manager.rs) has no
#      NamedKey::Copy / NamedKey::Paste case.
#   2. `f24` / `f20` — high F-keys with no default bindings anywhere
#      (xmonad / GNOME / ghostty / firefox). Neovide's get_special_key
#      table explicitly lists NamedKey::F1–F35 → "F1".."F35", so they
#      reach nvim as <F24> / <F20>. F21–F23 are reserved for prog1/2/3
#      (albert / scratchpads); KEY_F24 (194) is the kernel F-key
#      ceiling. F20 is the next free slot below the prog range.
#
# CAVEAT — X11 keysym overrides required: xkb's default `inet` rules bind
# X11 keycodes 198/202 (= evdev F20/F24) to XF86AudioMicMute / unmapped.
# winit then can't translate them into NamedKey::F20 / F24, so neovide
# drops them too. xmonad's startupHook runs `xmodmap -e 'keycode 198 = F20'
# -e 'keycode 202 = F24'` to override that — see xmonad.symlink/xmonad.hs.
# Removing that xmodmap call breaks the neovide path.
#
# Each app reacts to whichever keysym it's bound to and silently ignores
# the other:
#   - ghostty:   handles `copy`/`paste`, no default F20/F24 binding
#   - firefox:   GTK handles XF86Copy/Paste, no F20/F24 binding
#   - xmonad:    no bindings on F20/F24 or `copy`/`paste`
#   - neovide:   drops bare keysym (no NamedKey case), maps <F24>/<F20> in
#                nvim/.../vimrcs/my-clipboard.lua (mode-aware behaviour:
#                visual = selection, normal/insert = <cword>, command =
#                cmdline; paste uses "+P / "_d"+P / <C-r>+ as appropriate)
#
# Note: keyd's bare key names are lowercase `copy`/`paste`/`f24`/`f20` —
# NOT `XF86Copy` or `macro(XF86Paste)`. `macro(<unknown>)` would treat the
# token as a string and type the literal characters.
[meta]
c = macro(copy f24)
v = macro(paste f20)

# Super+Shift+V → copyq toggle (clipboard history picker, bound in xmonad).
# Super+Shift+C → killWindow (xmonad gnomeConfig default).
# Without this composite layer, [meta]'s explicit `v = ...` / `c = ...` would
# fire even when Shift is also held, swallowing the xmonad bindings: Super+
# Shift+V would emit a paste macro, and Super+Shift+C would emit a copy macro
# whose Shifted F24 modifier state ends up reaching xmonad as Super+Shift+C
# unpredictably (sometimes killing the window, sometimes not, depending on
# keysym-to-keycode resolution timing).
[meta+shift]
v = M-S-v
c = M-S-c
