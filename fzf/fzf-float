#!/usr/bin/env bash
# fzf-float: run fzf in a zellij floating pane
# Usage: pipe input | fzf-float [fzf args...]
set -euo pipefail

# Resolve real fzf binary (not shell function/alias)
FZF_BIN=$(command -v fzf)

tmpdir=$(mktemp -d /tmp/fzf-float.XXXXXX)
trap 'rm -rf "$tmpdir"' EXIT

cat > "$tmpdir/in"
touch "$tmpdir/out"

# Save args NUL-delimited so the runner can read them without quoting issues
printf '%s\0' "$@" > "$tmpdir/args"

# Save env vars that fzf reads
env | grep -E '^(FZF_DEFAULT_OPTS|BAT_|DOTFILES|HOME|PATH|TERM|COLORTERM|LANG|LC_)=' > "$tmpdir/env" || true

# The runner script reads args back from the file
cat > "$tmpdir/run.sh" << 'RUNNER'
#!/usr/bin/env bash
dir="$1"
fzf_bin="$2"
set -a; source "$dir/env" 2>/dev/null; set +a
# Strip --height/--min-height since the floating pane IS the viewport
args=()
while IFS= read -r -d '' arg; do
  case "$arg" in
    --height|--min-height) read -r -d '' _ ;; # skip flag + value
    --height=*|--min-height=*) ;;              # skip --flag=value
    *) args+=("$arg") ;;
  esac
done < "$dir/args"
"$fzf_bin" "${args[@]}" < "$dir/in" > "$dir/out"
RUNNER

zellij action new-pane --floating --close-on-exit --blocking \
  --width 90% --height 90% \
  -- bash "$tmpdir/run.sh" "$tmpdir" "$FZF_BIN" \
  || true

cat "$tmpdir/out"
