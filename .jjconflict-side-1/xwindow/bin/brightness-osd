#!/bin/bash
# Change brightness and show OSD via dzen2.
# Uses a FIFO so rapid key presses update text without flicker.
# Usage: brightness-osd up|down
FIFO="/tmp/brightness-osd-fifo"
LOCKFILE="/tmp/brightness-osd-lock"

start_dzen() {
    rm -f "$FIFO"
    mkfifo "$FIFO"
    scale=$(xrdb -query 2>/dev/null | awk '/Xft.dpi/{printf "%d", $2/96}')
    : "${scale:=1}"
    (tail -f "$FIFO" | dzen2 -p -x $((100*scale)) -y $((430*scale)) -w $((1240*scale)) -h $((100*scale)) \
        -fn "JetBrainsMono Nerd Font:size=36:style=Bold" \
        -bg "#0d0d1a" -fg "#f8f8a0" -title-name "bright-osd") &
    sleep 0.2
}

[ -p "$FIFO" ] || start_dzen

pct=$(brightnessctl -m | awk -F, '{print $4}' | tr -d '%')

case "$1" in
    up)
        if [ "$pct" -lt 20 ]; then
            brightnessctl set +5%
        else
            brightnessctl set +10%
        fi
        ;;
    down)
        if [ "$pct" -le 20 ]; then
            brightnessctl set 5%-
        else
            brightnessctl set 10%-
        fi
        ;;
esac

pct=$(brightnessctl -m | awk -F, '{print $4}' | tr -d '%')

bar=""
filled=$((pct / 5))
for ((i=0; i<20; i++)); do
    if [ $i -lt $filled ]; then bar+="━"; else bar+="┄"; fi
done
text="  󰃠  $bar  ${pct}%"

echo "$text" > "$FIFO"

echo $$ > "$LOCKFILE"
(sleep 2; [ "$(cat "$LOCKFILE" 2>/dev/null)" = "$$" ] && pkill -f "dzen2.*bright-osd" && rm -f "$FIFO") &
