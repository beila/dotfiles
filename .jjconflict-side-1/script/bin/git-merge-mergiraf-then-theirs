#!/usr/bin/env bash
# git-merge-mergiraf-then-theirs — git merge driver that runs mergiraf
# first (syntax-aware merge) and falls back to taking theirs on the hunks
# mergiraf couldn't resolve.
#
# Pipeline:
#   1. Snapshot %A (mergiraf --git overwrites it in place).
#   2. Try `mergiraf merge --git` for syntax-aware (tree-sitter) merging.
#      If it exits clean (rc=0), keep its output. Done.
#   3. Otherwise restore the original %A and run `git merge-file --theirs`
#      against the unmodified inputs — line-merge clean hunks, take theirs
#      for conflicting hunks.
#
# Why this exists: %A by the time we run is the file mergiraf scribbled
# conflict markers into. Re-running merge-file against that would treat
# the markers as our content. Restoring %A from the snapshot first makes
# the fallback a real 3-way of the *original* sides.
#
# Args (matches gitattributes/git-merge-file conventions):
#   $1 = %O (base)
#   $2 = %A (ours / output — driver writes the merged result here)
#   $3 = %B (theirs)
#   $4 = %P (path; passed to mergiraf for language detection)
#   $5 = %L (conflict marker size)
#
# Exit:
#   0 on clean merge (driver fully resolved)
#   non-zero if the final merge-file --theirs itself failed (rare —
#   merge-file --theirs only conflicts on parse errors, and even then it
#   takes theirs for those hunks too)

set -u

base=$1 ours=$2 theirs=$3 path=$4 markersz=$5

snapshot=$(mktemp --suffix=.smart-theirs)
trap 'rm -f "$snapshot"' EXIT
cp -- "$ours" "$snapshot"

# Mergiraf substitutes literal %S/%X/%Y if not provided, so pass dummies
# for callers (like jj's resolve-by-attrs) that can't supply real revision
# labels. The labels only affect conflict-marker text, and we strip those
# below if mergiraf fails anyway.
if mergiraf merge --git "$base" "$ours" "$theirs" \
                  -p "$path" -l "$markersz" \
                  -s local -x base -y other 2>/dev/null; then
  exit 0
fi

# Mergiraf wrote conflict markers into $ours (or some other partial state).
# Restore from the snapshot and let git merge-file --theirs handle it.
cp -f -- "$snapshot" "$ours"
exec git merge-file --theirs --marker-size="$markersz" -- "$ours" "$base" "$theirs"
