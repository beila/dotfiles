#!/usr/bin/env bash
# logrun-move — ask the surrounding `logrun` wrapper to relocate its log
# file to a different directory. The filename (including timestamp) is
# preserved. Works only while running as a descendant of `logrun` (which
# exports $LOGRUN_PID and $LOGRUN_MOVE_FILE).
#
# Usage: logrun-move NEW_DIR
#
# Typical use inside a justfile recipe:
#     logrun-move "{{ build_dir }}"
set -u

if [[ -z "${LOGRUN_PID:-}" || -z "${LOGRUN_MOVE_FILE:-}" ]]; then
    echo "logrun-move: not running under logrun" >&2
    exit 1
fi
if [[ $# -ne 1 || -z "$1" ]]; then
    echo "Usage: logrun-move NEW_DIR" >&2
    exit 2
fi

# Atomic write so the signal handler never sees a truncated path.
tmp="${LOGRUN_MOVE_FILE}.new.$$"
printf '%s' "$1" > "$tmp" && mv "$tmp" "$LOGRUN_MOVE_FILE"
kill -USR1 "$LOGRUN_PID"
