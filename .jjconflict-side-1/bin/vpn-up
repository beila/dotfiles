#!/usr/bin/env bash
# vpn-up — start a VPN client and supervise it with vpn-watch.
#
# Why: openconnect installs DNS + routes pointing at the VPN concentrator.
# If the underlying network changes (Wi-Fi roam home -> café -> office)
# without first tearing down the tunnel, the box ends up with a dead tunnel
# that still claims to be the default route — every DNS lookup hangs and
# the network is effectively inaccessible until the user notices. vpn-up
# bundles two things into one foreground command:
#   1. The VPN client itself (caller supplies via $1 / VPN_START_CMD).
#      The client is expected to do its own sudo prompt up front (e.g.
#      amazon-vpn calls `sudo /bin/true` then `sudo openconnect …`).
#   2. vpn-watch in the background, which monitors NetworkManager
#      connectivity and SIGTERMs the VPN process the moment it drops.
#      The watcher's `sudo -n pkill` reuses the cache the VPN client just
#      primed, and `sudo -nv` keeps it warm via VPN_SUDO_REFRESH.
# When the VPN client exits (user disconnect, watcher kill, network
# failure), vpn-up tears down the watcher and returns.
#
# Usage:
#   vpn-up                          # uses $VPN_START_CMD
#   vpn-up amazon-vpn               # explicit start command (positional)
#   VPN_PROCESS_NAME=foo vpn-up ... # override what to pkill on loss
#
# Env (also forwarded to vpn-watch):
#   VPN_START_CMD       command to run in the foreground (e.g. "amazon-vpn")
#                       — required if no positional argument given
#   VPN_PROCESS_NAME    name to pkill (default "openconnect")
#   VPN_DEBOUNCE_SEC    debounce window (default 5; see vpn-watch)
#   VPN_SUDO_REFRESH    sudo cache refresh interval (default 240)
#   VPN_STARTUP_WAIT    seconds to wait for VPN process at start (default 30)

set -uo pipefail

LOG_TAG=vpn-up
DOTFILES_ROOT=${DOTFILES_ROOT:-$HOME/.dotfiles}
# shellcheck source=/dev/null
source "$DOTFILES_ROOT/script/logger/log.sh"

# Resolve the start command.
if [ "$#" -gt 0 ]; then
    START_CMD=("$@")
elif [ -n "${VPN_START_CMD:-}" ]; then
    # shellcheck disable=SC2206 -- intentional word-split for cmd+args
    START_CMD=(${VPN_START_CMD})
else
    log ERROR "no VPN start command — pass as positional arg or set \$VPN_START_CMD"
    exit 2
fi

if ! command -v "${START_CMD[0]}" >/dev/null 2>&1; then
    log ERROR "VPN start command not found: ${START_CMD[0]}"
    exit 127
fi

# Spawn the watcher first so it's already running by the time the VPN
# client primes sudo — vpn-watch's startup wait gives the client time to
# both prompt for sudo and spawn the actual VPN process before the watcher
# starts polling. The watcher will reuse the sudo cache primed by the
# client when it later needs to `pkill -TERM` on connectivity loss.
"$DOTFILES_ROOT/bin/vpn-watch" &
WATCHER_PID=$!

cleanup() {
    if kill -0 "$WATCHER_PID" 2>/dev/null; then
        kill -TERM "$WATCHER_PID" 2>/dev/null || true
        wait "$WATCHER_PID" 2>/dev/null || true
    fi
}
trap cleanup EXIT INT TERM

log INFO "starting ${START_CMD[*]}; watcher pid=$WATCHER_PID"

# Run the VPN client in the foreground. When it exits, cleanup() reaps
# the watcher.
"${START_CMD[@]}"
rc=$?
log INFO "${START_CMD[0]} exited rc=$rc"
exit "$rc"
