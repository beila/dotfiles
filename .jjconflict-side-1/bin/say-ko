#!/usr/bin/env bash
# Korean text-to-speech via edge-tts (requires internet)
# Usage: say-ko "한국어 텍스트" or echo "텍스트" | say-ko
VOICE="${EDGE_TTS_VOICE:-ko-KR-SunHiNeural}"
if [ $# -gt 0 ]; then
    TEXT="$*"
else
    TEXT="$(cat)"
fi
[ -z "$TEXT" ] && exit 0
TMP="$(mktemp /tmp/say-ko-XXXXXX.mp3)"
trap 'rm -f "$TMP"' EXIT
RATE="${EDGE_TTS_RATE:-+50%}"
uv run --quiet --with edge-tts -- edge-tts --voice "$VOICE" --rate "$RATE" --text "$TEXT" --write-media "$TMP" 2>/dev/null \
  && ffmpeg -v quiet -i "$TMP" -f wav -acodec pcm_s16le -ar 24000 -ac 1 pipe:1 2>/dev/null \
  | aplay -q 2>/dev/null
