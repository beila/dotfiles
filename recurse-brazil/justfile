c *command: mwinit
    ssh dev-dsk-$(whoami)-1c-1d10d9ca.eu-west-1.amazon.com "{{ command }}"

# Run `eval $(just setup_shell)` for aliases (jbuild, jrelase, etc) and command completion
setup_shell:
    #!/usr/bin/env zsh
    for recipe in `just --summary`
    do
        echo "alias j$recipe=\"just $recipe\""
    done
    echo "alias jm=\"just mwinit\""
    echo "alias jmf=\"just mwinitf\""

    just --completions $(basename $SHELL)

alias m := mwinit
alias mf := mwinitf
