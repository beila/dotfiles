[no-cd]
collect_deps_AVLivingRoomRustClient:
    #!/usr/bin/env python3
    import tomllib
    import os
    import pathlib
    with open("Cargo.toml") as main_file:
        for line in main_file:
            if line == '[patch.crates-io]\n':
                exit()

    source_dir = pathlib.Path('../IgnitionXRustBundle')
    patches=({'name':p['name'], 'path':str(path.parent)}
        for path in source_dir.rglob('Cargo.toml')
        for file in [open(path, 'rb')]
        for toml in [tomllib.load(file)]
        if 'package' in toml
        for p in [toml['package']]
    )

    #for p in patches: print(p)
    #with open("Cargo.toml", "r+") as main_file:
        #toml = tomllib.loads(main_file)
        #toml.update({'patch.crates-io':list(patches)})
        #main_file.write(toml.dump(toml))
    with open("Cargo.toml", "a") as main_file:
        main_file.write('[patch.crates-io]\n')
        for p in patches:
            main_file.write(p['name'] + ' = { path = "' + p['path'] + '"}\n')

[no-cd]
build_AVLivingRoomClientBundle:
    brazil-build run build -- -f Ignition-X-XP --nobytecode --noaot --nothreads --nonativebundle=false
    strings build/lib_debug/*client-*.so|grep 'always_return_true'

[no-cd]
release_AVLivingRoomClientBundle:
    brazil-build run put-this-on-that -- --flavor Ignition-X-XP --dtid=A3VN4E5F7BBC7S --did=abcd$(whoami)abcd --stringBundles en_US

[no-cd]
native_app:
    #!/usr/bin/env zsh
    name=native_app just run "
        cd ../AVLivingRoomRustClient/crates/app-start &&
        just pre_build &&
        cargo build -p amzn-av-living-room-rust-client --lib --features=amzn-ignx-compositron/allow_no_js_vm,amzn-ignx-compositron/use_ignx_local
    "

