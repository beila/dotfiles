# Local/private config goes in the include
[include]
        path = ~/.gitconfig.local
[color]
        diff = auto
    status = auto
        branch = auto
        ui = true
[core]
        excludesfile = ~/.gitignore
        editor = vim
	autocrlf = input
	safecrlf = false
[push]
        # See `git help config` (search for push.default)
        # for more information on different options of the below setting.
        #
        # Setting to git 2.0 default to suppress warning message
	default = upstream
[merge]
	conflictStyle = zdiff3
	tool = nvimdiff
# https://lwn.net/Articles/1042355/#:~:text=%5Bmerge%20%22mergiraf%22%5D,%25Y%20%2Dp%20%25P%20%2Dl%20%25L
[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --verbose --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
# Registers the `ours` merge driver used by lockfile patterns in
# git.configsymlink/attributes. Git's built-in merge drivers are only
# text/binary/union (per gitattributes(5)); `-s ours` is a whole-commit
# strategy, not a per-path driver. `true` exits 0 without modifying %A
# so our side is preserved.
[merge "ours"]
	name = Keep our version
	driver = true
# `mergiraf-then-theirs`: syntax-aware merge first (mergiraf understands
# JSON / TOML / Java / Rust / etc. via tree-sitter); on hunks mergiraf
# can't reconcile, fall back to taking theirs. Structurally additive
# changes from both sides merge cleanly (e.g. distinct entries appended
# to a JSON array from two machines); genuine semantic conflicts collapse
# to theirs. Logic lives in `script/bin/git-merge-mergiraf-then-theirs`
# because the snapshot-and-restore dance was too gnarly to inline here.
[merge "mergiraf-then-theirs"]
	name = mergiraf first, theirs on conflict
	driver = ~/.dotfiles/script/bin/git-merge-mergiraf-then-theirs %O %A %B %P %L
# `mergiraf-then-ours`: same shape as -theirs but keeps OUR side on
# conflict. Use when the local machine's value is the source of truth
# (e.g. Claude Code settings.json fields like awsCredentialExport that
# each machine fills in with its own absolute $HOME — never accept the
# incoming value, it's from another machine). Sibling driver script.
[merge "mergiraf-then-ours"]
	name = mergiraf first, ours on conflict
	driver = ~/.dotfiles/script/bin/git-merge-mergiraf-then-ours %O %A %B %P %L
[rerere]
	enabled = true
[alias]
	#dag = log --graph --format='format:%C(yellow)%h%C(reset) %C(blue)\"%an\" <%ae>%C(reset) %C(magenta)%cr%C(reset)%C(auto)%d%C(reset)%n%s' --date-order
    dag = log --graph --format='format:%C(yellow)%h%C(reset) %C(blue)\"%an\" <%ae>%C(reset) %C(magenta)%cd%C(reset)%C(auto)%d%C(reset)%n%s' --date='format:%y-%m-%d' --date-order
[pull]
	ff = only
[protocol "codecommit"]
	allow = always
[init]
	defaultBranch = main
[rebase]
	autoSquash = true
	updateRefs = true
	autoStash = true
[diff]
    colorMoved = default
	submodule = log
	external = difft
[commit]
	verbose = true
[clone]
	defaultRemoteName = origin

# Defininig a custom hunk-header in man gitattributes
[diff "artworkstoml"]
    xfuncname = "^title *=.*$"

[fetch]
	prunetags = true
	prune = true
	parallel = 0
[credential]
	helper = !aws codecommit credential-helper $@
	UseHttpPath = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
