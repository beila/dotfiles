#!/bin/bash
# Battery genmon script for xfce4-panel
bat=/sys/class/power_supply/BAT0
if [ ! -d "$bat" ]; then
    echo "<txt>⚡ AC</txt>"
    echo "<tool>No battery detected</tool>"
    exit 0
fi
cap=$(cat "$bat/capacity")
status=$(cat "$bat/status")
case "$status" in
    Charging)    icon="🔌" ;;
    Full)        icon="🔋" ;;
    *)  if   [ "$cap" -ge 80 ]; then icon="🔋"
        elif [ "$cap" -ge 50 ]; then icon="🔋"
        elif [ "$cap" -ge 20 ]; then icon="🪫"
        else                         icon="🪫"
        fi ;;
esac
echo "<txt>${icon} ${cap}%</txt>"
# tooltip with details
energy_now=$(cat "$bat/energy_now" 2>/dev/null)
energy_full=$(cat "$bat/energy_full" 2>/dev/null)
power_now=$(cat "$bat/power_now" 2>/dev/null)
tip="Status: $status
Level:  ${cap}%"
if [ -n "$power_now" ] && [ "$power_now" -gt 0 ]; then
    watts=$(awk "BEGIN{printf \"%.1f\", $power_now/1000000}")
    tip="$tip
Power:  ${watts}W"
    if [ "$status" = "Discharging" ] && [ -n "$energy_now" ]; then
        hrs=$(awk "BEGIN{printf \"%.1f\", $energy_now/$power_now}")
        tip="$tip
Time:   ~${hrs}h remaining"
    elif [ "$status" = "Charging" ] && [ -n "$energy_full" ] && [ -n "$energy_now" ]; then
        hrs=$(awk "BEGIN{printf \"%.1f\", ($energy_full-$energy_now)/$power_now}")
        tip="$tip
Time:   ~${hrs}h to full"
    fi
fi
echo "<tool>$tip</tool>"
