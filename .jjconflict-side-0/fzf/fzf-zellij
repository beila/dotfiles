#!/usr/bin/env bash
# fzf-zellij: starts fzf in a zellij floating pane
# usage: fzf-zellij [LAYOUT OPTIONS] [--] [FZF OPTIONS]
#
# Also injects a layout-aware ctrl-/ preview-cycle binding (down,50% when
# --reverse, up,50% otherwise) so prompt and preview always anchor opposite
# ends of the screen — see the binding logic further down for the rationale.

fail() { >&2 echo "$1"; exit 2; }

fzf="$(command which fzf)" || fzf="$(dirname "$0")/fzf"
[[ -x $fzf ]] || fail 'fzf executable not found'

args=()
skip=""

# Adaptive default size based on terminal width:
#   - wide screens (>=200 cols, e.g. ultrawide / external): 80% × 85% so the
#     underlying pane peeks ~10% on each side and you can still read context.
#   - narrow screens (laptop, ~150-180 cols): 98% × 92% so we don't waste
#     columns on a margin that's too thin to be useful anyway.
# CLI flags below (-w / -h / -p) still override these defaults verbatim.
_cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 0)}
if (( _cols >= 200 )); then
  width="80%"
  height="85%"
else
  width="98%"
  height="92%"
fi
unset _cols

while [[ $# -gt 0 ]]; do
  arg="$1"; shift
  [[ -z $skip ]] && case "$arg" in
    --help)
      >&2 echo 'usage: fzf-zellij [-p W,H | -w W -h H] [--] [FZF OPTIONS]'; exit ;;
    -w*) if [[ ${#arg} -gt 2 ]]; then width="${arg:2}"; else width="$1"; shift; fi ;;
    -h*) if [[ ${#arg} -gt 2 ]]; then height="${arg:2}"; else height="$1"; shift; fi ;;
    -p*)
      if [[ ${#arg} -gt 2 ]]; then size="${arg:2}"
      elif [[ ${1:-} =~ ^[0-9%,]+$ ]]; then size="$1"; shift
      else size="90%"; fi
      width=${size%%,*}; height=${size##*,} ;;
    --) skip=1; continue ;;
    *) args+=("$arg") ;;
  esac
  [[ -n $skip ]] && args+=("$arg")
done

# ctrl-/ vertical preview position: place the preview on the OPPOSITE end
# from the prompt so the list always sits between them (visual flow:
# prompt → list → preview).
#
#   layout      | prompt at | preview goes
#   ------------+-----------+--------------
#   --reverse   | top       | bottom (down,50%)  ← FZF_DEFAULT_OPTS default
#   default     | bottom    | top    (up,50%)    ← override added here
#
# FZF_DEFAULT_OPTS in fzf.zsh sets the down,50% default because the most
# common widgets are reversed (built-in fzf-cd-widget / fzf-file-widget
# inject --reverse via fzf's own __fzf_defaults; fzf-tab uses --reverse;
# our log dispatchers _jh/_jhh/_jyy/_jy/_gs all pass --reverse via
# fzf_down). When --reverse is NOT present we append a later --bind that
# overrides the FZF_DEFAULT_OPTS one (fzf's last-bind-wins semantics).
#
# Detection looks at BOTH command-line args (where fzf_down callers put
# --reverse) AND FZF_DEFAULT_OPTS env var (where fzf's built-in widgets
# inject --reverse via __fzf_defaults before invoking us). --layout=reverse
# and --layout=reverse-list both treated as reversed.
reversed=0
for a in "${args[@]}"; do
  case "$a" in
    --reverse|--layout=reverse|--layout=reverse-list) reversed=1; break ;;
  esac
done
if (( ! reversed )); then
  # Normalize whitespace (FZF_DEFAULT_OPTS may contain newlines from fzf's
  # __fzf_defaults printf-based composition) and pad with spaces so the
  # boundary checks below match whole tokens.
  _opts=" ${FZF_DEFAULT_OPTS//[$'\n\t']/ } "
  case "$_opts" in
    *' --reverse '*|*' --layout=reverse'*) reversed=1 ;;
  esac
  unset _opts
fi
if (( ! reversed )); then
  args+=("--bind=ctrl-/:change-preview-window(up,50%|hidden|)")
fi

# Outside zellij or already in a fzf-zellij pane: just run fzf directly
if [[ -z ${ZELLIJ:-} ]] || [[ -n ${FZF_ZELLIJ:-} ]]; then
  if [[ -n ${FZF_ZELLIJ:-} ]]; then
    # Strip --height/--min-height since the floating pane IS the viewport
    filtered=(); skip=""
    for a in "${args[@]}"; do
      if [[ -n $skip ]]; then skip=""; continue; fi
      case "$a" in
        --height=*|--min-height=*) ;;
        --height|--min-height) skip=1 ;;
        *) filtered+=("$a") ;;
      esac
    done
    args=("${filtered[@]}")
  fi
  "$fzf" "${args[@]}"
  exit $?
fi

# --height not meaningful in a floating pane
args=("${args[@]}" "--no-height" "--bind=ctrl-z:ignore")

tmpdir=$(mktemp -d "${TMPDIR:-/tmp}/fzf-zellij-XXXXXX")
trap '\rm -rf "$tmpdir"' EXIT

output="$tmpdir/out"
argsf="$tmpdir/args"
touch "$output"

# Build the script to run in the floating pane
{
  echo "export TERM=$(printf %q "$TERM")"
  echo "export PATH=$(printf %q "$PATH")"
  echo "export FZF_ZELLIJ=1"
  echo "export FZF_DEFAULT_OPTS=$(printf %q "${FZF_DEFAULT_OPTS:-}")"
  # Built-in widgets set FZF_DEFAULT_COMMAND from FZF_ALT_C_COMMAND /
  # FZF_CTRL_T_COMMAND before calling __fzfcmd; without forwarding, fzf
  # falls back to its --walker.
  [[ -n ${FZF_DEFAULT_COMMAND:-} ]] && echo "export FZF_DEFAULT_COMMAND=$(printf %q "$FZF_DEFAULT_COMMAND")"
  [[ -n ${BAT_THEME:-} ]] && echo "export BAT_THEME=$(printf %q "$BAT_THEME")"
  echo "trap 'touch $(printf %q "$tmpdir/done")' EXIT"
  echo -n "\"$fzf\""
  for a in "${args[@]}"; do printf ' %q' "$a"; done
  if [[ ! -t 0 ]]; then
    mkfifo "$tmpdir/fifo"
    echo " < $(printf %q "$tmpdir/fifo") > $(printf %q "$output")"
  else
    echo " > $(printf %q "$output")"
  fi
} > "$argsf"

# Feed stdin into FIFO in background (streams data as it arrives)
if [[ ! -t 0 ]]; then
  cat <&0 > "$tmpdir/fifo" &
fi

# Suppress stdout: zellij run prints pane name (e.g. "terminal_45") which would
# otherwise contaminate fzf-zellij's own stdout and get picked up by callers'
# post-processing pipelines (e.g. _gh extracting jj change IDs)
zellij run --floating --close-on-exit \
  --width "$width" --height "$height" \
  --cwd "$PWD" \
  -- bash "$argsf" \
  >/dev/null 2>&1 || {
  "$fzf" "${args[@]}"
  exit $?
}

# Wait for pane's bash to exit (EXIT trap touches done marker, works even after become)
while [[ ! -f "$tmpdir/done" ]]; do sleep 0.05; done

# Strip \r (zellij pty leaves CRs) and any stray "terminal_NN" lines from
# zellij output that may have slipped past the redirection
sed -e 's/\r$//' -e '/^terminal_[0-9]*$/d' "$output"
