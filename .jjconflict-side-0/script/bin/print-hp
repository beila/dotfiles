#!/usr/bin/env bash
# print-hp — send a file to an HP network printer via raw JetDirect (port 9100).
#
# Why this exists:
#   Some CUPS print servers (e.g. older Synology bundled CUPS 1.5 with a broken
#   rastertogutenprint filter) silently drop PDF jobs. This script bypasses
#   CUPS entirely and streams PostScript directly to the printer's JetDirect
#   port. It's also faster — no filter re-encoding.
#
# Features:
#   - Uses the cached IP as long as it still answers on port 9100 (cheap
#     /dev/tcp probe, CACHE_PROBE_TIMEOUT seconds). Otherwise falls back to
#     an nmap scan of $SUBNET. Override with --ip / $PRINT_HP_IP.
#   - Accepts PDF (converted to PS), PostScript, or text files.
#   - Optional page range for PDF (--pages 3, --pages 2-5, --pages 3-, --pages -5).
#   - --dry-run skips the final send and leaves the payload for inspection.
#   - Prints A4 duplex by default.
#
# Requires:
#   - nmap                  (network scan)
#   - ncat or netcat        (raw TCP send on port 9100)
#   - pdftops               (poppler-utils — converts PDF → PS)
#   - enscript              (optional — pretty-prints text files)

set -euo pipefail

# ─── Defaults (override via flags / env vars) ──────────────────────────────
SUBNET="${PRINT_HP_SUBNET:-192.168.1.0/24}"
HP_IP="${PRINT_HP_IP:-}"
PAPER="${PRINT_HP_PAPER:-A4}"
DUPLEX=1
PAGE_FIRST=""
PAGE_LAST=""
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/print-hp"
SCAN_TIMEOUT=30
# Probe timeout when re-verifying a cached IP. Long enough for a sleeping
# printer to complete the TCP handshake on 9100 after being woken; still
# much faster than an nmap scan of a /22 subnet.
CACHE_PROBE_TIMEOUT=8
NC_TIMEOUT=60

usage() {
  cat <<'USAGE'
Usage:  print-hp [OPTIONS] FILE

Sends FILE to an HP network printer at port 9100 (JetDirect). Auto-discovers
the printer on the local subnet and caches the IP until it stops responding.

OPTIONS
  -h, --help             Show this help
  -d, --discover         Print the detected printer IP and exit
  -i, --ip IP            Skip discovery, use this IP
  -s, --simplex          Single-sided (default: duplex, long-edge)
  -p, --paper SIZE       Paper size for PDF conversion (default: A4)
      --pages RANGE      Page range for PDF only. Formats:
                           N      single page (e.g. 3)
                           N-M    range          (e.g. 2-5)
                           N-     from N to end  (e.g. 3-)
                           -M     start to M     (e.g. -5)
  -n, --no-cache         Force a fresh network scan
      --subnet CIDR      Subnet to scan (default: 192.168.1.0/24)
      --timeout SECS     Max transfer time (default: 60)
      --dry-run          Do everything except send to the printer.
                         Leaves the converted payload at a printed path.

SUPPORTED FORMATS
  .pdf            — converted to PostScript locally
  .ps / .eps      — sent as-is
  .txt and others — pretty-printed via enscript if available, else raw

ENVIRONMENT
  PRINT_HP_IP      Override auto-discovery (e.g. "192.168.1.42")
  PRINT_HP_SUBNET  Subnet to scan (default: 192.168.1.0/24)
  PRINT_HP_PAPER   Paper size (default: A4)

EXAMPLES
  print-hp document.pdf
  print-hp --simplex notes.txt
  print-hp --pages 3 report.pdf               # only page 3
  print-hp --pages 2-5 report.pdf             # pages 2 through 5
  print-hp -d                                  # just show the printer IP
  PRINT_HP_IP=192.168.1.42 print-hp report.pdf
  print-hp --subnet 10.0.0.0/24 receipt.pdf
USAGE
}

err()  { printf '\033[31m✗\033[0m %s\n' "$*" >&2; }
ok()   { printf '\033[32m✓\033[0m %s\n' "$*"; }
info() { printf '\033[36m→\033[0m %s\n' "$*"; }
warn() { printf '\033[33m!\033[0m %s\n' "$*" >&2; }

# ─── Arg parsing ───────────────────────────────────────────────────────────
DISCOVER_ONLY=0
FORCE_RESCAN=0
DRY_RUN=0
FILE=""
PAGES_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)      usage; exit 0 ;;
    -d|--discover)  DISCOVER_ONLY=1; shift ;;
    -i|--ip)        HP_IP="$2"; shift 2 ;;
    -s|--simplex)   DUPLEX=0; shift ;;
    -p|--paper)     PAPER="$2"; shift 2 ;;
    -n|--no-cache)  FORCE_RESCAN=1; shift ;;
    --subnet)       SUBNET="$2"; shift 2 ;;
    --timeout)      NC_TIMEOUT="$2"; shift 2 ;;
    --pages)        PAGES_ARG="$2"; shift 2 ;;
    --dry-run)      DRY_RUN=1; shift ;;
    --)             shift; FILE="${1:-}"; break ;;
    -*)             err "Unknown option: $1"; usage >&2; exit 2 ;;
    *)              FILE="$1"; shift ;;
  esac
done

# ─── Parse --pages RANGE ───────────────────────────────────────────────────
# Accepted: N, N-M, N-, -M
if [[ -n "$PAGES_ARG" ]]; then
  if [[ "$PAGES_ARG" =~ ^([0-9]+)$ ]]; then
    PAGE_FIRST="${BASH_REMATCH[1]}"
    PAGE_LAST="${BASH_REMATCH[1]}"
  elif [[ "$PAGES_ARG" =~ ^([0-9]+)-([0-9]+)$ ]]; then
    PAGE_FIRST="${BASH_REMATCH[1]}"
    PAGE_LAST="${BASH_REMATCH[2]}"
    if (( PAGE_FIRST > PAGE_LAST )); then
      err "--pages range reversed: $PAGES_ARG (first page > last page)"
      exit 2
    fi
  elif [[ "$PAGES_ARG" =~ ^([0-9]+)-$ ]]; then
    PAGE_FIRST="${BASH_REMATCH[1]}"
  elif [[ "$PAGES_ARG" =~ ^-([0-9]+)$ ]]; then
    PAGE_LAST="${BASH_REMATCH[1]}"
  else
    err "--pages: unrecognised range '$PAGES_ARG'. Use N, N-M, N-, or -M."
    exit 2
  fi
fi

# ─── Discover printer ──────────────────────────────────────────────────────
nmap_cmd() {
  if command -v nmap &>/dev/null; then
    echo nmap
  elif command -v nix &>/dev/null; then
    echo "nix shell nixpkgs#nmap --command nmap"
  else
    err "nmap not found. Install nmap or pass --ip."
    exit 3
  fi
}

discover() {
  local cache_file="$CACHE_DIR/hp-ip"
  mkdir -p "$CACHE_DIR"

  if [[ -n "$HP_IP" ]]; then
    info "Using printer IP: $HP_IP (from flag/env)"
    echo "$HP_IP" > "$cache_file"
    return
  fi

  # Try the cached IP first — most printers keep their DHCP lease for days,
  # so a short TCP probe on port 9100 is far cheaper than an nmap sweep of
  # a /22. CACHE_PROBE_TIMEOUT is generous enough for a sleeping printer to
  # wake on the handshake. Age is informational only; we trust the probe.
  if [[ "$FORCE_RESCAN" -eq 0 ]] && [[ -f "$cache_file" ]]; then
    local cached_ip cache_age
    cached_ip=$(cat "$cache_file")
    cache_age=$(( ( $(date +%s) - $(stat -c %Y "$cache_file") ) / 60 ))
    if [[ -n "$cached_ip" ]] && timeout "$CACHE_PROBE_TIMEOUT" bash -c ": </dev/tcp/$cached_ip/9100" 2>/dev/null; then
      HP_IP="$cached_ip"
      info "Using cached printer IP: $HP_IP (cached ${cache_age} min ago, port 9100 responsive)"
      # Touch the cache file so age reflects last-verified, not last-discovered.
      touch "$cache_file"
      return
    fi
    [[ -n "$cached_ip" ]] && warn "Cached IP $cached_ip not responding on 9100 — rescanning"
  fi

  info "Scanning $SUBNET for printer on port 9100 (may take ~20s)..."
  local scan
  # shellcheck disable=SC2086
  scan=$(timeout "$SCAN_TIMEOUT" $(nmap_cmd) -Pn -p 9100 --open --min-rate 200 "$SUBNET" 2>/dev/null \
    | awk '/Nmap scan report for/ { ip=$NF; gsub(/[()]/,"",ip); next } /9100\/tcp open/ { print ip }')

  local count
  count=$(printf '%s\n' "$scan" | grep -c '^[0-9]' || true)

  if [[ "$count" -eq 0 ]]; then
    err "No printer found on $SUBNET. Make sure it's powered on and on the same network."
    exit 4
  fi
  if [[ "$count" -gt 1 ]]; then
    warn "Multiple printers found — picking the first. Others:"
    printf '%s\n' "$scan" | sed 's/^/    /'
  fi

  HP_IP=$(printf '%s\n' "$scan" | head -n 1)
  ok "Found printer at $HP_IP"
  echo "$HP_IP" > "$cache_file"
}

# ─── Prepare payload ───────────────────────────────────────────────────────
PAYLOAD=""
PAYLOAD_IS_PS=0   # 1 when PAYLOAD is PostScript and safe to wrap with PJL
CLEANUP=()

cleanup() {
  # In dry-run mode we keep the payload so the caller can inspect it.
  if [[ "$DRY_RUN" -eq 1 ]] && [[ -n "$PAYLOAD" ]] && [[ -f "$PAYLOAD" ]]; then
    info "Dry-run: payload left at $PAYLOAD"
    # Remove the payload from CLEANUP before deleting the rest.
    local -a keep=()
    local f
    for f in "${CLEANUP[@]}"; do
      [[ "$f" == "$PAYLOAD" ]] || keep+=("$f")
    done
    CLEANUP=("${keep[@]}")
  fi
  [[ ${#CLEANUP[@]} -gt 0 ]] && rm -f "${CLEANUP[@]}"
}
trap cleanup EXIT

prepare_payload() {
  local file="$1"
  local ext="${file##*.}"
  ext="${ext,,}"

  if [[ -n "$PAGES_ARG" ]] && [[ "$ext" != "pdf" ]]; then
    err "--pages is only supported for PDF files (got .$ext)."
    exit 2
  fi

  case "$ext" in
    ps|eps)
      PAYLOAD="$file"
      PAYLOAD_IS_PS=1
      ;;
    pdf)
      if ! command -v pdftops &>/dev/null; then
        err "pdftops not found. Install poppler-utils."
        exit 5
      fi
      PAYLOAD=$(mktemp --suffix=.ps)
      CLEANUP+=("$PAYLOAD")
      local -a pdftops_args=(-paper "$PAPER" -level3)
      [[ -n "$PAGE_FIRST" ]] && pdftops_args+=(-f "$PAGE_FIRST")
      [[ -n "$PAGE_LAST"  ]] && pdftops_args+=(-l "$PAGE_LAST")
      if [[ -n "$PAGE_FIRST$PAGE_LAST" ]]; then
        info "Converting PDF → PostScript ($PAPER, pages ${PAGE_FIRST:-1}-${PAGE_LAST:-end})..."
      else
        info "Converting PDF → PostScript ($PAPER)..."
      fi
      pdftops "${pdftops_args[@]}" "$file" "$PAYLOAD"
      PAYLOAD_IS_PS=1
      ok "Converted: $(du -h "$PAYLOAD" | cut -f1)"
      ;;
    *)
      # Treat as text. Use enscript if available for nice formatting.
      if command -v enscript &>/dev/null; then
        PAYLOAD=$(mktemp --suffix=.ps)
        CLEANUP+=("$PAYLOAD")
        info "Pretty-printing text → PostScript..."
        local dup_flag=""
        [[ "$DUPLEX" -eq 1 ]] && dup_flag="--duplex"
        # shellcheck disable=SC2086
        enscript --output="$PAYLOAD" --media="$PAPER" $dup_flag \
                 --fancy-header --line-numbers "$file" 2>/dev/null || {
          warn "enscript failed — falling back to raw text"
          PAYLOAD="$file"
        }
        if [[ -s "$PAYLOAD" ]] && [[ "$PAYLOAD" != "$file" ]]; then
          PAYLOAD_IS_PS=1
          ok "Prepared: $(du -h "$PAYLOAD" | cut -f1)"
        fi
      else
        warn "enscript not installed — sending raw text (no margins/font)"
        PAYLOAD="$file"
      fi
      ;;
  esac
}

# Wrap a PostScript payload with PJL DUPLEX directives so the printer honours
# the duplex setting regardless of its panel default. Raw JetDirect (port 9100)
# bypasses CUPS, so duplex flags from pdftops/enscript inside the PS aren't
# enough — we need PJL, which overrides the device default for this job only
# and resets at @PJL RESET.
wrap_with_pjl_duplex() {
  local in="$1" want_duplex="$2"
  local out
  out=$(mktemp --suffix=.ps)
  CLEANUP+=("$out")

  # PJL header / trailer use UEL (<ESC>%-12345X) per HP's PJL spec.
  local uel=$'\x1b%-12345X'
  {
    printf '%s@PJL\n' "$uel"
    if [[ "$want_duplex" -eq 1 ]]; then
      printf '@PJL SET DUPLEX=ON\n'
      printf '@PJL SET BINDING=LONGEDGE\n'
    else
      printf '@PJL SET DUPLEX=OFF\n'
    fi
    printf '@PJL ENTER LANGUAGE=POSTSCRIPT\n'
    cat "$in"
    printf '%s' "$uel"
    printf '@PJL RESET\n'
    printf '%s' "$uel"
  } > "$out"

  PAYLOAD="$out"
}

# ─── Send to printer ───────────────────────────────────────────────────────
send_to_printer() {
  local file="$1"
  local ip="$2"
  local size
  size=$(du -h "$file" | cut -f1)

  if [[ "$DRY_RUN" -eq 1 ]]; then
    info "Dry-run: would send $size to $ip:9100 (not sending)"
    return
  fi

  info "Sending $size to $ip:9100 (timeout ${NC_TIMEOUT}s)..."

  local -a nc_cmd
  if command -v ncat &>/dev/null; then
    nc_cmd=(ncat --send-only -w "${NC_TIMEOUT}s" "$ip" 9100)
  elif command -v nc &>/dev/null; then
    nc_cmd=(nc -q 5 -w "$NC_TIMEOUT" "$ip" 9100)
  else
    err "No ncat or nc found. Install ncat (from nmap) or netcat."
    exit 7
  fi

  if "${nc_cmd[@]}" < "$file"; then
    ok "Data delivered. Pages should start in ~30s."
  else
    err "Failed to send print data to $ip:9100"
    exit 8
  fi
}

# ─── Main ──────────────────────────────────────────────────────────────────
if [[ "$DISCOVER_ONLY" -eq 1 ]]; then
  discover
  echo "$HP_IP"
  exit 0
fi

if [[ -z "$FILE" ]]; then
  err "No file specified."
  usage >&2
  exit 2
fi

if [[ ! -f "$FILE" ]]; then
  err "File not found: $FILE"
  exit 2
fi

discover
prepare_payload "$FILE"
if [[ "$PAYLOAD_IS_PS" -eq 1 ]]; then
  wrap_with_pjl_duplex "$PAYLOAD" "$DUPLEX"
fi
send_to_printer "$PAYLOAD" "$HP_IP"
