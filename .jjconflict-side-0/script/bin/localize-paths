#!/usr/bin/env bash
# localize-paths — stream filter that replaces the placeholder string
# `$USER_HOME` with this machine's $HOME literal. Pure stdin → stdout
# filter, no file I/O of its own. Exact inverse of `generalize-paths`.
#
# Round-trip identity:
#   foo | generalize-paths | localize-paths == foo
#   foo | localize-paths | generalize-paths == foo
#
# Used by script/bootstrap on a fresh clone to expand placeholders that
# tools like the Amazon `claude` binary or xfconf can't expand themselves.
# Most tools (shells, anything that interpolates env vars in config) will
# resolve `$USER_HOME` at runtime because home-manager and zshenv
# export it as USER_HOME=$HOME. The localize step is for the holdouts.
#
# Mechanism notes:
#   - $HOME is expanded by the calling shell at exec time.
#   - The literal placeholder is the eight-character string $USER_HOME;
#     sed sees it after one round of shell quoting, hence the `\$` and the
#     surrounding double quotes. The `\\\$` in jj fix's TOML produces `\$`
#     after sh -c, which sed reads as the literal `$`.

set -eu

if [[ -z "${HOME:-}" ]]; then
  echo "localize-paths: \$HOME is unset" >&2
  exit 2
fi

exec sed "s|\\\$USER_HOME|$HOME|g"
